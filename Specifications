Database


    public class Document
    {
        public int Id { get; set; }
       
        [Required]
        public string Name { get; set; }
       
        public string Description { get; set; }
             
        // Stocke l'empreinte du fichier pour vérifier l'intégrité
        public byte[] FileContent{ get; set; }
       
        public long FileSize { get; set; }
       
        public string ContentType { get; set; }
       
        public DateTime UploadDate { get; set; }
       
        public DateTime? LastModifiedDate { get; set; }
       
        [Required]
        public int OwnerId { get; set; }
       
        public virtual Utilisateur Owner { get; set; }
       
        public virtual ICollection<DocumentShare> SharedWith { get; set; }
    }

    public class DocumentShare
    {
        public int DocumentId { get; set; }
        public virtual Document Document { get; set; }
       
        public int SharedWithUserId { get; set; }
        public virtual Utilisateur SharedWithUser { get; set; }
       
        public DateTime SharedDate { get; set; }
       
        public DateTime? ExpiryDate { get; set; }

        public string Email { get; set; }

    }



