function isNullOrEmpty(value) {
    return value === null
        || value === undefined
        || value === "";
}


function refreshReaRejPersonnePhysique(
    index,
    typeRelationAffaireId,
    typeRelationAffaireTra3Id,
    isInitialization) {

    var isTra3 =
        typeRelationAffaireId === typeRelationAffaireTra3Id;

    var $container =
        $("#PersonnePhysiqueLabReaRejContainer" + index);

    var reaRejInstance =
        $("#PersonnePhysiqueLabIsReaRej" + index)
            .dxCheckBox("instance");

    $container.toggle(isTra3);

    if (!isTra3
        && reaRejInstance
        && isInitialization !== true) {

        reaRejInstance.option("value", false);
    }

    var dateInstance =
        $("#PersonnePhysiqueLabDateCessationRelation" + index)
            .dxDateBox("instance");

    refreshDateCessationRelationPersonnePhysique(
        index,
        dateInstance ? dateInstance.option("value") : null,
        typeRelationAffaireTra3Id
    );
}


function refreshDateCessationRelationPersonnePhysique(
    index,
    dateCessationRelation,
    typeRelationAffaireTra3Id) {

    var relationInstance =
        $("#PersonnePhysiqueLabTypeRelationAffaireLabId" + index)
            .dxSelectBox("instance");

    var reaRejInstance =
        $("#PersonnePhysiqueLabIsReaRej" + index)
            .dxCheckBox("instance");

    if (!relationInstance) {
        return;
    }

    var isTra3 =
        relationInstance.option("value") === typeRelationAffaireTra3Id;

    var isReaRej =
        reaRejInstance
        && reaRejInstance.option("value") === true;

    var isRequired =
        isTra3
        && !isReaRej
        && isNullOrEmpty(dateCessationRelation);

    $("#PersonnePhysiqueLabDateCessationRelation" + index)
        .toggleClass("required-date", isRequired);
}


