Pour la partie reprise historique ça doit être un script sql qui met à jour le champ VictimeUsurpationIdentite de la table [Fraude].[PersonnePhysiqueFraude] (à partir du champ UnsurpationIdentite de la même table pour catégorie 718, 905 + statut fraude victime et dans les autres cas appliquer la valeur par défaut dans le premier tableau). Ci-dessous le script sql de récupération des différents champs nécessaires. Pour la méthode updateVictimeUsurpationIdentite elle doit plus tenir compte de la valeur du champ unsurpationIdentite.
SELECT df.CategorieId, cf.Code as CategoryCode, dpp.StatutPersonneFraudeId, ppf.VictimeUsurpationIdentite, ppf.UnsurpationIdentite
FROM [Fraude].[PersonnePhysiqueFraude] ppf
INNER JOIN [Fraude].[DossierFraudePersonnePhysique] dpp ON ppf.Id = dpp.PersonnePhysiqueFraudeId
INNER JOIN [Fraude].DossierFraude df ON df.Id = dpp.DossierFraudeId
INNER JOIN [Fraude].[CategorieFraude] cf ON cf.Id = df.CategorieId
INNER JOIN [Fraude].StatutPersonneFraude spf ON spf.Id = dpp.StatutPersonneFraudeId
WHERE UnsurpationIdentite IS NOT NULL

function updateVictimeUsurpationIdentite(index) {

const categorieCode = getSelectedCategorieFraudeCode();  
const statutCode = getStatutPersonneFraudeCode(index);  

const select =  
    $("#PersonnePhysiqueFraudeVictimeUsurpationIdentite" + index)  
    .dxSelectBox("instance");  

if (!select) {  
    return;  
}  

const usurpationCheckBox =  
    $("#PersonnePhysiqueFraudeUnsurpationIdentite" + index)  
    .dxCheckBox("instance");  

const usurpationIdentite = usurpationCheckBox.option("value");  

const isCategorie718Or905 =  
    categorieCode === CategorieFraudeEnum.Categorie718 ||  
    categorieCode === CategorieFraudeEnum.Categorie905;  

const isCategorie906 =  
    categorieCode === CategorieFraudeEnum.Categorie906;  

const isVictime =  
    statutCode === StatutPersonneFraudeEnum.Victime;  

/* ========================================================  
   Par défaut :  
   statut vide ou différent de Victime  
   => Non + désactivé  
   ======================================================== */  

select.option("readOnly", true);  

if (isCategorie718Or905 && isVictime) {  

    select.option("readOnly", false);  

    if(isNullOrUndefined(usurpationIdentite))  
    {  
        return;  
    }  
      
    select.option("value", usurpationIdentite);  

    return;  
}  

if (isCategorie906 && isVictime) {  

    select.option("value", true);  

    return;  
}  

select.option("value", false);

}

function updateVictimeUsurpationIdentiteForAll()
{
$(".physicalPerson").each(function () {
const id = $(this).attr("id");
const index = id.replace("rowPhysicalPerson", "");

updateVictimeUsurpationIdentite(index);  
});

}