// ============================================================================
// FICHIER : document.js
// DESCRIPTION : forcer le progress au premier chargement de "Tous les documents".
// Pourquoi ?
// Même avec LoadPanel DevExtreme, comme le container est initialement display:none,
// le premier refresh peut parfois ne pas afficher le loader.
// On force donc beginCustomLoading / endCustomLoading.
// ============================================================================


// ----------------------------------------------------------------------------
// REMPLACER refreshGrid par cette version :
// ----------------------------------------------------------------------------

Transfert.Document.refreshGrid = function (gridId) {
    var grid = $("#" + gridId).dxDataGrid("instance");

    if (!grid) {
        return;
    }

    grid.beginCustomLoading(_transfertTranslatableLoading);

    var refreshResult = grid.refresh();

    if (refreshResult && refreshResult.done) {
        refreshResult.done(function () {
            grid.endCustomLoading();
        });

        refreshResult.fail(function () {
            grid.endCustomLoading();
        });
    }
    else {
        setTimeout(function () {
            grid.endCustomLoading();
        }, 500);
    }
};



// ============================================================================
// FICHIER : _ViewStart.cshtml
// DESCRIPTION : ajouter la variable JS utilisée par beginCustomLoading.
// ============================================================================

var _transfertTranslatableLoading =
    "@Html.Raw(translator.Common["Loading"])";



// ============================================================================
// SCRIPT SQL : TRADUCTION LOADING
// DESCRIPTION : à exécuter uniquement si la clé Loading n'existe pas déjà.
// Table réelle : [Commun].[Traduction]
// Colonnes : [Id], [FrenchTranslate], [EnglishTranslate]
// ============================================================================

MERGE [Commun].[Traduction] AS target
USING
(
    VALUES
    (
        N'Loading',
        N'Chargement...',
        N'Loading...'
    )
)
AS source ([Id], [FrenchTranslate], [EnglishTranslate])
ON target.[Id] = source.[Id]
WHEN MATCHED THEN
    UPDATE SET
        target.[FrenchTranslate] = source.[FrenchTranslate],
        target.[EnglishTranslate] = source.[EnglishTranslate]
WHEN NOT MATCHED THEN
    INSERT ([Id], [FrenchTranslate], [EnglishTranslate])
    VALUES (source.[Id], source.[FrenchTranslate], source.[EnglishTranslate]);