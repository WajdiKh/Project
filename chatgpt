function initializeReaRejPersonnePhysique(
    index,
    cessationBlocageVenteId,
    relationTermineeId) {

    var relationInstance =
        $("#PersonnePhysiqueLabTypeRelationAffaireLabId" + index)
            .dxSelectBox("instance");

    if (!relationInstance) {
        return;
    }

    onTypeRelationAffairePersonnePhysiqueChanged(
        index,
        relationInstance.option("value"),
        cessationBlocageVenteId,
        relationTermineeId,
        true
    );
}

function onTypeRelationAffairePersonnePhysiqueChanged(
    index,
    typeRelationAffaireId,
    cessationBlocageVenteId,
    relationTermineeId,
    isInitialization) {

    var isCessationBlocageVente =
        typeRelationAffaireId === cessationBlocageVenteId;

    var isRelationTerminee =
        typeRelationAffaireId === relationTermineeId;

    var isDateEnabled =
        isCessationBlocageVente || isRelationTerminee;

    var cessationRelationInstance =
        $("#PersonnePhysiqueLabCessationRelation" + index)
            .dxCheckBox("instance");

    var dateCessationInstance =
        $("#PersonnePhysiqueLabDateCessationRelation" + index)
            .dxDateBox("instance");

    var reaRejInstance =
        $("#PersonnePhysiqueLabIsReaRej" + index)
            .dxCheckBox("instance");

    $("#PersonnePhysiqueLabReaRejContainer" + index)
        .toggle(isCessationBlocageVente);

    if (cessationRelationInstance) {
        cessationRelationInstance.option(
            "value",
            isRelationTerminee
        );
    }

    if (dateCessationInstance) {
        dateCessationInstance.option("disabled", !isDateEnabled);

        if (!isDateEnabled) {
            dateCessationInstance.option("value", null);
        }
    }

    if (!isCessationBlocageVente
        && reaRejInstance
        && isInitialization !== true) {

        reaRejInstance.option("value", false);
    }

    refreshDateCessationRelationPersonnePhysiqueValidation(
        index,
        cessationBlocageVenteId
    );
}

function refreshDateCessationRelationPersonnePhysiqueValidation(
    index,
    cessationBlocageVenteId) {

    var relationInstance =
        $("#PersonnePhysiqueLabTypeRelationAffaireLabId" + index)
            .dxSelectBox("instance");

    var reaRejInstance =
        $("#PersonnePhysiqueLabIsReaRej" + index)
            .dxCheckBox("instance");

    if (!relationInstance) {
        return;
    }

    var isCessationBlocageVente =
        relationInstance.option("value") === cessationBlocageVenteId;

    var isReaRej =
        reaRejInstance
        && reaRejInstance.option("value") === true;

    setDateCessationRequiredState(
        "#PersonnePhysiqueLabDateCessationRelation" + index,
        isCessationBlocageVente && !isReaRej
    );
}


