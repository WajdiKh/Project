9. GetCurrentUserActiveDocumentShareAsync
============================================================

SUPPRIMER toute condition sur share.ExpiryDate.

public async Task<DocumentShare> GetCurrentUserActiveDocumentShareAsync(
    int documentId,
    int userId,
    string email,
    CancellationToken token = default)
{
    var now = DateTimeOffset.Now;

    return await Context.DocumentShares
        .Include(x => x.Document)
            .ThenInclude(x => x.Owner)
        .FirstOrDefaultAsync(x =>
            x.DocumentId == documentId
            && x.IsActive
            && x.SharedDate <= now
            && x.Document.ExpiryDate >= now
            && (
                x.SharedWithUserId == userId
                || x.Email == email
            ),
            token);
}

