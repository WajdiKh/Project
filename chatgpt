    UPDATE [Lab].[PersonnePhysiqueLab]
    SET [IsReaRej] = 0
    WHERE [IsReaRej] IS NULL;

    -- Ajouter une contrainte DEFAULT si elle n'existe pas
    IF NOT EXISTS
    (
        SELECT 1
        FROM sys.default_constraints dc
        INNER JOIN sys.columns c
            ON c.default_object_id = dc.object_id
        WHERE dc.parent_object_id = OBJECT_ID('[Lab].[PersonnePhysiqueLab]')
          AND c.name = 'IsReaRej'
    )
    BEGIN
        ALTER TABLE [Lab].[PersonnePhysiqueLab]
        ADD CONSTRAINT [DF_PersonnePhysiqueLab_IsReaRej]
            DEFAULT (0) FOR [IsReaRej];
    END;

    -- Rendre la colonne NOT NULL
    ALTER TABLE [Lab].[PersonnePhysiqueLab]
    ALTER COLUMN [IsReaRej] BIT NOT NULL;

    COMMIT TRANSACTION;
