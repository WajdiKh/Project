.TitleTemplate(@<text>
    <div class="d-flex flex-row align-items-center justify-content-between">
        <div class="font-size-16px text-green text-font-weight-600 smallCaps text-green">
            <i class="fas fa-cogs mr-2" aria-hidden="true"></i>
            <span id="shareSettingsDocumentPopupTitle"></span>
        </div>
        <button type="button"
                class="popup-close-btn"
                onclick="Transfert.Document.closeShareSettingsPopup();"
                style="cursor: pointer; font-size: 24px; background: none; border: none; padding: 0; color: inherit;">
            &times;
        </button>
    </div>
</text>)


// =========================
// document.js
// Garde cette méthode
// =========================

Transfert.Document.buildPopupTitle = function (suffix) {
    if (!Transfert.Document.selectedDocument) {
        return suffix;
    }

    return _transfertTranslatableTransfer +
        " >> " +
        Transfert.Document.selectedDocument.Name +
        " >> " +
        suffix;
};


// =========================
// document.js
// Dans openSharePopup, remplacer popup.option("title", ...) par :
// =========================

$("#shareDocumentPopupTitle").text(
    Transfert.Document.buildPopupTitle(
        _transfertTranslatableDocumentShareWithUsers
    )
);


// =========================
// document.js
// Dans openShareSettingsPopup, remplacer popup.option("title", ...) par :
// =========================

$("#shareSettingsDocumentPopupTitle").text(
    Transfert.Document.buildPopupTitle(
        _transfertTranslatableDocumentShareSettings
    )
);


// =========================
// Important
// Ne mets plus popup.option("title", "...") pour ces deux popups,
// sinon DevExtreme repasse sur le titre standard et tu perds ton style.
// =========================