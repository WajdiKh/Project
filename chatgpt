@model ShareDocumentViewModel

@{
    var startDate = Model.StartDate;
    var expiryDate = Model.ExpiryDate;
    var maxDate = Model.DocumentExpiryDate;
}

<div class="card-body">

    @using (Html.BeginForm(FormMethod.Post, new { id = TransfertConstants.ShareDocumentFormId }))
    {
        @Html.HiddenFor(x => x.DocumentId)

        @using (Html.DevExtreme().ValidationGroup(TransfertConstants.ShareDocumentFormValidationGroupName))
        {
            <div class="row mb-3">

                <div class="col-sm-12 col-md-3">
                    <div class="text-truncate text-green">
                        E-mail :
                    </div>
                </div>

                <div class="col-sm-12 col-md-9">
                    @(Html.DevExtreme()
                        .TextArea()
                        .ID("ShareEmails")
                        .Name("Emails")
                        .Height(90)
                        .Width("100%"))
                </div>

            </div>

            <div class="row mb-3">

                <div class="col-sm-12 col-md-6">

                    <div class="mb-2 text-green">
                        Date de début du partage :
                    </div>

                    @(Html.DevExtreme()
                        .DateBox()
                        .ID("ShareStartDate")
                        .Name("StartDate")
                        .Type(DateBoxType.Date)
                        .ShowClearButton(true)
                        .DisplayFormat("dd/MM/yyyy")
                        .UseMaskBehavior(true)
                        .Value(startDate.LocalDateTime)
                        .Min(DateTime.Now)
                        .Width("100%"))

                </div>

                <div class="col-sm-12 col-md-6">

                    <div class="mb-2 text-green">
                        Date d'expiration du partage :
                    </div>

                    @(Html.DevExtreme()
                        .DateBox()
                        .ID("ShareExpiryDate")
                        .Name("ExpiryDate")
                        .Type(DateBoxType.Date)
                        .ShowClearButton(true)
                        .DisplayFormat("dd/MM/yyyy")
                        .UseMaskBehavior(true)
                        .Value(expiryDate.LocalDateTime)
                        .Min(startDate.LocalDateTime)
                        .Width("100%"))

                </div>

            </div>

            <div class="row mt-5">

                <div class="col d-flex justify-content-end align-items-center">

                    <div class="mr-2">
                        @(Html.DevExtreme()
                            .Button()
                            .Text("Envoyer")
                            .Icon("email")
                            .ElementAttr("class", "color-blue")
                            .OnClick("Transfert.Document.shareDocument"))
                    </div>

                    <div>
                        @(Html.DevExtreme()
                            .Button()
                            .Text("Annuler")
                            .Icon("close")
                            .ElementAttr("class", "color-red")
                            .OnClick("Transfert.Document.closeShareDocumentPopup"))
                    </div>
                </div>
            </div>
        }
    }
</div>
