10. SQL traductions
============================================================

USE [BacaratWeb]
GO

DECLARE @Traductions TABLE
(
    Id NVARCHAR(250) NOT NULL,
    FrenchTranslate VARCHAR(MAX) NOT NULL,
    EnglishTranslate VARCHAR(MAX) NOT NULL
);

INSERT INTO @Traductions
(
    Id,
    FrenchTranslate,
    EnglishTranslate
)
VALUES
(
    N'Transfert.Document.Active',
    'Actif',
    'Active'
),
(
    N'Transfert.Document.Inactive',
    'Inactif',
    'Inactive'
),
(
    N'Transfert.Document.Email',
    'Email',
    'Email'
),
(
    N'Transfert.Document.UserNotAuthorizedTransfer',
    'Vous n''avez pas les droits d''accès à BacaratWeb Transfert. Merci d''effectuer une demande d''habilitation.',
    'You are not authorized to access BacaratWeb Transfert. Please request access.'
);

MERGE [Commun].[Traduction] AS target
USING @Traductions AS source
    ON target.Id = source.Id
WHEN MATCHED THEN
    UPDATE SET
        target.FrenchTranslate = source.FrenchTranslate,
        target.EnglishTranslate = source.EnglishTranslate
WHEN NOT MATCHED BY TARGET THEN
    INSERT
    (
        Id,
        FrenchTranslate,
        EnglishTranslate
    )
    VALUES
    (
        source.Id,
        source.FrenchTranslate,
        source.EnglishTranslate
    );
GO