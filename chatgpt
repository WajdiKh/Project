// Oui, c’est normal : enlever seulement display:none ne suffit pas.
// Le vrai souci vient du timing : tu fais un refresh trop tôt, avant que le grid soit visible ET avant que DevExtreme ait recalculé ses dimensions.
// Résultat : loader visible, mais headers pas encore rendus.
//
// La correction propre :
// 1) garder display:none au départ
// 2) au moment d’afficher un menu : afficher le container
// 3) appeler updateDimensions()
// 4) appeler repaint()
// 5) ensuite seulement lancer refresh()
//
// Donc NE PAS utiliser beginCustomLoading ici : laisse DevExtreme gérer son LoadPanel natif.


// ============================================================================
// FICHIER : Index.cshtml
// GARDER les containers comme avant.
// ============================================================================

<div id="gridAllDocumentsContainer" style="display:none;">
<div id="gridMyDocumentsContainer" style="display:none;">
<div id="gridSharedDocumentsContainer" style="display:none;">


// ============================================================================
// FICHIER : Index.cshtml
// AJOUTER LoadPanel dans les 3 DataGrid.
// ============================================================================

.LoadPanel(loadPanel => loadPanel
    .Enabled(true)
    .ShowPane(true)
    .ShowIndicator(true)
    .Text(translator.Common["Loading"]))


// ============================================================================
// FICHIER : document.js
// REMPLACER applyMode ET refreshGrid par ce code.
// ============================================================================

Transfert.Document.applyMode = function (mode) {
    _transfertCurrentMode = mode;

    $("#gridAllDocumentsContainer").hide();
    $("#gridMyDocumentsContainer").hide();
    $("#gridSharedDocumentsContainer").hide();

    var containerId = null;
    var gridId = null;

    if (mode === "mine") {
        containerId = "gridMyDocumentsContainer";
        gridId = "myDocumentsGrid";
    }
    else if (mode === "shared") {
        containerId = "gridSharedDocumentsContainer";
        gridId = "sharedDocumentsGrid";
    }
    else {
        containerId = "gridAllDocumentsContainer";
        gridId = "allDocumentsGrid";
    }

    $("#" + containerId).show();

    var menu = $("#menuSelectMode").dxMenu("instance");
    if (menu) {
        menu.option("items", Transfert.Document.getMenuItems(mode));
    }

    // Important :
    // On attend que le navigateur ait réellement affiché le container.
    // Ensuite DevExtreme peut calculer les dimensions, afficher les headers,
    // puis lancer le chargement avec son LoadPanel natif.
    setTimeout(function () {
        Transfert.Document.refreshGrid(gridId);
    }, 50);
};


Transfert.Document.refreshGrid = function (gridId) {
    var grid = $("#" + gridId).dxDataGrid("instance");

    if (!grid) {
        return;
    }

    // Important :
    // updateDimensions avant refresh règle le problème des headers absents.
    grid.updateDimensions();
    grid.repaint();
    grid.refresh();
};


// ============================================================================
// SI LE PROBLÈME ARRIVE ENCORE SUR LE PREMIER CHARGEMENT UNIQUEMENT,
// UTILISE CETTE VERSION PLUS ROBUSTE DU setTimeout DANS applyMode.
// Remplace le setTimeout précédent par celui-ci.
// ============================================================================

setTimeout(function () {
    var grid = $("#" + gridId).dxDataGrid("instance");

    if (!grid) {
        return;
    }

    grid.updateDimensions();
    grid.repaint();

    setTimeout(function () {
        grid.refresh();
    }, 50);

}, 100);


// ============================================================================
// CONCLUSION
// ============================================================================
// - display:none peut rester.
// - il ne faut pas forcer beginCustomLoading.
// - il faut afficher le container AVANT de refresh.
// - updateDimensions() + repaint() doivent être appelés avant refresh().
// - le LoadPanel natif DevExtreme s’affichera correctement avec headers.
// ============================================================================