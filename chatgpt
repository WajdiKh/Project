/* ============================================================
   CAUSE

   Le message contient une apostrophe HTML encodée :

       d&#x27;usurpation d&#x27;identité

   Cela arrive quand on injecte une traduction Razor directement
   dans une variable JavaScript sans décodage HTML.

   Il ne faut pas faire :
       var message = "@translator.Common["VictimeUsurpationIdentiteRequired"]";

   Il faut utiliser Html.Raw + JavaScriptStringEncode.
   ============================================================ */


/* ============================================================
   1) Dans _Layout.cshtml ou dans la vue Razor
   ============================================================ */

var _commonTranslatableMessageVictimeUsurpationIdentiteRequired =
    "@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(
        translator.Common["VictimeUsurpationIdentiteRequired"].ToString()
    ))";


/* ============================================================
   Variante si tu n’as pas une clé dédiée
   ============================================================ */

var _commonTranslatableMessageVictimeUsurpationIdentiteRequired =
    "@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(
        translator.Common["VeuillezRenseignerLeChamp"].ToString()
        + " "
        + translator.Common["VictimeUsurpationIdentite"].ToString()
    ))";


/* ============================================================
   2) Utilisation dans le dxValidator côté JS
   ============================================================ */

function enableVictimeUsurpationIdentiteRequiredValidation(index) {

    const validator =
        getOrCreateVictimeUsurpationIdentiteValidator(index);

    if (!validator) {
        return;
    }

    validator.option("validationRules", [
        {
            type: "required",
            message: _commonTranslatableMessageVictimeUsurpationIdentiteRequired
        }
    ]);

    validator.reset();
}


/* ============================================================
   Alternative rapide, moins propre

   Si la variable existe déjà mais arrive encodée en HTML,
   tu peux décoder côté JS.
   ============================================================ */

function htmlDecode(value) {

    const textarea =
        document.createElement("textarea");

    textarea.innerHTML = value;

    return textarea.value;
}

validator.option("validationRules", [
    {
        type: "required",
        message: htmlDecode(_commonTranslatableMessageVictimeUsurpationIdentiteRequired)
    }
]);