function produit_fraude_OnValueChanged(fromBody) {
    $("#categorieDetailContainer").removeClass("pt-1 pb-1");
    var produitId = $("#ProduitId").dxSelectBox("instance").option('value');
    if (produitId !== undefined && produitId > 0) {

        if (fromBody) {
            $("#CanalBdfId").dxSelectBox("instance").option('value', null);
            $("#ComplementMotifRejetChequeId").dxSelectBox("instance").option('value', null);
            $("#EtablissementDeclarantId").dxSelectBox("instance").option('value', null);
            $("#ModeOperatoireId").dxSelectBox("instance").option('value', null);
            $("#TypeCollecteChequeId").dxSelectBox("instance").option('value', null);
            $("#TypePaiementId").dxSelectBox("instance").option('value', null);
            $("#TypologieBdfId").dxSelectBox("instance").option('value', null);
            $("#MotifRejetChequeId").dxSelectBox("instance").option('value', null);
            $("#NombreOperations").dxTextBox("instance").option('value', null);
        }

        $("#canal-bdf-container").addClass("dx-hidden");
        $("#type-paiement-container").addClass("dx-hidden");
        $("#etablissement-declarant-container").addClass("dx-hidden");
        $("#mode-operatoire-container").addClass("dx-hidden");
        $("#gdrFluxOperationContainer").addClass("dx-hidden");
        $("#typologie-bdf-container").addClass("dx-hidden");
        $("#type-collecte-cheque-container").addClass("dx-hidden");
        $("#motif-reject-cheque-container").addClass("dx-hidden");
        $("#compl-motif-reject-cheque-container").addClass("dx-hidden");
        $("#nombre-operations-container").addClass("dx-hidden");
        $.ajax({
            method: "GET",
            cache: false,
            dataType: "json",
            contentType: "application/json; charset=utf-8",
            url: '/' + culture + '/Fraude/ServiceFraude/GetCategoryByProduit?produitId=' + produitId,
        }).done(function (data) {
            $("#CategorieId").dxSelectBox("instance").option("dataSource", data);
            categorie_fraude_OnValueChanged(fromBody);
        }).fail(function (e) {
            if (e.status == 401) {
                var popup = $("#modalReconnect").dxPopup('instance');
                popup.show();
                return;
            }
            DevExpress.ui.notify(_fraudeTranslatableMessageLoadingCategoriesError, "error");
        }).always(function (e) {
            hideLoadPanel();
        });
    }
}

