17. SQL — TRADUCTIONS
============================================================

USE [BacaratWeb];
GO

DECLARE @Traductions TABLE
(
    Id NVARCHAR(250) NOT NULL,
    FrenchTranslate VARCHAR(MAX) NOT NULL,
    EnglishTranslate VARCHAR(MAX) NOT NULL
);

INSERT INTO @Traductions
(
    Id,
    FrenchTranslate,
    EnglishTranslate
)
VALUES
(
    N'Lab.IsReaRej',
    'REA / REJ',
    'REA / REJ'
),
(
    N'Lab.DateCessationRelation.Required',
    'Veuillez saisir la date de cessation de relation ou cocher REA / REJ.',
    'Please enter the relationship termination date or select REA / REJ.'
);

MERGE [Commun].[Traduction] AS target
USING @Traductions AS source
    ON target.Id = source.Id
WHEN MATCHED THEN
    UPDATE SET
        target.FrenchTranslate =
            source.FrenchTranslate,
        target.EnglishTranslate =
            source.EnglishTranslate
WHEN NOT MATCHED BY TARGET THEN
    INSERT
    (
        Id,
        FrenchTranslate,
        EnglishTranslate
    )
    VALUES
    (
        source.Id,
        source.FrenchTranslate,
        source.EnglishTranslate
    );
GO


