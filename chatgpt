DECLARE @ConstraintName NVARCHAR(128);
DECLARE @Sql NVARCHAR(MAX);

SELECT @ConstraintName = dc.name
FROM sys.default_constraints dc
INNER JOIN sys.columns c
    ON dc.parent_object_id = c.object_id
    AND dc.parent_column_id = c.column_id
WHERE dc.parent_object_id = OBJECT_ID(N'[Fraude].[PersonnePhysiqueFraude]')
  AND c.name = N'UsurpationIdentite';

IF @ConstraintName IS NOT NULL
BEGIN
    SET @Sql = N'ALTER TABLE [Fraude].[PersonnePhysiqueFraude] DROP CONSTRAINT [' + @ConstraintName + N']';
    EXEC sp_executesql @Sql;
END;

ALTER TABLE [Fraude].[PersonnePhysiqueFraude]
ALTER COLUMN [UsurpationIdentite] BIT NULL;
GO