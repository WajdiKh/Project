function isTransmissionUpdateRelationAffaireCessationBlocageVente(rowData) {

    if (!rowData) {
        return false;
    }

    if (rowData.TypeRelationAffaireCode) {
        return rowData.TypeRelationAffaireCode === TYPE_RELATION_AFFAIRE_CESSATION_BLOCAGE_VENTE;
    }

    if (rowData.RelationAffaireCode) {
        return rowData.RelationAffaireCode === TYPE_RELATION_AFFAIRE_CESSATION_BLOCAGE_VENTE;
    }

    if (rowData.TypeRelationAffaire && rowData.TypeRelationAffaire.Code) {
        return rowData.TypeRelationAffaire.Code === TYPE_RELATION_AFFAIRE_CESSATION_BLOCAGE_VENTE;
    }

    return false;
}

function validateTransmissionUpdatePersonnePhysique(rowData) {

    if (!isTransmissionUpdateRelationAffaireCessationBlocageVente(rowData)) {
        return true;
    }

    if (rowData.IsReaRej === true) {
        return true;
    }

    return rowData.DateCessationRelation !== null
        && rowData.DateCessationRelation !== undefined
        && rowData.DateCessationRelation !== "";
}

function onTransmissionUpdatePersonnePhysiqueRowValidating(e) {

    if (!validateTransmissionUpdatePersonnePhysique(e.newData && Object.keys(e.newData).length
        ? $.extend({}, e.oldData, e.newData)
        : e.oldData)) {

        e.isValid = false;
        e.errorText = _labDateCessationRelationRequired;
    }
}


Dans la grille personnes physiques du popup MAJ, ajouter :

