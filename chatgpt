function validateReaRejDateCessationRelations() {
    var isValid = true;

    $(".PersonnePhysiqueLabTypeRelationAffaireLabId").each(function () {
        var id = $(this).attr("id");
        var index = id.replace(
            "PersonnePhysiqueLabTypeRelationAffaireLabId",
            ""
        );

        var relationInstance = $(this).dxSelectBox("instance");
        var selectedItem = relationInstance
            ? relationInstance.option("selectedItem")
            : null;

        var isTra3 =
            selectedItem
            && selectedItem.Code === "TRA3";

        var reaRejInstance =
            $("#PersonnePhysiqueLabIsReaRej" + index)
                .dxCheckBox("instance");

        var dateInstance =
            $("#PersonnePhysiqueLabDateCessationRelation" + index)
                .dxDateBox("instance");

        var isReaRej =
            reaRejInstance
            && reaRejInstance.option("value") === true;

        var dateValue =
            dateInstance
            ? dateInstance.option("value")
            : null;

        if (isTra3 && !isReaRej && isEmptyValue(dateValue)) {
            $("#PersonnePhysiqueLabDateCessationRelation" + index)
                .addClass("required-date");

            isValid = false;
        }
    });

    $(".PersonneMoraleLabTypeRelationAffaireLabId").each(function () {
        var id = $(this).attr("id");
        var index = id.replace(
            "PersonneMoraleLabTypeRelationAffaireLabId",
            ""
        );

        var relationInstance = $(this).dxSelectBox("instance");
        var selectedItem = relationInstance
            ? relationInstance.option("selectedItem")
            : null;

        var isTra3 =
            selectedItem
            && selectedItem.Code === "TRA3";

        var reaRejInstance =
            $("#PersonneMoraleLabIsReaRej" + index)
                .dxCheckBox("instance");

        var dateInstance =
            $("#PersonneMoraleLabDateCessationRelation" + index)
                .dxDateBox("instance");

        var isReaRej =
            reaRejInstance
            && reaRejInstance.option("value") === true;

        var dateValue =
            dateInstance
            ? dateInstance.option("value")
            : null;

        if (isTra3 && !isReaRej && isEmptyValue(dateValue)) {
            $("#PersonneMoraleLabDateCessationRelation" + index)
                .addClass("required-date");

            isValid = false;
        }
    });

    if (!isValid) {
        DevExpress.ui.notify(
            _labDateCessationRelationRequired,
            "error",
            4000
        );
    }

    return isValid;
}


