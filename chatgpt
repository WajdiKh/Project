IF COL_LENGTH('Transfert.DocumentShare', 'CreateurId') IS NULL
BEGIN
    ALTER TABLE [Transfert].[DocumentShare]
    ADD [CreateurId] INT NULL;
END
GO

IF NOT EXISTS (
    SELECT 1
    FROM sys.foreign_keys
    WHERE name = 'FK_DocumentShare_Utilisateur_CreateurId'
)
BEGIN
    ALTER TABLE [Transfert].[DocumentShare]
    ADD CONSTRAINT [FK_DocumentShare_Utilisateur_CreateurId]
        FOREIGN KEY ([CreateurId])
        REFERENCES [Commun].[Utilisateur]([Id]);
END
GO

IF NOT EXISTS (
    SELECT 1
    FROM sys.indexes
    WHERE name = 'IX_DocumentShare_CreateurId'
      AND object_id = OBJECT_ID('Transfert.DocumentShare')
)
BEGIN
    CREATE INDEX [IX_DocumentShare_CreateurId]
    ON [Transfert].[DocumentShare]([CreateurId]);
END
GO


