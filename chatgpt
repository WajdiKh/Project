DECLARE @Traductions TABLE
(
    Id NVARCHAR(250) NOT NULL,
    FrenchTranslate VARCHAR(MAX) NOT NULL,
    EnglishTranslate VARCHAR(MAX) NOT NULL
);

INSERT INTO @Traductions
(
    Id,
    FrenchTranslate,
    EnglishTranslate
)
VALUES
(
    N'Transfert.Document.Emails',
    'Emails',
    'Emails'
),
(
    N'Transfert.Document.Email',
    'Email',
    'Email'
),
(
    N'Transfert.Document.EmailsTooltip',
    'Veuillez ajouter un point-virgule après chaque adresse e-mail.',
    'Please add a semicolon following each email address.'
),
(
    N'Transfert.Document.ShareHistory',
    'Historique de partage',
    'Share history'
),
(
    N'Transfert.Document.RecipientsNotAuthorizedTransfer',
    'Les utilisateurs suivants n''existent pas dans BacaratWeb Transfert : {0}. Merci d''effectuer une demande d''habilitation pour les destinataires.',
    'The following users do not exist in BacaratWeb Transfert: {0}. Please request access for the recipients.'
);

MERGE [Commun].[Traduction] AS target
USING @Traductions AS source
    ON target.Id = source.Id
WHEN MATCHED THEN
    UPDATE SET
        target.FrenchTranslate = source.FrenchTranslate,
        target.EnglishTranslate = source.EnglishTranslate
WHEN NOT MATCHED BY TARGET THEN
    INSERT
    (
        Id,
        FrenchTranslate,
        EnglishTranslate
    )
    VALUES
    (
        source.Id,
        source.FrenchTranslate,
        source.EnglishTranslate
    );
GO


