        private bool CanAddNewDocument()
        {
            return _roleAccessUser.HasRoles(null, null, RoleUser.AdminGlobal) ||
            _roleAccessUser.HasClaims(ActiviteModule.TRANSFERT, ClaimUser.WRITE, null);
        }

