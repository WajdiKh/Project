// Remplacer initShareDocumentValidators par :
Transfert.Document.initShareDocumentValidators = function () {
    $("#ShareEmails").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            {
                type: "required",
                message: _transfertTranslatableDocumentShareEmailRequired
            },
            {
                type: "stringLength",
                max: 2000,
                message: _transfertTranslatableDocumentShareEmailMaxLength
            },
            {
                type: "custom",
                message: _transfertTranslatableDocumentShareEmailInvalid,
                validationCallback: function (e) {
                    if (!e.value) {
                        return false;
                    }

                    var emails = e.value
                        .split(";")
                        .map(x => x.trim())
                        .filter(x => x !== "");

                    var regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                    return emails.length > 0 && emails.every(x => regex.test(x));
                }
            }
        ]
    });

    $("#ShareExpiryDate").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            {
                type: "required",
                message: _transfertTranslatableDocumentShareExpiryDateRequired
            },
            {
                type: "custom",
                message: _transfertTranslatableDocumentShareExpiryDateInvalid,
                validationCallback: function (e) {
                    var startDate = $("#StartDate").val();
                    var expiryDate = e.value;

                    if (!startDate || !expiryDate) {
                        return false;
                    }

                    var start = new Date(startDate).setHours(0, 0, 0, 0);
                    var expiry = new Date(expiryDate).setHours(0, 0, 0, 0);

                    return expiry > start;
                }
            },
            {
                type: "custom",
                message: _transfertTranslatableDocumentShareExpiryDateDocumentInvalid,
                validationCallback: function (e) {
                    var documentExpiryDate = $("#DocumentExpiryDate").val();
                    var expiryDate = e.value;

                    if (!documentExpiryDate || !expiryDate) {
                        return false;
                    }

                    var documentExpiry = new Date(documentExpiryDate).setHours(0, 0, 0, 0);
                    var expiry = new Date(expiryDate).setHours(0, 0, 0, 0);

                    return expiry <= documentExpiry;
                }
            }
        ]
    });
};


