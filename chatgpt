private void ValidateReaRejDateCessationRelations(
    DossierLabViewModel model)
{
    var codeTra3 = nameof(TypeRelationAffaire.TRA3);

    var personnesPhysiquesInvalides = model.DossierLabPersonnePhysiques
        ?.Where(x =>
            x?.PersonnePhysiqueLab?.TypeRelationAffaireLab?.Code
                == codeTra3
            && !x.PersonnePhysiqueLab.IsReaRej
            && !x.PersonnePhysiqueLab.DateCessationRelations.HasValue)
        .Any() == true;

    var personnesMoralesInvalides = model.DossierLabPersonneMorales
        ?.Where(x =>
            x?.PersonneMoraleLab?.TypeRelationAffaireLab?.Code
                == codeTra3
            && !x.PersonneMoraleLab.IsReaRej
            && !x.PersonneMoraleLab.DateCessationRelations.HasValue)
        .Any() == true;

    if (personnesPhysiquesInvalides || personnesMoralesInvalides)
    {
        throw new CustomMessageException(
            _translator.Common["Lab.DateCessationRelation.Required"]);
    }
}


