/* ============================================================
   PROBLÈME

   Si la catégorie 718/905/906 est déjà sélectionnée puis qu'une
   nouvelle personne physique est ajoutée, le champ
   VictimeUsurpationIdentite n'est jamais initialisé.

   Pourquoi ?
   Parce que updateVictimeUsurpationIdentite() n'est appelé que :

   - lors du changement de catégorie
   - lors du changement de statut

   Une nouvelle personne est créée avec un statut vide et aucun
   événement OnValueChanged n'est déclenché.

   Il faut donc recalculer explicitement le champ juste après
   l'ajout de la personne physique.
   ============================================================ */


/* ============================================================
   Fonction robuste
   ============================================================ */

function updateVictimeUsurpationIdentite(index) {

    const categorieCode = getSelectedCategorieFraudeCode();
    const statutCode = getStatutPersonneFraudeCode(index);

    const select =
        $("#PersonnePhysiqueFraudeVictimeUsurpationIdentite" + index)
        .dxSelectBox("instance");

    if (!select) {
        return;
    }

    const usurpationCheckBox =
        $("#PersonnePhysiqueFraudeUnsurpationIdentite" + index)
        .dxCheckBox("instance");

    const usurpationIdentite =
        usurpationCheckBox
            ? usurpationCheckBox.option("value")
            : false;

    const isCategorie718Or905 =
        categorieCode === CategorieFraudeEnum.Categorie718 ||
        categorieCode === CategorieFraudeEnum.Categorie905;

    const isCategorie906 =
        categorieCode === CategorieFraudeEnum.Categorie906;

    const isVictime =
        statutCode === StatutPersonneFraudeEnum.Victime;

    /* ========================================================
       Par défaut :
       statut vide ou différent de Victime
       => Non + désactivé
       ======================================================== */

    select.option("readOnly", true);

    if (isCategorie718Or905 && isVictime) {

        select.option("readOnly", false);

        select.option(
            "value",
            usurpationIdentite === true
        );

        return;
    }

    if (isCategorie906 && isVictime) {

        select.option("value", true);

        return;
    }

    select.option("value", false);
}


/* ============================================================
   IMPORTANT

   Dans la fonction qui ajoute une nouvelle personne physique,
   appeler updateVictimeUsurpationIdentite juste après le rendu
   du partial.

   Exemple :
   ============================================================ */

// Après append/html/load du partial

updateVictimeUsurpationIdentite(indexNouvellePersonne);


/* ============================================================
   Exemple typique
   ============================================================ */

$.ajax({
    ...
}).done(function (html) {

    $("#physicalPersonsContainer").append(html);

    // Initialisation de la nouvelle ligne
    updateVictimeUsurpationIdentite(indexNouvellePersonne);
});


/* ============================================================
   Ainsi le comportement sera correct dans tous les cas :

   - changement catégorie
   - changement statut
   - ajout d'une nouvelle personne physique
   ============================================================ */