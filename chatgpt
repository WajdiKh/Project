    var _isRelationTerminee = Model.Item1.PersonnePhysiqueFraude.TypeRelationAffaireFraudeId == 4 || Model.Item1.PersonnePhysiqueFraude.TypeRelationAffaireFraudeId == 3;
    var isRobot = _roleAccess.HasRoles(ActiviteModule.Fraude, null, RoleUser.Robot);
