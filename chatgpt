                            .Type(ButtonType.Normal)
                            .Icon("email")
                            .ElementAttr("class", "color-blue")
                            .OnClick("Transfert.Document.shareDocument"))
                    </div>
                    <div>
                        @(Html.DevExtreme()
                            .Button()
                            .ID("btnCancelShareDocument")
                            .Icon("close")
                            .Text("Annuler")
                            .ElementAttr("class", "color-red")
                            .OnClick("Transfert.Document.closeShareDocumentPopup"))
                    </div>
                </div>
            </div>
        }
    }
</div>
// ShareDocumentViewModel
using System;
using System.ComponentModel.DataAnnotations;

namespace BacaratWeb.ViewModel.Transfert
{
    public class ShareDocumentViewModel
    {
        [Required]
        public int DocumentId { get; set; }

        [Required(ErrorMessage = "Transfert.Document.ShareEmailRequired")]
        [StringLength(320, ErrorMessage = "Transfert.Document.ShareEmailMaxLength")]
        public string Emails { get; set; }

        [Required(ErrorMessage = "Transfert.Document.ShareExpiryDateRequired")]
        public DateTimeOffset ExpiryDate { get; set; }

        public DateTimeOffset DocumentExpiryDate { get; set; }
    }
}

// Document.js
Transfert.Document.selectedDocument = null;

Transfert.Document.initShareButton = function () {
    $("#btnShareDocument").dxButton({
        text: "Partagés avec d'autres utilisateurs",
        icon: "share",
        disabled: true,
        elementAttr: {
            class: "color-blue"
        },
        onClick: function () {
            Transfert.Document.openSharePopup();
        }
    });
};

// Document.ready
Transfert.Document.initShareButton();

Transfert.Document.onMyDocumentsSelectionChanged = function (e) {
    var selectedRows = e.selectedRowsData;

    Transfert.Document.selectedDocument =
        selectedRows && selectedRows.length > 0 ? selectedRows[0] : null;

    var button = $("#btnShareDocument").dxButton("instance");
    if (button) {
        button.option("disabled", !Transfert.Document.selectedDocument);
    }
};

Transfert.Document.closeShareDocumentPopup = function () {
    closePopup(_transfertShareDocumentPopupId);
};

Transfert.Document.openSharePopup = function () {
    if (!Transfert.Document.selectedDocument) {
        return;
    }

    $.ajax({
        method: "GET",
        cache: false,
        url: "/" + culture + "/transfert/share-document",
        data: {
            documentId: Transfert.Document.selectedDocument.Id
        }
    }).done(function (htmlContent) {
        showScrollablePopup(_transfertShareDocumentPopupId, htmlContent);
        Transfert.Document.initShareDocumentValidators();
    }).fail(function (e) {
        if (e.status === 401) {
            $("#modalReconnect").dxPopup("instance").show();
            return;
        }

        if (e.status === 403) {
            DevExpress.ui.notify(_commonTranslatableMessagePasDePermissionAction, "error");
            return;
        }

        DevExpress.ui.notify(e.responseText || _commonTranslatableMessageErrorLoadForm, "error");
    });
};

Transfert.Document.initShareDocumentValidators = function () {
    $("#ShareEmails").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            { type: "required", message: _transfertTranslatableDocumentShareEmailRequired },
            { type: "stringLength", max: 320, message: _transfertTranslatableDocumentShareEmailMaxLength },
            {
                type: "custom",
                message: _transfertTranslatableDocumentShareEmailEmail,
                validationCallback: function (e) {
                    if (!e.value) {
                        return false;
                    }

                    var emails = e.value.split(";");
                    var emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                    for (var i = 0; i < emails.length; i++) {
                        var email = emails[i].trim();

                        if (!email || !emailRegex.test(email)) {
                            return false;
                        }
                    }

                    return true;
                }
            }
        ]
    });

    $("#ShareExpiryDate").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            { type: "required", message: _transfertTranslatableDocumentShareExpiryDateRequired }
        ]
    });
};

Transfert.Document.shareDocument = function () {
    if (!validateGroup(_transfertShareDocumentFormValidationGroupName)) {
        return;
    }

    var form = $("#" + _transfertShareDocumentFormId)[0];
    var formData = new FormData(form);

    $.ajax({
        url: "/" + culture + "/transfert/share-document",
        type: "POST",
        data: formData,
        processData: false,
        contentType: false,
        success: function () {
            DevExpress.ui.notify(_transfertDocumentShareSuccess, "success", 3000);

            $("#" + _transfertShareDocumentPopupId)
                .dxPopup("instance")
                .hide();

            Transfert.Document.refreshGrid("myDocumentsGrid");
            Transfert.Document.refreshGrid("allDocumentsGrid");
        },
        error: function (xhr) {
            DevExpress.ui.notify(xhr.responseText || _transfertDocumentShareError, "error", 5000);
        }
    });
};

// IDocumentService
Task<Document> GetDocumentByIdAndOwnerAsync(int documentId, int ownerId, CancellationToken token = default);

Task<bool> ShareDocumentAsync(int documentId, IEnumerable<DocumentShare> shares, CancellationToken token = default);

// DocumentService
public async Task<Document> GetDocumentByIdAndOwnerAsync(int documentId, int ownerId, CancellationToken token = default)
{
    return await Context.Documents
        .Include(x => x.DocumentShares)
        .FirstOrDefaultAsync(x => x.Id == documentId && x.OwnerId == ownerId, token);
}

public async Task<bool> ShareDocumentAsync(int documentId, IEnumerable<DocumentShare> shares, CancellationToken token = default)
{
    var existingShares = Context.DocumentShares.Where(x => x.DocumentId == documentId);

    Context.DocumentShares.RemoveRange(existingShares);

    await Context.DocumentShares.AddRangeAsync(shares, token);

    return await Context.SaveChangesAsync(token) > 0;
}

// DocumentController
[HttpGet]
[Route("{culture}/transfert/share-document")]
public async Task<IActionResult> ShareDocument(int documentId, CancellationToken token = default)
{
    var document = await _documentService.GetDocumentByIdAndOwnerAsync(documentId, CurrentUser.Id, token);

    if (document == null)
        return NotFound();

    var vm = new ShareDocumentViewModel
    {
        DocumentId = document.Id,
        ExpiryDate = DateTimeOffset.Now,
        DocumentExpiryDate = document.ExpiryDate
    };

    return PartialView("/Areas/Transfert/Views/Document/_PartialShareDocument.cshtml", vm);
}

[HttpPost]
[Route("{culture}/transfert/share-document")]
public async Task<IActionResult> ShareDocument(ShareDocumentViewModel model, CancellationToken token = default)
{
    if (!ModelState.IsValid)
        return BadRequest(GetModelStateErrorMessage());

    var document = await _documentService.GetDocumentByIdAndOwnerAsync(model.DocumentId, CurrentUser.Id, token);

    if (document == null)
        return NotFound();

    if (model.ExpiryDate < DateTimeOffset.Now || model.ExpiryDate > document.ExpiryDate)
        return BadRequest(_translator.Common["Transfert.Document.ShareExpiryDateInvalid"]);

    var emails = model.Emails
        .Split(';')
        .Select(x => x.Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();

    var shares = new List<DocumentShare>();

    foreach (var email in emails)
    {
        var user = await _utilisateurService.GetUtilisateurByEmailAsync(email, token);

        if (user == null)
        {
            return BadRequest("L'utilisateur n'existe pas dans BacaratWeb Transfert. Merci d'effectuer une demande d'habilitation pour le destinataire.");
        }

        shares.Add(new DocumentShare
        {
            DocumentId = document.Id,
            SharedWithUserId = user.Id,
            Email = user.Email,
            SharedDate = DateTimeOffset.Now,
            ExpiryDate = model.ExpiryDate
        });
    }

    var saved = await _documentService.ShareDocumentAsync(document.Id, shares, token);

    if (!saved)
        return BadRequest(_translator.Common["Transfert.Document.ShareError"]);

    return Ok(new { success = true });
}


