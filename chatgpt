        [HttpGet("{culture:required}/transfert/share-document")]
        public async Task<IActionResult> ShareDocument(
            int documentId,
            CancellationToken token = default)
        {
            var document = await _documentService.GetAsync(documentId, true, token);

            if (document == null)
                return NotFound();

            var now = DateTimeOffset.Now;

            var vm = new ShareDocumentViewModel
            {
                DocumentId = document.Id,
                StartDate = now,
                ExpiryDate = document.ExpiryDate,
                DocumentExpiryDate = document.ExpiryDate
            };

            return PartialView(
                "/Areas/Transfert/Views/Document/_PartialShareDocument.cshtml",
                vm);
        }

        [HttpPost("{culture:required}/transfert/save-share-document")]
        public async Task<IActionResult> SaveShareDocument(
            ShareDocumentViewModel model,
            CancellationToken token = default)
        {
            try
            {
                if (!ModelState.IsValid)
                    return BadRequest(GetModelStateErrorMessage());

                var document = await _documentService.GetAsync(model.DocumentId, true, token);

                if (document == null)
                    return BadRequest("Document introuvable.");

                if (model.StartDate.Date < DateTimeOffset.Now.Date)
                    return BadRequest(_translator.Common["Transfert.Document.ShareStartDateInvalid"]);

                if (model.ExpiryDate.Date < model.StartDate.Date)
                    return BadRequest(_translator.Common["Transfert.Document.ShareExpiryDateInvalid"]);

                var emails = model.Emails
                    .Split(';', StringSplitOptions.RemoveEmptyEntries)
                    .Select(x => x.Trim())
                    .Distinct()
                    .ToList();

                foreach (var email in emails)
                {
                    var user = await _utilisateurService
                        .GetUtilisateurByEmailAsync(email, token);

                    if (user == null)
                        continue;

                    var share = new DocumentShare
                    {
                        DocumentId = document.Id,
                        SharedWithUserId = user.Id,
                        Email = email,
                        SharedDate = model.StartDate,
                        ExpiryDate = model.ExpiryDate
                    };

                    document.DocumentShares ??= new List<DocumentShare>();
                    document.DocumentShares.Add(share);
                }

                var saved = await _documentService.UpdateAsync(document, token);

                if (!saved)
                    return BadRequest(_translator.Common["Transfert.Document.SaveError"]);

                return Ok(new { success = true });
            }
            catch (Exception ex)
            {
                _logger.TraceError(ex);

                return StatusCode(
                    500,
                    _translator.Common["Transfert.Document.SaveError"]);
            }
        }
    }
