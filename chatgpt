var _transfertTranslatableDocumentShareEmailRequired = "@Html.Raw(translator.Common["Transfert.Document.ShareEmailRequired"])";
var _transfertTranslatableDocumentShareEmailEmail = "@Html.Raw(translator.Common["Transfert.Document.ShareEmailEmail"])";
var _transfertTranslatableDocumentShareEmailMaxLength = "@Html.Raw(translator.Common["Transfert.Document.ShareEmailMaxLength"])";
var _transfertTranslatableDocumentShareExpiryDateRequired = "@Html.Raw(translator.Common["Transfert.Document.ShareExpiryDateRequired"])";
var _transfertDocumentShareSuccess = "@Html.Raw(translator.Common["Transfert.Document.ShareSuccess"])";
