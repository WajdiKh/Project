8. CanUserDownloadSharedDocumentAsync
============================================================

SUPPRIMER toute condition sur share.ExpiryDate.

AVANT :

x.IsActive
&& x.SharedDate <= now
&& x.ExpiryDate >= now
&& x.Document.ExpiryDate >= now

APRÈS :

x.IsActive
&& x.SharedDate <= now
&& x.Document.ExpiryDate >= now

Implémentation :

public async Task<bool> CanUserDownloadSharedDocumentAsync(
    int documentId,
    int userId,
    string email,
    CancellationToken token = default)
{
    var now = DateTimeOffset.Now;

    return await Context.DocumentShares
        .Include(x => x.Document)
        .AnyAsync(x =>
            x.DocumentId == documentId
            && x.IsActive
            && x.SharedDate <= now
            && x.Document.ExpiryDate >= now
            && (
                x.SharedWithUserId == userId
                || x.Email == email
            ),
            token);
}

