};

Transfert.Document.openShareSettingsPopup = function () {
    if (!Transfert.Document.selectedDocument) {
        return;
    }

    $.ajax({
        method: "GET",
        cache: false,
        url: "/" + culture + "/transfert/share-settings",
        data: {
            documentId: Transfert.Document.selectedDocument.Id
        }
    }).done(function (htmlContent) {
        showScrollablePopup(_transfertShareSettingsDocumentPopupId, htmlContent);
        Transfert.Document.selectedDocumentShare = null;
    }).fail(function (e) {
        if (e.status === 401) {
            $("#modalReconnect").dxPopup("instance").show();
            return;
        }

        if (e.status === 403) {
            DevExpress.ui.notify(_commonTranslatableMessagePasDePermissionAction, "error");
            return;
        }

        DevExpress.ui.notify(e.responseText || _commonTranslatableMessageErrorLoadForm, "error");
    });
};

Transfert.Document.selectedDocumentShare = null;

Transfert.Document.onShareSettingsSelectionChanged = function (e) {
    var selectedRows = e.selectedRowsData;

    Transfert.Document.selectedDocumentShare =
        selectedRows && selectedRows.length > 0 ? selectedRows[0] : null;

    var editButton = $("#btnEditDocumentShare").dxButton("instance");
    if (editButton) {
        editButton.option("disabled", !Transfert.Document.selectedDocumentShare);
    }

    var deleteButton = $("#btnDeleteDocumentShare").dxButton("instance");
    if (deleteButton) {
        deleteButton.option("disabled", !Transfert.Document.selectedDocumentShare);
    }
};

Transfert.Document.refreshShareSettingsGrid = function () {
    var grid = $("#shareSettingsGrid").dxDataGrid("instance");

    if (grid) {
        grid.refresh();
    }
};

Transfert.Document.openEditSharePopup = function () {
    if (!Transfert.Document.selectedDocumentShare) {
        return;
    }

    $.ajax({
        method: "GET",
        cache: false,
        url: "/" + culture + "/transfert/edit-share-document",
        data: {
            documentShareId: Transfert.Document.selectedDocumentShare.Id
        }
    }).done(function (htmlContent) {
        showScrollablePopup(_transfertShareDocumentPopupId, htmlContent);
        Transfert.Document.initShareDocumentValidators();
    }).fail(function (e) {
        DevExpress.ui.notify(e.responseText || _commonTranslatableMessageErrorLoadForm, "error");
    });
};

Transfert.Document.confirmDeleteShare = function () {
    if (!Transfert.Document.selectedDocumentShare) {
        return;
    }

    var dialog = DevExpress.ui.dialog.custom({
        title: _transfertTranslatableDocumentShareSettings,
        messageHtml: _transfertTranslatableDocumentShareDeleteConfirmation,
        buttons: [
            {
                text: _transfertTranslatableDocumentYes,
                onClick: function () {
                    return true;
                }
            },
            {
                text: _transfertTranslatableDocumentNo,
                onClick: function () {
                    return false;
                }
            }
        ]
    });

    dialog.show().done(function (dialogResult) {
        if (dialogResult) {
            Transfert.Document.deleteShareDocument();
        }
    });
};

Transfert.Document.deleteShareDocument = function () {
    if (!Transfert.Document.selectedDocumentShare) {
        return;
    }

    $.ajax({
        url: "/" + culture + "/transfert/delete-share-document",
        type: "POST",
        data: {
            documentShareId: Transfert.Document.selectedDocumentShare.Id
        },
        success: function () {
            DevExpress.ui.notify(
                _transfertTranslatableDocumentShareDeleteSuccess,
                "success",
                3000);

            Transfert.Document.selectedDocumentShare = null;
            Transfert.Document.refreshShareSettingsGrid();

            var editButton = $("#btnEditDocumentShare").dxButton("instance");
            if (editButton) {
                editButton.option("disabled", true);
            }

            var deleteButton = $("#btnDeleteDocumentShare").dxButton("instance");
            if (deleteButton) {
                deleteButton.option("disabled", true);
            }

            Transfert.Document.refreshGrid("allDocumentsGrid");
            Transfert.Document.refreshGrid("sharedDocumentsGrid");
        },
        error: function (xhr) {
            DevExpress.ui.notify(
                xhr.responseText || _transfertTranslatableDocumentShareDeleteError,
                "error",
                5000);
        }
    });
};
