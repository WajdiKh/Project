public async Task<bool> AddDocumentWithSharesAndNotificationsAsync(
    Document document,
    IEnumerable<DocumentShare> shares,
    IEnumerable<EmailNotification> notifications,
    CancellationToken token = default)
{
    if (document == null)
        throw new ArgumentNullException(nameof(document));

    var sharesToAdd = shares?.ToList()
        ?? new List<DocumentShare>();

    var notificationsToAdd = notifications?.ToList()
        ?? new List<EmailNotification>();

    if (!sharesToAdd.Any() || !notificationsToAdd.Any())
        return false;

    await using var transaction =
        await Context.Database.BeginTransactionAsync(token);

    try
    {
        await Context.Documents.AddAsync(document, token);

        foreach (var share in sharesToAdd)
        {
            share.Document = document;
            share.IsActive = true;
        }

        await Context.DocumentShares.AddRangeAsync(
            sharesToAdd,
            token);

        await Context.EmailNotifications.AddRangeAsync(
            notificationsToAdd,
            token);

        var result = await Context.SaveChangesAsync(token);

        if (result <= 0)
        {
            await transaction.RollbackAsync(token);
            return false;
        }

        await transaction.CommitAsync(token);
        return true;
    }
    catch
    {
        await transaction.RollbackAsync(token);
        throw;
    }
}


