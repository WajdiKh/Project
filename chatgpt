// ==========================================
// SQL TRADUCTIONS
// TABLE : [Commun].[Traduction]
// COLONNES :
//
// - Id
// - FrenchTranslate
// - EnglishTranslate
// ==========================================

MERGE [Commun].[Traduction] AS TARGET
USING
(
    VALUES
    ('Transfert.Document.Name', 'Nom du document', 'Document name'),
    ('Transfert.Document.UploadDate', 'Date d''ajout', 'Upload date'),
    ('Transfert.Document.ExpiryDate', 'Date d''expiration', 'Expiry date'),
    ('Transfert.Document.SharedEmails', 'Emails de partage', 'Shared emails'),
    ('Transfert.Document.AddedBy', 'Ajouté par', 'Added by'),
    ('Transfert.Document.StartDate', 'Date début', 'Start date'),
    ('Transfert.Document.EndDate', 'Date fin', 'End date'),
    ('Owner', 'Propriétaire', 'Owner'),
    ('Recipient', 'Destinataire', 'Recipient'),
    ('Status', 'Statut', 'Status'),
    ('Size', 'Taille', 'Size'),
    ('Search', 'Rechercher', 'Search'),
    ('Type', 'Type', 'Type')
) AS SOURCE ([Id], [FrenchTranslate], [EnglishTranslate])
ON TARGET.Id = SOURCE.Id
WHEN MATCHED THEN
    UPDATE SET
        TARGET.FrenchTranslate = SOURCE.FrenchTranslate,
        TARGET.EnglishTranslate = SOURCE.EnglishTranslate
WHEN NOT MATCHED THEN
    INSERT ([Id], [FrenchTranslate], [EnglishTranslate])
    VALUES (
        SOURCE.Id,
        SOURCE.FrenchTranslate,
        SOURCE.EnglishTranslate
    );