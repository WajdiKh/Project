/* Table utilisée :
   [Commun].[Traduction]
   Colonnes :
   - [Id]
   - [FrenchTranslate]
   - [EnglishTranslate]
*/

MERGE [Commun].[Traduction] AS target
USING
(
    VALUES
    (
        N'Transfert',
        N'Transfert',
        N'Transfer'
    ),
    (
        N'Transfert.Document.ShareWithUsers',
        N'Partage avec d''autres utilisateurs',
        N'Share with other users'
    ),
    (
        N'Transfert.Document.SharedEmails',
        N'Emails de partage',
        N'Shared emails'
    ),
    (
        N'Transfert.Document.AddedBy',
        N'Ajouté par',
        N'Added by'
    )
)
AS source ([Id], [FrenchTranslate], [EnglishTranslate])
ON target.[Id] = source.[Id]
WHEN MATCHED THEN
    UPDATE SET
        target.[FrenchTranslate] = source.[FrenchTranslate],
        target.[EnglishTranslate] = source.[EnglishTranslate]
WHEN NOT MATCHED THEN
    INSERT ([Id], [FrenchTranslate], [EnglishTranslate])
    VALUES (source.[Id], source.[FrenchTranslate], source.[EnglishTranslate]);