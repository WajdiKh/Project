[HttpGet]
public async Task<IActionResult> GetAllDocuments(
    CancellationToken token = default)
{
    var documents = await _documentService
        .GetAllDocumentsAsync(
            CurrentUser.Id,
            CurrentUser.Email,
            token);

    var data = _mapper.Map<IEnumerable<DocumentViewModel>>(documents);

    return Json(data);
}

[HttpPost("{culture:required}/transfert/delete-document")]
public async Task<IActionResult> DeleteDocument(
    int documentId,
    CancellationToken token = default)
{
    try
    {
        var deleted = await _documentService.DeleteDocumentAsync(
            documentId,
            CurrentUser.Id,
            token);

        if (!deleted)
        {
            return BadRequest(
                _translator.Common["Transfert.Document.DeleteError"]);
        }

        return Ok(new { success = true });
    }
    catch (Exception ex)
    {
        _logger.TraceError(ex);

        return StatusCode(
            500,
            _translator.Common["Transfert.Document.DeleteError"]);
    }
}

[HttpGet("{culture:required}/transfert/download/{id}")]
public async Task<IActionResult> Download(
    int id,
    CancellationToken token = default)
{
    var document = await _documentService
        .GetDocumentForDownloadAsync(id, token);

    if (document == null)
    {
        return BadRequest(
            _translator.Common["Transfert.Document.Expired"]);
    }

    var isOwner = document.OwnerId == CurrentUser.Id;

    if (isOwner)
    {
        return File(
            document.FileContent,
            "application/octet-stream",
            document.OriginalFileName);
    }

    var canDownload = await _documentService
        .CanUserDownloadDocumentAsync(
            id,
            CurrentUser.Id,
            CurrentUser.Email,
            token);

    if (!canDownload)
    {
        return BadRequest(
            _translator.Common["Transfert.Document.DownloadUnauthorized"]);
    }

    var vm = new DownloadDocumentViewModel
    {
        DocumentId = id
    };

    return View(vm);
}

[HttpPost("{culture:required}/transfert/validate-security-code")]
public async Task<IActionResult> ValidateSecurityCode(
    DownloadDocumentViewModel model,
    CancellationToken token = default)
{
    try
    {
        if (!ModelState.IsValid)
        {
            return BadRequest(
                _translator.Common["Transfert.Document.InvalidSecurityCode"]);
        }

        var document = await _documentService
            .GetDocumentForDownloadAsync(
                model.DocumentId,
                token);

        if (document == null
            || document.ExpiryDate <= DateTimeOffset.Now)
        {
            return BadRequest(
                _translator.Common["Transfert.Document.Expired"]);
        }

        if (document.SecurityCode != model.SecurityCode)
        {
            return BadRequest(
                _translator.Common["Transfert.Document.InvalidSecurityCode"]);
        }

        return Ok(new
        {
            success = true,
            downloadUrl = Url.Action(
                "DownloadFile",
                "Document",
                new
                {
                    area = "Transfert",
                    id = model.DocumentId
                })
        });
    }
    catch (Exception ex)
    {
        _logger.TraceError(ex);

        return StatusCode(
            500,
            _translator.Common["Error"]);
    }
}

[HttpGet("{culture:required}/transfert/download-file/{id}")]
public async Task<IActionResult> DownloadFile(
    int id,
    CancellationToken token = default)
{
    var document = await _documentService
        .GetDocumentForDownloadAsync(id, token);

    if (document == null
        || document.ExpiryDate <= DateTimeOffset.Now)
    {
        return BadRequest(
            _translator.Common["Transfert.Document.Expired"]);
    }

    return File(
        document.FileContent,
        "application/octet-stream",
        document.OriginalFileName);
}


