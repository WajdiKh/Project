function isEmptyValue(value) {
    return value === null
        || value === undefined
        || value === "";
}

function setDateCessationRequiredState(dateBoxSelector, isRequired) {
    var $dateBox = $(dateBoxSelector);

    if ($dateBox.length === 0) {
        return;
    }

    var dateBoxInstance = $dateBox.dxDateBox("instance");

    if (!dateBoxInstance) {
        return;
    }

    var dateValue = dateBoxInstance.option("value");

    $dateBox.toggleClass(
        "required-date",
        isRequired && isEmptyValue(dateValue)
    );
}


