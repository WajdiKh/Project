// Oui, parce qu’en passant par popup.option("title", "..."),
// on utilise le titre standard DevExtreme et non plus ton TitleTemplate custom.
// Pour garder le style, il faut remettre un TitleTemplate statique dans Index.cshtml
// avec un conteneur dont le texte sera mis à jour en JS.

// =========================
// Index.cshtml
// Popup ShareDocumentPopup : remplacer le TitleTemplate par ceci
// =========================

.TitleTemplate(@<text>
    <div class="d-flex flex-row align-items-center justify-content-between">
        <div class="font-size-16px text-green text-font-weight-600 smallCaps text-green">
            <i class="fas fa-share-alt mr-2" aria-hidden="true"></i>
            <span id="shareDocumentPopupTitle"></span>
        </div>
        <button type="button"
                class="popup-close-btn"
                onclick="Transfert.Document.closeShareDocumentPopup();"
                style="cursor: pointer; font-size: 24px; background: none; border: none; padding: 0; color: inherit;">
            &times;
        </button>
    </div>
</text>)


// =========================
// Index.cshtml
// Popup ShareSettingsDocumentPopup : remplacer le TitleTemplate par ceci
