private bool CanRecipientAccessTransfert(Utilisateur recipient)
{
    if (recipient == null)
    {
        return false;
    }

    return _utilisateurDirectionService.CanViewDossier(recipient.Id)
        || _utilisateurDirectionService.CanCreateDossier(recipient.Id);
}


