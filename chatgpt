// ============================================================================
// FICHIER : TransfertMappingProfile.cs
// DESCRIPTION : enlever le point dans l'extension du fichier.
// À faire dans les deux mappings :
// - Document -> DocumentViewModel
// - DocumentShare -> DocumentViewModel
// ============================================================================


// ----------------------------------------------------------------------------
// Dans le mapping Document -> DocumentViewModel
// REMPLACER le ForMember ContentType par celui-ci :
// ----------------------------------------------------------------------------

.ForMember(dest => dest.ContentType,
    opt => opt.MapFrom(src =>
        string.IsNullOrWhiteSpace(src.FileExtension)
            ? string.Empty
            : src.FileExtension.Replace(".", string.Empty).ToLower()))


// ----------------------------------------------------------------------------
// Dans le mapping DocumentShare -> DocumentViewModel
// REMPLACER le ForMember ContentType par celui-ci :
// ----------------------------------------------------------------------------

.ForMember(dest => dest.ContentType,
    opt => opt.MapFrom(src =>
        string.IsNullOrWhiteSpace(src.Document.FileExtension)
            ? string.Empty
            : src.Document.FileExtension.Replace(".", string.Empty).ToLower()))



