// document.js
window.Transfert = window.Transfert || {};
window.Transfert.Document = window.Transfert.Document || {};

$(document).ready(function () {
    Transfert.Document.initMenuSelectMode();
    Transfert.Document.applyMode(_transfertCurrentMode || "all");
    Transfert.Document.initAddButton();
    Transfert.Document.initShareButton();
    Transfert.Document.initShareSettingsButton();
});

Transfert.Document.getModeLabel = function (mode) {
    if (mode === "mine") {
        return "Mes documents";
    }

    if (mode === "shared") {
        return "Partagés avec moi";
    }

    return "Tous les documents";
};

Transfert.Document.getModeIcon = function (mode) {
    if (mode === "mine") {
        return "fas fa-user color-green2 adjust-icon-menu";
    }

    if (mode === "shared") {
        return "fas fa-share-alt color-green2 adjust-icon-menu";
    }

    return "fas fa-list color-green2 adjust-icon-menu";
};

Transfert.Document.getMenuItems = function (mode) {
    return [
        {
            icon: Transfert.Document.getModeIcon(mode),
            text: Transfert.Document.getModeLabel(mode),
            items: [
                {
                    icon: "fas fa-list adjust-icon-submenu",
                    text: "Tous les documents",
                    onClick: function () {
                        Transfert.Document.applyMode("all");
                    }
                },
                {
                    icon: "fas fa-user adjust-icon-submenu",
                    text: "Mes documents",
                    onClick: function () {
                        Transfert.Document.applyMode("mine");
                    }
                },
                {
                    icon: "fas fa-share-alt adjust-icon-submenu",
                    text: "Partagés avec moi",
                    onClick: function () {
                        Transfert.Document.applyMode("shared");
                    }
                }
            ]
        }
    ];
};

Transfert.Document.initMenuSelectMode = function () {
    $("#menuSelectMode").dxMenu({
        items: Transfert.Document.getMenuItems(_transfertCurrentMode || "all")
    });
};

Transfert.Document.applyMode = function (mode) {
    _transfertCurrentMode = mode;

    $("#gridAllDocumentsContainer").hide();
    $("#gridMyDocumentsContainer").hide();
    $("#gridSharedDocumentsContainer").hide();

    var containerId = null;
    var gridId = null;

    if (mode === "mine") {
        containerId = "gridMyDocumentsContainer";
        gridId = "myDocumentsGrid";
    }
    else if (mode === "shared") {
        containerId = "gridSharedDocumentsContainer";
        gridId = "sharedDocumentsGrid";
    }
    else {
        containerId = "gridAllDocumentsContainer";
        gridId = "allDocumentsGrid";
    }

    $("#" + containerId).show();
    
    Transfert.Document.refreshGrid(gridId);
};

Transfert.Document.refreshGrid = function (gridId) {
    var grid = $("#" + gridId).dxDataGrid("instance");

    if (!grid) {
        return;
    }

    grid.refresh();
};

Transfert.Document.initAddButton = function () {
    $("#btnAddDocument").dxButton({
        text: _commonTranslatableMessageAdd,
        icon: "add",
        elementAttr:
        {
            class: "color-blue"
        },
        onClick: function () {
            Transfert.Document.openAddPopup();
        }
    });
};

Transfert.Document.closeAddDocumentPopup = function () {

    closePopup(_transfertAddNewDocumentPopupId);
};

Transfert.Document.openAddPopup = function () 
{
    $.ajax({
        method: "GET",
        cache: false,
        url: '/' + culture + '/transfert/add-document',
    }).done(function (htmlContent) 
    {
        showScrollablePopup(_transfertAddNewDocumentPopupId, htmlContent);
        Transfert.Document.initAddDocumentValidators();
        Transfert.Document.initFileUploaderChange();

    }).fail(function (e) {
        if (e.status === 401) {
            const popup = $("#modalReconnect").dxPopup('instance');
            popup.show();
            return;
        }

        if (e.status == 403)
        {
            DevExpress.ui.notify(_commonTranslatableMessagePasDePermissionAction, "error");
            return;
        }

        DevExpress.ui.notify(e.responseText || _commonTranslatableMessageErrorLoadForm, "error");
    });
};

Transfert.Document.initAddDocumentValidators = function () {

    $("#Name").dxValidator({
        validationGroup: _transfertAddNewDocumentFormValidationGroupName,
        validationRules: [
            { type: "required", message: _transfertTranslatableDocumentNameRequired },
            { type: "stringLength", max: 255, message: _transfertTranslatableDocumentNameMaxLength }
        ]
    });

    $("#Description").dxValidator({
        validationGroup: _transfertAddNewDocumentFormValidationGroupName,
        validationRules: [
            { type: "stringLength", max: 1000, message: _transfertTranslatableDocumentDescriptionMaxLength }
        ]
    });

    $("#EncryptionKey").dxValidator({
        validationGroup: _transfertAddNewDocumentFormValidationGroupName,
        validationRules: [
            { type: "stringLength", max: 255, message: _transfertTranslatableDocumentEncryptionKeyMaxLength }
        ]
    });
};

Transfert.Document.saveDocument = function()
{
    if(!validateGroup(_transfertAddNewDocumentFormValidationGroupName))
    {
        return;
    }

    if (!Transfert.Document.validateSelectedFile()) {
        return;
    }

    var form = $("#" + _transfertAddNewDocumentFormId)[0];
    var formData = new FormData(form);

    $.ajax({
        url: "/" + culture + "/transfert/save-document",
        type: "POST",
        data: formData,
        processData: false,
        contentType: false,
        success: function () {
            DevExpress.ui.notify(_transfertDocumentSuccesAjout, "success", 3000);

            $("#" + _transfertAddNewDocumentPopupId)
                .dxPopup("instance")
                .hide();

            Transfert.Document.refreshGrid("myDocumentsGrid");
            Transfert.Document.refreshGrid("allDocumentsGrid");
        },
        error: function (xhr) {
            var message = xhr.responseText || _transfertDocumentSaveError;
            DevExpress.ui.notify(message, "error", 5000);
        }
    });
};

Transfert.Document.validateSelectedFile = function () {
    var fileInput = $("#FileUploader")[0];

    if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
        DevExpress.ui.notify(_transfertTranslatableDocumentFileRequired, "error");
        return false;
    }

    return true;
};

Transfert.Document.initFileUploaderChange = function () {
    $("#FileUploader").on("change", function () {
        var fileInput = this;
        var container = $("#selected-document-name-container");

        container.empty();

        if (!fileInput.files || fileInput.files.length === 0) {
            return;
        }

        var file = fileInput.files[0];

        var allowedExtensions = [".zip", ".rar", ".tar", ".gz", ".7z"];
        var extension = file.name.substring(file.name.lastIndexOf(".")).toLowerCase();

        if (allowedExtensions.indexOf(extension) === -1) {
            DevExpress.ui.notify(_transfertTranslatableDocumentFileExtension, "error");
            fileInput.value = "";
            container.empty();
            return;
        }

        if (file.size > 10485760) {
            DevExpress.ui.notify(_transfertTranslatableDocumentFileSize, "error");
            fileInput.value = "";
            container.empty();
            return;
        }

        container.html(
            '<div class="text-truncate text-green">' +
            file.name +
            '</div>'
        );
    });
};

Transfert.Document.selectedDocument = null;

Transfert.Document.initShareButton = function () {
    $("#btnShareDocument").dxButton({
        text: _transfertTranslatableDocumentShareWith,
        icon: "share",
        visible: false,
        elementAttr: {
            class: "color-blue"
        },
        onClick: function () {
            Transfert.Document.openSharePopup();
        }
    });
};

Transfert.Document.onMyDocumentsSelectionChanged = function (e) {
    
    var selectedRows = e.selectedRowsData;

    Transfert.Document.selectedDocument =
        selectedRows && selectedRows.length > 0
            ? selectedRows[0]
            : null;

    var hasSelection = !!Transfert.Document.selectedDocument;

    var shareButton = $("#btnShareDocument").dxButton("instance");

    if (shareButton) {
        shareButton.option("visible", hasSelection);
    }

    var shareSettingsButton = $("#btnShareSettingsDocument").dxButton("instance");

    if (shareSettingsButton) {
        shareSettingsButton.option("visible", hasSelection);
    }
};

Transfert.Document.closeShareDocumentPopup = function () {
    closePopup(_transfertShareDocumentPopupId);
};

Transfert.Document.openSharePopup = function () {
    if (!Transfert.Document.selectedDocument) {
        return;
    }

    $.ajax({
        method: "GET",
        cache: false,
        url: "/" + culture + "/transfert/share-document",
        data: {
            documentId: Transfert.Document.selectedDocument.Id
        }
    }).done(function (htmlContent) {
        showScrollablePopup(_transfertShareDocumentPopupId, htmlContent);

        Transfert.Document.setSharePopupTitles();

        Transfert.Document.initShareDocumentValidators();
    }).fail(function (e) {
        if (e.status === 401) {
            $("#modalReconnect").dxPopup("instance").show();
            return;
        }

        if (e.status === 403) {
            DevExpress.ui.notify(_commonTranslatableMessagePasDePermissionAction, "error");
            return;
        }

        DevExpress.ui.notify(e.responseText || _commonTranslatableMessageErrorLoadForm, "error");
    });
};

Transfert.Document.initShareDocumentValidators = function () {
    $("#ShareEmails").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            {
                type: "required",
                message: _transfertTranslatableDocumentShareEmailRequired
            },
            {
                type: "stringLength",
                max: 2000,
                message: _transfertTranslatableDocumentShareEmailMaxLength
            },
            {
                type: "custom",
                message: _transfertTranslatableDocumentShareEmailInvalid,
                validationCallback: function (e) {
                    if (!e.value) {
                        return false;
                    }

                    var emails = e.value
                        .split(";")
                        .map(x => x.trim())
                        .filter(x => x !== "");

                    var regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                    return emails.length > 0 && emails.every(x => regex.test(x));
                }
            }
        ]
    });

    $("#ShareExpiryDate").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            {
                type: "required",
                message: _transfertTranslatableDocumentShareExpiryDateRequired
            },
            {
                type: "custom",
                message: _transfertTranslatableDocumentShareExpiryDateInvalid,
                validationCallback: function (e) {
                    var startDate = $("#ShareStartDate")
                        .dxDateBox("instance")
                        .option("value");

                    var expiryDate = e.value;

                    var start = Transfert.Document.toDateOnlyTime(startDate);
                    var expiry = Transfert.Document.toDateOnlyTime(expiryDate);

                    if (start === null || expiry === null) {
                        return false;
                    }

                    return expiry > start;
                }
            },
            {
                type: "custom",
                message: _transfertTranslatableDocumentShareExpiryDateDocumentInvalid,
                validationCallback: function (e) {
                    var expiryDateBox = $("#ShareExpiryDate").dxDateBox("instance");

                    var documentExpiryDate = expiryDateBox.option("max");
                    var expiryDate = e.value;

                    var documentExpiry = Transfert.Document.toDateOnlyTime(documentExpiryDate);
                    var expiry = Transfert.Document.toDateOnlyTime(expiryDate);

                    if (documentExpiry === null || expiry === null) {
                        return false;
                    }

                    return expiry <= documentExpiry;
                }
            }
        ]
    });
};


Transfert.Document.shareDocument = function () {
    if (!validateGroup(_transfertShareDocumentFormValidationGroupName)) {
        return;
    }

    var form = $("#" + _transfertShareDocumentFormId)[0];
    var formData = new FormData(form);

    $.ajax({
        url: "/" + culture + "/transfert/save-share-document",
        type: "POST",
        data: formData,
        processData: false,
        contentType: false,
        success: function () {
            var documentShareId = $("#DocumentShareId").val();

            DevExpress.ui.notify(
                documentShareId
                    ? _transfertTranslatableDocumentShareUpdateSuccess
                    : _transfertDocumentShareSuccess,
                "success",
                3000);

            $("#" + _transfertShareDocumentPopupId)
                .dxPopup("instance")
                .hide();

            Transfert.Document.refreshGrid("myDocumentsGrid");
            Transfert.Document.refreshGrid("allDocumentsGrid");
            Transfert.Document.refreshGrid("sharedDocumentsGrid");
            Transfert.Document.refreshShareSettingsGrid();
        },
        error: function (xhr) {
            var documentShareId = $("#DocumentShareId").val();

            DevExpress.ui.notify(
                xhr.responseText ||
                    (documentShareId
                        ? _transfertTranslatableDocumentShareUpdateError
                        : _transfertDocumentShareError),
                "error",
                5000);
        }
    });
};

Transfert.Document.initShareSettingsButton = function () {
    $("#btnShareSettingsDocument").dxButton({
        text: _transfertTranslatableDocumentShareSettings,
        icon: "preferences",
        visible: false,
        elementAttr: {
            class: "color-blue"
        },
        onClick: function () {
            Transfert.Document.openShareSettingsPopup();
        }
    });
};

Transfert.Document.closeShareSettingsPopup = function () {
    closePopup(_transfertShareSettingsDocumentPopupId);
};

Transfert.Document.openShareSettingsPopup = function () {
    if (!Transfert.Document.selectedDocument) {
        return;
    }

    $.ajax({
        method: "GET",
        cache: false,
        url: "/" + culture + "/transfert/share-settings",
        data: {
            documentId: Transfert.Document.selectedDocument.Id
        }
    }).done(function (htmlContent) {
        showScrollablePopup(_transfertShareSettingsDocumentPopupId, htmlContent);

        Transfert.Document.setSharePopupTitles();

        Transfert.Document.selectedDocumentShare = null;
    }).fail(function (e) {
        if (e.status === 401) {
            $("#modalReconnect").dxPopup("instance").show();
            return;
        }

        if (e.status === 403) {
            DevExpress.ui.notify(_commonTranslatableMessagePasDePermissionAction, "error");
            return;
        }

        DevExpress.ui.notify(e.responseText || _commonTranslatableMessageErrorLoadForm, "error");
    });
};

Transfert.Document.selectedDocumentShare = null;

Transfert.Document.onShareSettingsSelectionChanged = function (e) {
    var selectedRows = e.selectedRowsData;

    Transfert.Document.selectedDocumentShare =
        selectedRows && selectedRows.length > 0 ? selectedRows[0] : null;

    var editButton = $("#btnEditDocumentShare").dxButton("instance");
    if (editButton) {
        editButton.option("disabled", !Transfert.Document.selectedDocumentShare);
    }

    var deleteButton = $("#btnDeleteDocumentShare").dxButton("instance");
    if (deleteButton) {
        deleteButton.option("disabled", !Transfert.Document.selectedDocumentShare);
    }
};

Transfert.Document.refreshShareSettingsGrid = function () {
    var grid = $("#shareSettingsGrid").dxDataGrid("instance");

    if (grid) {
        grid.refresh();
    }
};

Transfert.Document.openEditSharePopup = function () {
    if (!Transfert.Document.selectedDocumentShare) {
        return;
    }

    $.ajax({
        method: "GET",
        cache: false,
        url: "/" + culture + "/transfert/edit-share-document",
        data: {
            documentShareId: Transfert.Document.selectedDocumentShare.Id
        }
    }).done(function (htmlContent) {
        showScrollablePopup(_transfertShareDocumentPopupId, htmlContent);
        Transfert.Document.initShareDocumentValidators();
    }).fail(function (e) {
        DevExpress.ui.notify(e.responseText || _commonTranslatableMessageErrorLoadForm, "error");
    });
};

Transfert.Document.confirmDeleteShare = function () {
    if (!Transfert.Document.selectedDocumentShare) {
        return;
    }

    var dialog = DevExpress.ui.dialog.custom({
        title: _transfertTranslatableDocumentShareSettings,
        messageHtml: _transfertTranslatableDocumentShareDeleteConfirmation,
        buttons: [
            {
                text: _transfertTranslatableDocumentYes,
                onClick: function () {
                    return true;
                }
            },
            {
                text: _transfertTranslatableDocumentNo,
                onClick: function () {
                    return false;
                }
            }
        ]
    });

    dialog.show().done(function (dialogResult) {
        if (dialogResult) {
            Transfert.Document.deleteShareDocument();
        }
    });
};

Transfert.Document.deleteShareDocument = function () {
    if (!Transfert.Document.selectedDocumentShare) {
        return;
    }

    $.ajax({
        url: "/" + culture + "/transfert/delete-share-document",
        type: "POST",
        data: {
            documentShareId: Transfert.Document.selectedDocumentShare.Id
        },
        success: function () {
            DevExpress.ui.notify(
                _transfertTranslatableDocumentShareDeleteSuccess,
                "success",
                3000);

            Transfert.Document.selectedDocumentShare = null;
            Transfert.Document.refreshShareSettingsGrid();

            var editButton = $("#btnEditDocumentShare").dxButton("instance");
            if (editButton) {
                editButton.option("disabled", true);
            }

            var deleteButton = $("#btnDeleteDocumentShare").dxButton("instance");
            if (deleteButton) {
                deleteButton.option("disabled", true);
            }

            Transfert.Document.refreshGrid("allDocumentsGrid");
            Transfert.Document.refreshGrid("sharedDocumentsGrid");
        },
        error: function (xhr) {
            DevExpress.ui.notify(
                xhr.responseText || _transfertTranslatableDocumentShareDeleteError,
                "error",
                5000);
        }
    });
};

Transfert.Document.buildPopupTitle = function (suffix) {
    if (!Transfert.Document.selectedDocument) {
        return suffix;
    }

    return _transfertTranslatableTransfer +
        " >> " +
        Transfert.Document.selectedDocument.Name +
        " >> " +
        suffix;
};

Transfert.Document.toDateOnlyTime = function (value) {
    if (!value) {
        return null;
    }

    var date = new Date(value);

    return new Date(
        date.getFullYear(),
        date.getMonth(),
        date.getDate()
    ).getTime();
};

Transfert.Document.setSharePopupTitles = function () {
    if (!Transfert.Document.selectedDocument) {
        return;
    }

    $("#shareDocumentPopupTitle").text(
        Transfert.Document.buildPopupTitle(
            _transfertTranslatableDocumentShareWithUsers
        )
    );

    $("#shareSettingsDocumentPopupTitle").text(
        Transfert.Document.buildPopupTitle(
            _transfertTranslatableDocumentShareSettings
        )
    );
};

Transfert.Document.formatFileSize = function (fileSize) {
    if (!fileSize || fileSize <= 0) {
        return "0 " + _transfertDocumentFileSizeUnit;
    }

    var size = fileSize / 1024 / 1024;

    return size.toFixed(2) + " " + _transfertDocumentFileSizeUnit;
};

Transfert.Document.downloadDocument = function (documentId) {
    window.open(
        "/" + culture + "/transfert/download-document/" + documentId,
        "_blank");
};

Transfert.Document.confirmDeleteDocument = function (documentId) {
    var dialog = DevExpress.ui.dialog.custom({
        title: _transfertTranslatableDocumentDelete,
        messageHtml: _transfertDocumentDeleteConfirmation,
        buttons: [
            {
                text: _transfertTranslatableDocumentYes,
                onClick: function () {
                    return true;
                }
            },
            {
                text: _transfertTranslatableDocumentNo,
                onClick: function () {
                    return false;
                }
            }
        ]
    });

    dialog.show().done(function (dialogResult) {
        if (dialogResult) {
            Transfert.Document.deleteDocument(documentId);
        }
    });
};

Transfert.Document.deleteDocument = function (documentId) {
    $.ajax({
        url: "/" + culture + "/transfert/delete-document",
        type: "POST",
        data: {
            documentId: documentId
        },
        success: function () {
            DevExpress.ui.notify(
                _transfertDocumentDeleteSuccess,
                "success",
                3000);

            Transfert.Document.refreshGrid("allDocumentsGrid");
            Transfert.Document.refreshGrid("myDocumentsGrid");
            Transfert.Document.refreshGrid("sharedDocumentsGrid");

            Transfert.Document.selectedDocument = null;

            var shareButton = $("#btnShareDocument").dxButton("instance");
            if (shareButton) {
                shareButton.option("visible", false);
            }

            var shareSettingsButton = $("#btnShareSettingsDocument").dxButton("instance");
            if (shareSettingsButton) {
                shareSettingsButton.option("visible", false);
            }
        },
        error: function (xhr) {
            DevExpress.ui.notify(
                xhr.responseText || _transfertDocumentDeleteError,
                "error",
                5000);
        }
    });
};
