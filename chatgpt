// ============================================================================
// OBJECTIF DES MODIFICATIONS
// ============================================================================
// 1) Colonne "Actions" sans entête.
// 2) Colonne "Type" devient "Type de fichier".
// 3) Colonne "Taille" devient "Taille du fichier".
// 4) Colonne "Statut" : utiliser une clé spécifique avec bonne traduction EN.
// 5) Dates : format différent selon la langue :
//    - fr : dd/MM/yyyy HH:mm
//    - en : MM/dd/yyyy hh:mm a
// 6) Ajouter / corriger les traductions SQL nécessaires.
// ============================================================================



// ============================================================================
// FICHIER : Index.cshtml
// MODIFICATION 1 : ajouter les formats de date selon la langue.
// À mettre dans le bloc @{ ... } en haut du fichier.
// ============================================================================

@{
    var currentMode = ViewBag.Mode ?? "all";
    var language = Context.Features.Get<IRequestCultureFeature>().RequestCulture.Culture.ToString().ToCamelCase();

    // Format user friendly selon la langue courante.
    // fr => 27/05/2026 14:30
    // en => 05/27/2026 02:30 PM
    var dateTimeFormat = language == "en"
        ? "MM/dd/yyyy hh:mm a"
        : "dd/MM/yyyy HH:mm";
}



// ============================================================================
// FICHIER : Index.cshtml
// MODIFICATION 2 : dans les 3 DataGrid, remplacer les captions suivantes.
// ============================================================================


// ----------------------------------------------------------------------------
// AVANT
// ----------------------------------------------------------------------------

columns.AddFor(m => m.ContentType)
    .Caption(translator.Common["Type"]);

columns.Add()
    .Caption(translator.Common["Size"])
    .CalculateCellValue("function(data) { return Transfert.Document.formatFileSize(data.FileSize); }");

columns.AddFor(m => m.UploadDate)
    .Caption(translator.Common["Transfert.Document.UploadDate"])
    .DataType(GridColumnDataType.DateTime)
    .Format("dd/MM/yyyy HH:mm");

columns.AddFor(m => m.ExpiryDate)
    .Caption(translator.Common["Transfert.Document.ExpiryDate"])
    .DataType(GridColumnDataType.DateTime)
    .Format("dd/MM/yyyy HH:mm");

columns.Add()
    .Caption(translator.Common["Statut"])
    .DataField($"StatutDocumentName{language}");

columns.Add()
    .Caption(translator.Common["Actions"])
    .Width(100)
    .Alignment(HorizontalAlignment.Center)


// ----------------------------------------------------------------------------
// APRÈS
// À appliquer dans allDocumentsGrid, myDocumentsGrid et sharedDocumentsGrid.
// ----------------------------------------------------------------------------

columns.AddFor(m => m.ContentType)
    .Caption(translator.Common["Transfert.Document.FileType"]);

columns.Add()
    .Caption(translator.Common["Transfert.Document.FileSizeLabel"])
    .CalculateCellValue("function(data) { return Transfert.Document.formatFileSize(data.FileSize); }");

columns.AddFor(m => m.UploadDate)
    .Caption(translator.Common["Transfert.Document.UploadDate"])
    .DataType(GridColumnDataType.DateTime)
    .Format(dateTimeFormat);

columns.AddFor(m => m.ExpiryDate)
    .Caption(translator.Common["Transfert.Document.ExpiryDate"])
    .DataType(GridColumnDataType.DateTime)
    .Format(dateTimeFormat);

columns.Add()
    .Caption(translator.Common["Transfert.Document.Status"])
    .DataField($"StatutDocumentName{language}");

columns.Add()
    .Caption("")
    .Width(100)
    .Alignment(HorizontalAlignment.Center)



// ============================================================================
// FICHIER : Index.cshtml
// MODIFICATION 3 : version complète de la colonne Actions pour allDocumentsGrid
// et sharedDocumentsGrid.
// Résultat : pas d'entête + bouton centré.
// ============================================================================

columns.Add()
    .Caption("")
    .Width(100)
    .Alignment(HorizontalAlignment.Center)
    .AllowFiltering(false)
    .AllowSorting(false)
    .AllowHeaderFiltering(false)
    .AllowExporting(false)
    .CellTemplate(@<text>
        <div class="d-flex justify-content-center align-items-center w-100">
            <a href="javascript:void(0)"
               title="@translator.Common["Download"]"
               onclick="Transfert.Document.downloadDocument(<%= data.Id %>)">
                <i class="fas fa-download color-blue2"></i>
            </a>
        </div>
    </text>);



// ============================================================================
// FICHIER : Index.cshtml
// MODIFICATION 4 : version complète de la colonne Actions pour myDocumentsGrid.
// Résultat : pas d'entête + boutons Télécharger/Supprimer centrés.
// ============================================================================

columns.Add()
    .Caption("")
    .Width(130)
    .Alignment(HorizontalAlignment.Center)
    .AllowFiltering(false)
    .AllowSorting(false)
    .AllowHeaderFiltering(false)
    .AllowExporting(false)
    .CellTemplate(@<text>
        <div class="d-flex justify-content-center align-items-center w-100">
            <a href="javascript:void(0)"
               class="mr-3"
               title="@translator.Common["Download"]"
               onclick="Transfert.Document.downloadDocument(<%= data.Id %>)">
                <i class="fas fa-download color-blue2"></i>
            </a>

            <a href="javascript:void(0)"
               title="@translator.Common["Delete"]"
               onclick="Transfert.Document.confirmDeleteDocument(<%= data.Id %>)">
                <i class="fas fa-trash color-red2"></i>
            </a>
        </div>
    </text>);



// ============================================================================
// FICHIER : Index.cshtml
// EXEMPLE : bloc de colonnes corrigé à appliquer dans les 3 DataGrid.
// Pour myDocumentsGrid, remplacer seulement la colonne Actions par la version
// avec les deux boutons.
// ============================================================================

.Columns(columns =>
{
    columns.AddFor(m => m.Name)
        .Caption(translator.Common["Transfert.Document.Name"]);

    columns.AddFor(m => m.Description)
        .Caption(translator.Common["Description"]);

    columns.AddFor(m => m.ContentType)
        .Caption(translator.Common["Transfert.Document.FileType"]);

    columns.Add()
        .Caption(translator.Common["Transfert.Document.FileSizeLabel"])
        .CalculateCellValue("function(data) { return Transfert.Document.formatFileSize(data.FileSize); }");

    columns.AddFor(m => m.UploadDate)
        .Caption(translator.Common["Transfert.Document.UploadDate"])
        .DataType(GridColumnDataType.DateTime)
        .Format(dateTimeFormat);

    columns.AddFor(m => m.ExpiryDate)
        .Caption(translator.Common["Transfert.Document.ExpiryDate"])
        .DataType(GridColumnDataType.DateTime)
        .Format(dateTimeFormat);

    columns.AddFor(m => m.OwnerName)
        .Caption(translator.Common["Owner"]);

    columns.Add()
        .Caption(translator.Common["Transfert.Document.Status"])
        .DataField($"StatutDocumentName{language}");

    columns.Add()
        .Caption("")
        .Width(100)
        .Alignment(HorizontalAlignment.Center)
        .AllowFiltering(false)
        .AllowSorting(false)
        .AllowHeaderFiltering(false)
        .AllowExporting(false)
        .CellTemplate(@<text>
            <div class="d-flex justify-content-center align-items-center w-100">
                <a href="javascript:void(0)"
                   title="@translator.Common["Download"]"
                   onclick="Transfert.Document.downloadDocument(<%= data.Id %>)">
                    <i class="fas fa-download color-blue2"></i>
                </a>
            </div>
        </text>);
})



