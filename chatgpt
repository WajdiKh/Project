@(Html.DevExtreme().DataGrid<DossierLabRowViewModel>().Width("100%")
        .ID("gridDossiersLabWithNoTiers")
        .AllowColumnReordering(true)
        .ColumnResizingMode(ColumnResizingMode.Widget)
        .Selection(s => s.Mode(SelectionMode.Single))
        .Export(e => e.Enabled(true)
        .AllowExportSelectedData(true))
        .HoverStateEnabled(true)
        .Grouping(grouping => grouping.AutoExpandAll(true))
        .SearchPanel(searchPanel => searchPanel.Visible(true))
        .GroupPanel(groupPanel => groupPanel.Visible(true))
        .RemoteOperations(false)
        .RowAlternationEnabled(false)
        .ShowBorders(true)
        .AllowColumnResizing(true).ColumnAutoWidth(true)
        .ColumnChooser(cc => cc.Enabled(true).AllowSearch(true))
        .Paging(p => p.PageSize(5))
        .Pager(pager =>
            pager.ShowPageSizeSelector(true)
                .ShowNavigationButtons(true)
                .AllowedPageSizes(new List<int> { 5, 10, 20 })
        )
        .SearchPanel(s => s
            .Visible(true)
            .HighlightCaseSensitive(true)
        )
        .GroupPanel(g => g.Visible(true))
        .Grouping(g => g.AutoExpandAll(true))
        .ColumnFixing(c => c.Enabled(true))
        .OnInitialized("exporting")
        .Columns(columns =>
        {
            columns.Add()
                .Width("auto")
                .Caption(translator.Common["NumberDossier"])
                .CellTemplate(@<text>
                                  <%= data.CodeUnique %>
                                  <% if(data.MotifAlerte != null && data.MotifAlerte != ''){ %>
                                  @(Html.DevExtreme().Tooltip().Height(75)
                                      .ShowEvent("mouseenter")
                                      .HideEvent("mouseleave")
                                      .ContentTemplate(new JS("data.MotifAlerte"))
                                      .OnInitialized("function (e) { e.component.option('target', e.element.parent()); }")
                                      )
                                  <% } %>
                               </text>)
                .DataField("CodeUnique")
                .Fixed(true)
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["NumberDossierOrigine"])
                .DataField("DuplicateDossierCode")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["Statut"])
                .DataField("Statut")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["IsDsGrid"])
                .DataField("IsDeclarationSoupcon")
                .CalculateCellValue(@<text>
                                        function(data) {
                                        return (!data.IsConfidentHiden? data.IsDeclarationSoupcon ===true ? "@translator.Common["Yes"]": "@translator.Common["No"]" :"");
                                        }
                                     </text>).DataType(GridColumnDataType.String);


            columns.Add()
                .Width("auto")
                .Caption(translator.Common["AvisSF"])
                .DataField("AvisSF")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["VisaSF"])
                .DataField("VisaSF")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("150px")
                .Caption(translator.Common["AlertReception"])
                .DataField("DateReception")
                .DataType(GridColumnDataType.Date)
                .Format(CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern);

            columns.Add()
                .Width("100px")
                .Caption(translator.Common["SaisieLe"])
                .DataField("DateSaisie")
                .DataType(GridColumnDataType.Date)
                .Format(CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern);

            columns.Add()
                .Width("100px")
                .Caption(translator.Common["EndDate"])
                .DataField("DateCloture")
                .DataType(GridColumnDataType.Date)
                .Format(CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern);

            columns.Add()
                .Caption(translator.Common["TempsTraitement"])
                .DataField("TempsTraitementDossier")
                .Width("auto")
                .DataType(GridColumnDataType.Number);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["Direction"])
                .DataField("Direction")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["EntiteAgence"])
                .DataField("Entite")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["CategorieGroupeLab"])
                .DataField("CategorieGroupeLab")
                .DataType(GridColumnDataType.String);


            columns.Add()
                .Width("auto")
                .Caption(translator.Common["Categorie"])
                .DataField("Categorie")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["OrigineGroupeLab"])
                .DataField("OrigineGroupeLab")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["Origine"])
                .DataField("Origine")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Caption(translator.Common["Secteur"])
                .Width("auto")
                .DataField("Secteur")
                .DataType(GridColumnDataType.String);


            columns.Add()
                .Width("auto")
                .Caption(translator.Common["DeclarationNumberTracfin"])
                .DataField("DeclarationNumber")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["Datedeladeclaration"])
                .DataField("DateDeclaration")
                .DataType(GridColumnDataType.Date)
                .Format(CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["ReferenceInterne"])
                .DataField("ReferenceInterne")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["NumeroAccuseReceptionTracfin"])
                .DataField("NumeroAccuseReception")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["TransmissionParquet"])
                .DataField("IsTransmissionParquet")
                .CalculateCellValue(@<text>
                                        function(data) {
                                        if(data.IsTransmissionParquet==null) return "";
                                        return ( data.IsTransmissionParquet ===true ? "@translator.Common["Yes"]": "@translator.Common["No"]");
                                        }
                                     </text>).DataType(GridColumnDataType.String);
                columns.Add()
            .Width("auto")
            .Caption(translator.Common["TransmissionAutoriteHorsTracfin"])
            .DataField("IsTransmissionAutorite")
            .CalculateCellValue(@<text>
                function(data) {
                if(data.IsTransmissionAutorite==null) return "";
                return ( data.IsTransmissionAutorite ===true ? "@translator.Common["Yes"]": "@translator.Common["No"]");
                }
            </text>).DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["Dgt"])
                .DataField("IsDgt")
                .CalculateCellValue(@<text>
                                        function(data) {
                                        if(data.IsDgt==null) return "";
                                        return ( data.IsDgt ===true ? "@translator.Common["Yes"]": "@translator.Common["No"]");
                                        }
                                     </text>)
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["AutorisationDGT"])
                .DataField("IsAutorisationDGT")
                .CalculateCellValue(@<text>
                                        function(data) {
                                        if(data.IsAutorisationDGT==null) return "";
                                        return ( data.IsAutorisationDGT ===true ? "@translator.Common["Yes"]": "@translator.Common["No"]");
                                        }
                                     </text>)
                .DataType(GridColumnDataType.String);

	        columns.Add()
		        .Width("auto")
		        .Caption(translator.Common["202COV"])
		        .DataField("IsCov")
		        .CalculateCellValue(@<text>
                                        function(data) {
                                        if(data.IsCov==null) return "";
                                        return ( data.IsCov ===true ? "@translator.Common["Yes"]": "@translator.Common["No"]");
                                        }
                                     </text>)
                .DataType(GridColumnDataType.String);
            columns.Add()
                .Width("150px")
                .Caption(translator.Common["ResponsableDossier"])
                .DataField("Utilisateur")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["Modificateur"])
                .DataField("Modificateur")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("100px")
                .Caption(translator.Common["DateModificateur"])
                .DataField("DateModification")
                .DataType(GridColumnDataType.Date)
                .Format(CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern);

            columns.Add()
                .Caption(translator.Common["InformationRequestStatus"])
                .DataField("InformationRequestStatus")
                .DataType(GridColumnDataType.String)
                .CalculateCellValue("getInformationRequestStatusLabel");

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["IsNewDeclarationDs"])
                .DataField("IsNewDeclarationTracfin")
                .CalculateCellValue(@<text>
                                        function(data) {
                                        if(data.IsNewDeclarationTracfin==null) return "";
                                        return ( data.IsNewDeclarationTracfin ===true ? "@translator.Common["Yes"]": "@translator.Common["No"]");
                                        }
                                     </text>)
                .DataType(GridColumnDataType.String).Visible(isAdminGlobal);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["NombreRelance"])
                .DataField("NombreRelance")
                .DataType(GridColumnDataType.String);

            columns.Add()
                .Width("auto")
                .Caption(translator.Common["LastDateRelance"])
                .DataField("LastDateRelance")
                .DataType(GridColumnDataType.Date)
                .Format(CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern);
            columns.Add()
                .Width("auto")
                .Caption(translator.Common["DateRetourDemandeInfo"])
                .DataField("DateReponseDemandeInfo")
                .DataType(GridColumnDataType.Date)
                .Format(CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern);
            columns.Add()
                .Width("auto")
                .Caption(translator.Common["DateDerniereDeclarationDgt"])
                .DataField("DateDerniereDeclarationDgt")
                .DataType(GridColumnDataType.Date)
                .Format(CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern);
            columns.Add()
                .Width("auto")
                .Caption(translator.Common["MontantFlux"])
                .DataField("Montant")
                .Format("###.### €")
                .DataType(GridColumnDataType.Number);
            
            columns.Add()
                .Width("auto")
                .Caption(translator.Common["DateDeclarationLocale"])
                .DataField("DateDeclarationLocale")
                .DataType(GridColumnDataType.Date)
                .Format(CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern);
        }).FilterRow(filterRow => filterRow
        .Visible(true)
        .ApplyFilter(GridApplyFilterMode.Auto)
        ).RepaintChangesOnly(true).OnRowPrepared("gridDossiersLabWithNoTiers_OnRowPrepared")
        .OnSelectionChanged(@<text>
					            function(data) {
					            manageCommandButtonsActivationManagementMode();
					            }
					         </text>)
        .SortByGroupSummaryInfo(i => i.Add())
        .Summary(s => s.GroupItems(items =>
        {
            items.AddFor(m => m.Entite)
                .SummaryType(SummaryType.Count)
                .DisplayFormat("{0} " + translator.Common["dossierMin"] + "(s)");
        })
        ).MasterDetail(md =>
        {
        md.Enabled(true);
        md.Template(@<text>

                            @(Html.DevExtreme().DataGrid<PersonnePhysiqueItemLabViewModel>().Width("80%").Visible(false)
                                .ColumnAutoWidth(true)
                                .ShowBorders(true).Height("auto")
                                .OnContentReady("function(e){ if(e.component.getVisibleRows().length==0) {e.component.option('visible',false);} else {e.component.option('visible',true);}}")
                                .Columns(columns =>
                                {
                                    columns.AddFor(m => m.FullName).Caption(translator.Common["FullName"]).Width(250);
                                    columns.AddFor(m => m.DateNaissance).Caption(translator.Common["DateNaissance"]).Width(250)
                                        .DataType(GridColumnDataType.Date)
                                        .Format(CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern);
                                    columns.AddFor(m => m.NumeroCompte).Caption(translator.Common["NumeroCompte"]).Width(250);
                                })
                                .DataSource(d => d.Mvc().RouteName("apiRoute")
                                    .LoadAction("GetPersonnesPhysique")
                                    .LoadParams(new { dossierId = new JS("data.CryptedId"), isConfidentiel = new JS("data.IsConfidentHiden") })
                                )
                                )

                            @(Html.DevExtreme().DataGrid<PersonneMoraleItemLabViewModel>().Width("80%").Visible(false).ElementAttr("class", "mt-4")
                                .ColumnAutoWidth(true)
                                .ShowBorders(true).Height("auto")
                                .OnContentReady("function(e){ if(e.component.getVisibleRows().length==0) {e.component.option('visible',false);} else {e.component.option('visible',true);}}")
                                .Columns(columns =>
                                {
                                    columns.AddFor(m => m.RaisonSociale).Caption(translator.Common["RaisonSociale"]).Width(250);
                                    columns.AddFor(m => m.NumeroImmatriculation).Caption(translator.Common["NumeroImmatriculation"]).Width(250);
                                    columns.AddFor(m => m.NumeroCompte).Caption(translator.Common["NumeroCompte"]).Width(250);
                                })
                                .DataSource(d => d.Mvc().RouteName("apiRoute")
                                    .LoadAction("GetPersonnesMorale")
                                    .LoadParams(new { dossierId = new JS("data.CryptedId"), isConfidentiel = new JS("data.IsConfidentHiden") })
                                )
                                )


                         </text>);
        })
    )
