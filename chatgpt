            .ElementAttr("class", "popup")
            .Width(500)
            .Height("auto")
            .ShowTitle(false)
            .Visible(false)
            .DragEnabled(true)
            .CloseOnOutsideClick(true)
            )
        @(Html.DevExtreme().Popup()
            .ID("modalPreview")
            .ElementAttr(new Dictionary<string, object>
        {{"class", "popup"}})
            .ShowTitle(true)
            .Title("")
            .DragEnabled(true).ShowCloseButton(true).ShowTitle(true)
            .ResizeEnabled(false).Width("80%").MinHeight("90%").Position(PositionAlignment.Center)
            )
        @(Html.DevExtreme().Popup()
            .ID("manuelUtilisateurModalPreview")
            .ElementAttr(new Dictionary<string, object>
        {{"class", "popup"}})
