Transfert.Document.openSharePopup = function () {
    if (!Transfert.Document.selectedDocument) {
        return;
    }

    $.ajax({
        method: "GET",
        cache: false,
        url: "/" + culture + "/transfert/share-document",
        data: {
            documentId: Transfert.Document.selectedDocument.Id
        }
    }).done(function (htmlContent) {
        showScrollablePopup(_transfertShareDocumentPopupId, htmlContent);
        Transfert.Document.initShareDocumentValidators();
    }).fail(function (e) {
        if (e.status === 401) {
            $("#modalReconnect").dxPopup("instance").show();
            return;
        }

        if (e.status === 403) {
            DevExpress.ui.notify(_commonTranslatableMessagePasDePermissionAction, "error");
            return;
        }

        DevExpress.ui.notify(e.responseText || _commonTranslatableMessageErrorLoadForm, "error");
    });
};

Transfert.Document.initShareDocumentValidators = function () {

    $("#ShareEmails").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            {
                type: "required",
                message: _transfertTranslatableDocumentShareEmailRequired
            },
            {
                type: "custom",
                message: _transfertTranslatableDocumentShareEmailInvalid,
                validationCallback: function (e) {

                    if (!e.value) {
                        return false;
                    }

                    var emails = e.value
                        .split(";")
                        .map(x => x.trim())
                        .filter(x => x !== "");

                    var regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                    return emails.every(x => regex.test(x));
                }
            }
        ]
    });

    $("#ShareStartDate").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            {
                type: "required",
                message: _transfertTranslatableDocumentShareStartDateRequired
            }
        ]
    });

    $("#ShareExpiryDate").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            {
                type: "required",
                message: _transfertTranslatableDocumentShareExpiryDateRequired
            },
            {
                type: "custom",

                // message affiché si la date d'expiration est antérieure
                // à la date de début du partage
                message: _transfertTranslatableDocumentShareExpiryDateInvalid,

                validationCallback: function (e) {

                    // récupération de la date de début du partage
                    var startDate = $("#ShareStartDate")
                        .dxDateBox("instance")
                        .option("value");

                    // récupération de la date d'expiration
                    var expiryDate = e.value;

                    // sécurité si une des deux dates est vide
                    if (!startDate || !expiryDate) {
                        return false;
                    }

                    // comparaison uniquement sur la partie date
                    // sans tenir compte des heures
                    var start = new Date(startDate)
                        .setHours(0, 0, 0, 0);

                    var expiry = new Date(expiryDate)
                        .setHours(0, 0, 0, 0);

                    // validation :
                    // expiration >= début partage
                    return expiry > start;
                }
            }
        ]
    });

    $("#ShareStartDate")
        .dxDateBox("instance")
        .option("onValueChanged", function () {
            
            $("#ShareExpiryDate")
                .dxValidator("instance")
                .validate();
        });
};

