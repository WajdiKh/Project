@{
    bool hasAccess =
        _roleAccess.HasClaims(ActiviteModule.TRANSFERT, ClaimUser.READ) ||
        _roleAccess.HasClaims(ActiviteModule.TRANSFERT, ClaimUser.WRITE);
}

<li class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower() == "document" ? "active" : string.Empty)">
    <a class="nav-link @(hasAccess ? "" : "disabled")"
       href="@(hasAccess ? $"/{currentCulture}/transfert/document" : "#")"
       tabindex="@(hasAccess ? "0" : "-1")"
       aria-disabled="@(!hasAccess)">
        @translator.Common["Transfert"]
    </a>
</li>