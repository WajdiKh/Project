// SCRIPT SQL : NOTIFICATION DocumentTelecharge
// DESCRIPTION : crée le type de notification et les templates FR/EN.
// IMPORTANT : on récupère l'Id du type par Code côté SQL.
// Le code C# récupère aussi le type par Code, donc pas besoin d'ajouter
// NotificationType.DocumentTelecharge dans l'enum.
// ============================================================================

IF NOT EXISTS (
    SELECT 1
    FROM [Commun].[EmailNotificationType]
    WHERE [Code] = 'DocumentTelecharge'
)
BEGIN
    INSERT INTO [Commun].[EmailNotificationType]
    (
        [Code],
        [Libelle],
        [Description],
        [DateCreation],
        [DateModification],
        [ModificateurId],
        [CreateurId],
        [IsActive]
    )
    VALUES
    (
        'DocumentTelecharge',
        'DocumentTelecharge',
        'DocumentTelecharge',
        SYSDATETIMEOFFSET(),
        NULL,
        NULL,
        NULL,
        1
    );
END;

