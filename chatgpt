function validateTransmissionReaRejRow(e) {
    var rowData = $.extend(
        {},
        e.oldData || {},
        e.newData || {}
    );

    var selectedRelation =
        rowData.TypeRelationAffaireLab;

    var relationCode =
        rowData.TypeRelationAffaireLabCode
        || rowData.TypeRelationAffaireCode
        || (selectedRelation ? selectedRelation.Code : null);

    if (relationCode !== "TRA3") {
        return;
    }

    if (rowData.IsReaRej === true) {
        return;
    }

    if (isNullOrEmpty(rowData.DateCessationRelations)) {
        e.isValid = false;
        e.errorText = _labDateCessationRelationRequired;
    }
}


