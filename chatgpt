function getDateCessationRelationValidatorInstance(index) {

    var validator = $("#DateCessationRelationValidator" + index);

    if (validator.length === 0) {
        return null;
    }

    return validator.dxValidator("instance");
}

function refreshDateCessationRelationValidationPersonnePhysique(index) {

    var isCessationBlocageVente =
        isRelationAffaireCessationBlocageVentePersonnePhysique(index);

    var isReaRejChecked =
        isReaRejPersonnePhysiqueChecked(index);

    var isDateRequired =
        isCessationBlocageVente && !isReaRejChecked;

    var validator = getDateCessationRelationValidatorInstance(index);

    if (!validator) {
        return;
    }

    validator.option("validationRules",
        isDateRequired
            ? [{
                type: "required",
                message: _labDateCessationRelationRequired
            }]
            : []);

    validator.reset();

    var dateBox = getDateCessationRelationPersonnePhysiqueInstance(index);

    if (dateBox) {
        dateBox.option("isValid", true);
        dateBox.option("validationError", null);
    }
}


