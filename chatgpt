// document.js
window.Transfert = window.Transfert || {};
window.Transfert.Document = window.Transfert.Document || {};

// Bootstrap

$(document).ready(function () {
    Transfert.Document.initState();
    Transfert.Document.initMenuSelectMode();
    Transfert.Document.applyMode(Transfert.Document.getInitialMode());
    Transfert.Document.initAddButton();
    Transfert.Document.initShareButton();
    Transfert.Document.initShareSettingsButton();
});

Transfert.Document.initState = function () {
    Transfert.Document.selectedDocument = null;
    Transfert.Document.selectedDocumentShare = null;
};

Transfert.Document.getInitialMode = function () {
    if (_transfertCurrentMode === "mine" && !_transfertCanWrite) {
        return "all";
    }

    return _transfertCurrentMode || "all";
};



// Menu

Transfert.Document.getModeLabel = function (mode) {
    if (mode === "mine") {
        return _transfertTranslatableMenuMyDocuments;
    }

    if (mode === "shared") {
        return _transfertTranslatableMenuSharedWithMe;
    }

    return _transfertTranslatableMenuAllDocuments;
};

Transfert.Document.getModeIcon = function (mode) {
    if (mode === "mine") {
        return "fas fa-user color-green2 adjust-icon-menu";
    }

    if (mode === "shared") {
        return "fas fa-share-alt color-green2 adjust-icon-menu";
    }

    return "fas fa-list color-green2 adjust-icon-menu";
};

Transfert.Document.getMenuItems = function (mode) {
    var items = [
        {
            icon: "fas fa-list adjust-icon-submenu",
            text: _transfertTranslatableMenuAllDocuments,
            onClick: function () {
                Transfert.Document.applyMode("all");
            }
        },
        {
            icon: "fas fa-share-alt adjust-icon-submenu",
            text: _transfertTranslatableMenuSharedWithMe,
            onClick: function () {
                Transfert.Document.applyMode("shared");
            }
        }
    ];

    if (_transfertCanWrite) {
        items.splice(1, 0, {
            icon: "fas fa-user adjust-icon-submenu",
            text: _transfertTranslatableMenuMyDocuments,
            onClick: function () {
                Transfert.Document.applyMode("mine");
            }
        });
    }

    return [
        {
            icon: Transfert.Document.getModeIcon(mode),
            text: Transfert.Document.getModeLabel(mode),
            items: items
        }
    ];
};


Transfert.Document.initMenuSelectMode = function () {
    $("#menuSelectMode").dxMenu({
        items: Transfert.Document.getMenuItems(Transfert.Document.getInitialMode())
    });
};

Transfert.Document.refreshMenuSelectMode = function (mode) {
    var menu = $("#menuSelectMode").dxMenu("instance");

    if (!menu) {
        return;
    }

    menu.option("items", Transfert.Document.getMenuItems(mode));
};

Transfert.Document.applyMode = function (mode) {
    if (mode === "mine" && !_transfertCanWrite) {
        mode = "all";
    }

    _transfertCurrentMode = mode;

    Transfert.Document.refreshMenuSelectMode(mode);

    $("#gridAllDocumentsContainer").hide();
    $("#gridMyDocumentsContainer").hide();
    $("#gridSharedDocumentsContainer").hide();

    var containerId = null;
    var gridId = null;

    if (mode === "mine") {
        containerId = "gridMyDocumentsContainer";
        gridId = "myDocumentsGrid";
    }
    else if (mode === "shared") {
        containerId = "gridSharedDocumentsContainer";
        gridId = "sharedDocumentsGrid";
    }
    else {
        containerId = "gridAllDocumentsContainer";
        gridId = "allDocumentsGrid";
    }

    $("#" + containerId).show();

    Transfert.Document.refreshGrid(gridId);
};

// Grids

Transfert.Document.refreshGrid = function (gridId) {
    var grid = $("#" + gridId).dxDataGrid("instance");

    if (!grid) {
        return;
    }

    grid.refresh();
};

Transfert.Document.refreshShareSettingsGrid = function () {
    var grid = $("#shareSettingsGrid").dxDataGrid("instance");

    if (grid) {
        grid.refresh();
    }
};

Transfert.Document.onMyDocumentsSelectionChanged = function (e) {
    var selectedRows = e.selectedRowsData;

    Transfert.Document.selectedDocument =
        selectedRows && selectedRows.length > 0
            ? selectedRows[0]
            : null;

    var hasSelection = !!Transfert.Document.selectedDocument;

    Transfert.Document.setButtonVisible("btnShareDocument", hasSelection && _transfertCanWrite);
    Transfert.Document.setButtonVisible("btnShareSettingsDocument", hasSelection && _transfertCanWrite);
};



// Add Document

Transfert.Document.initAddButton = function () {
    if (!_transfertCanWrite) {
        $("#btnAddDocument").hide();
        return;
    }

    $("#btnAddDocument").dxButton({
        text: _commonTranslatableMessageAdd,
        icon: "add",
        elementAttr: {
            class: "color-blue"
        },
        onClick: function () {
            Transfert.Document.openAddPopup();
        }
    });
};

Transfert.Document.openAddPopup = function () {
    $.ajax({
        method: "GET",
        cache: false,
        url: "/" + culture + "/transfert/add-document"
    }).done(function (htmlContent) {
        showScrollablePopup(_transfertAddNewDocumentPopupId, htmlContent);
        Transfert.Document.initAddDocumentValidators();
        Transfert.Document.initFileUploaderChange();
    }).fail(function (e) {
        Transfert.Document.handleAjaxError(e);
    });
};

Transfert.Document.closeAddDocumentPopup = function () {
    closePopup(_transfertAddNewDocumentPopupId);
};

