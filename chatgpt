Remplacer ValidateShareRecipients + ValidateRecipientsTransfertAccess par une seule méthode groupée :

private void ValidateTransferRecipients(
    IEnumerable<string> emails,
    IEnumerable<Utilisateur> recipients)
{
    var recipientEmails = recipients
        .Where(x => !string.IsNullOrWhiteSpace(x.Email))
        .Select(x => x.Email)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

    var invalidEmails = emails
        .Where(x => !recipientEmails.Contains(x))
        .ToList();

    var unauthorizedEmails = recipients
        .Where(x => !CanRecipientAccessTransfert(x))
        .Select(x => x.Email)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .ToList();

    var rejectedEmails = invalidEmails
        .Concat(unauthorizedEmails)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();

    if (rejectedEmails.Any())
    {
        throw new CustomMessageException(
            string.Format(
                _translator.Common["Transfert.Document.RecipientsNotAuthorizedTransfer"],
                string.Join(", ", rejectedEmails)));
    }
}

Garder CanRecipientAccessTransfert avec IUtilisateurDirectionService :

private bool CanRecipientAccessTransfert(Utilisateur recipient)
{
    if (recipient == null)
        return false;

    return _utilisateurDirectionService.CanViewDossier(recipient.Id)
        || _utilisateurDirectionService.CanCreateDossier(recipient.Id);
}

