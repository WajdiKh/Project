            cursor: pointer;
        }

        #activity-title-container {
            top: 60px;
            width: 100%;
            position: fixed;
            padding: 4px 0 0 4px;
            user-select: none;
            color: #177775 !important;
            background-image: linear-gradient(to right, #b7d0cf, #c9dbe0, #dde6ec, #f0f2f6, #ffffff);
            z-index: 999;
        }
    </style>
    <script>
        $(document).ready(function () {
            window.setInterval(function () {
                $.ajax({
                    method: "Get",
                    cache: false,
                    async: true,
                    dataType: "json",
                    url: '/' + culture + '/Account/GetIamConnected',
                }).done(function (data) {
                    if (data != "null" && data != null) {
                        if (data.connected == false) {
                            var popup = $("#modalReconnect").dxPopup('instance');
                            if (popup) popup.show();
                        }
                    }
                });
            }, 30000);
        });
    </script>
    <script>
        $(document).ready(function () {
            $(window).resize(function () {
                resizeContainer();
            });
            resizeContainer();
        });
    </script>
