                    @(Html.DevExtreme()
                        .TextBox()
                        .ID("ShareEmails")
                        .Name("Emails")
                        .Height(30)
                        .Width("100%"))
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-12 col-md-3">
                    <div class="text-truncate text-green">Date d'expiration :</div>
                </div>
