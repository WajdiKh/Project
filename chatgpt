var _transfertTranslatableDocumentDeleteConfirmation =
"@Html.Raw(translator.Common["Transfert.Document.DeleteConfirmation"])";

var _transfertTranslatableDocumentDeleteSuccess =
"@Html.Raw(translator.Common["Transfert.Document.DeleteSuccess"])";

var _transfertTranslatableDocumentDeleteError =
"@Html.Raw(translator.Common["Transfert.Document.DeleteError"])";


// ==========================================================
// ======================= SQL FR ===========================
// ==========================================================

MERGE [Commun].[Traduction] AS TARGET
USING
(
    SELECT
        'Transfert.Document.DeleteConfirmation' AS Code,
        'Voulez-vous vraiment supprimer ce document ?' AS FrenchTranslation,
        'Do you really want to delete this document ?' AS EnglishTranslation

    UNION ALL

    SELECT
        'Transfert.Document.DeleteSuccess',
        'Document supprimé avec succès.',
        'Document deleted successfully.'

    UNION ALL

    SELECT
        'Transfert.Document.DeleteError',
        'Erreur lors de la suppression du document.',
        'Error while deleting document.'

    UNION ALL

    SELECT
        'Transfert.Document.InvalidSecurityCode',
        'Code de sécurité invalide.',
        'Invalid security code.'

    UNION ALL

    SELECT
        'Transfert.Document.SecurityCode',
        'Code de sécurité',
        'Security code'

    UNION ALL

    SELECT
        'Transfert.Document.DownloadUnauthorized',
        'Vous n''êtes pas autorisé à télécharger ce document.',
        'You are not authorized to download this document.'

    UNION ALL

    SELECT
        'Transfert.Document.Expired',
        'Document expiré.',
        'Expired document.'

) AS SOURCE
ON TARGET.Code = SOURCE.Code

WHEN MATCHED THEN
    UPDATE SET
        FrenchTranslation = SOURCE.FrenchTranslation,
        EnglishTranslation = SOURCE.EnglishTranslation

WHEN NOT MATCHED THEN
    INSERT
    (
        Code,
        FrenchTranslation,
        EnglishTranslation
    )
    VALUES
    (
        SOURCE.Code,
        SOURCE.FrenchTranslation,
        SOURCE.EnglishTranslation
    );


