@inject IViewTranslator translator
@inject IRoleAccessUser _roleAccess

@model Tuple<DossierLabPersonnePhysiqueViewModel, int>;
@inject IReferentielViewModel _referentiel;

@{
    var _isReadOnly = Model.Item1.IsReadOnly;
    var _lang = Context.Features.Get<IRequestCultureFeature>().RequestCulture.Culture.ToString().ToCamelCase();
    var typesClient = Model.Item1.DirectionId is > 0 ? _referentiel.GetTypeClientLabs(Model.Item1.DirectionId.Value).Where(x => x.IsCorporate != true) : null;
    dynamic dateNaissanceEntete = Model.Item1.PersonnePhysiqueLab.DateNaissance != DateTime.MinValue && Model.Item1.PersonnePhysiqueLab.DateNaissance.HasValue && Model.Item1.PersonnePhysiqueLab.DateNaissance > DateTime.Today && Model.Item1.PersonnePhysiqueLab.DateNaissance <= new DateTime(1900, 1, 1) ? Model.Item1.PersonnePhysiqueLab.DateNaissance.Value.ToString(_lang == "Fr" ? "dd/MM/yyyy" : "yyyy-MM-dd", CultureInfo.InvariantCulture) : string.Empty;
    var relationAffaires = translator.Common["RelationAffaires"];
    var clientOccasionnel = translator.Common["ClientOccasionnel"];
    var tentativeEer = translator.Common["TentativeEer"];
    var typesImplication = _referentiel.TypesImplicationLabs;
    var priorities = new[] { new { Id = 1, Name = relationAffaires }, new { Id = 2, Name = clientOccasionnel }, new { Id = 3, Name = tentativeEer } };
    var hasDateNaissance = Model.Item1.PersonnePhysiqueLab.DateNaissance != DateTime.MinValue && dateNaissanceEntete.Trim() != string.Empty && Model.Item1.PersonnePhysiqueLab.DateNaissance > DateTime.Today && Model.Item1.PersonnePhysiqueLab.DateNaissance <= new DateTime(1900, 1, 1);
    var canalEntreeRelationSources = _referentiel.CanalsEntreeEnRelation.Where(x => x.ActiviteId == 1);
    var hasTypeRelationAffaire = Model.Item1.PersonnePhysiqueLab.TypeRelationAffaireLab != null;
    var typeRelationAffaire = Model.Item1.Culture == "Fr"
        ? Model.Item1.PersonnePhysiqueLab.TypeRelationAffaireLab?.NameFr
        : Model.Item1.PersonnePhysiqueLab.TypeRelationAffaireLab?.NameEn;
    var _isRelationTerminee = Model.Item1.PersonnePhysiqueLab.TypeRelationAffaireLabId == 4 || Model.Item1.PersonnePhysiqueLab.TypeRelationAffaireLabId == 3;
    var isRobot = _roleAccess.HasRoles(ActiviteModule.Lab, null, RoleUser.Robot);
    var isIsole = _roleAccess.HasClaimIsole(ActiviteModule.Lab);
    var isPp = "True";
    var isPm = "False";
    var Yes = "Oui";
    var No = "Non";
    var YesEu = "Oui, dans l'UE";
    var YesNoEu = "Oui, hors UE";
    var dontKnow = "Je ne sais pas";

    var ouiNonDontKnow = new[] { new { Id = 1, Name = Yes }, new { Id = 2, Name = No }, new { Id = 3, Name = dontKnow } };
    var ouiNon = new[] { new { Id = 1, Name = Yes }, new { Id = 0, Name = No } };

    var ouiNonEu = new[] { new { Id = 1, Name = YesEu }, new { Id = 2, Name = YesNoEu }, new { Id = 3, Name = No } };

    var idEtranger = _referentiel.IdentificationProfessionnelles
        .Single(idp => idp.Code == nameof(IdentificationProfessionnelleEnum.RN6))
        .Id;
    var requiredAsteriskSuffix = Model.Item2 + Constants.AsteriskIdSuffix;
}
<script type="text/javascript">
    $(document).ready(function () {
        ppeId_lab_OnValueChanged(@Model.Item2);
        arrayFirstLoadPersonnePhysique[@(Model.Item2)] = true;
        setPartialPersonnePhysiqueLabAdditionalValidationRules(@(Model.Item2));
        identificationProfessionnelle_OnValueChanged(@(Model.Item2));
        disableEnableRequiredFiledOnAddPpPm();
        $(".afterPersonneDsField").toggleClass("pr-xl-1", !_labIsDeclarationTracfin);
        toggleDisplayButtonAddNewCoordonnee(@Model.Item2);
    });
</script>
<div class="card physicalPerson" id="rowPhysicalPerson@(Model.Item2)">
    @Html.TextBox($"DossierLabPersonnePhysiques[{Model.Item2}].CryptedId", Model.Item1.CryptedId, new { type = "hidden" })
    @Html.TextBox($"DossierLabPersonnePhysiques[{Model.Item2}].CryptedPersonnePhysiqueLabId", Model.Item1.CryptedPersonnePhysiqueLabId, new { id = "CryptedPersonnePhysiqueLabId" + Model.Item2, type = "hidden" })
    @Html.TextBox($"DossierLabPersonnePhysiques[{Model.Item2}].CryptedDossierLabId", Model.Item1.CryptedDossierLabId, new { type = "hidden" })
    @Html.TextBox($"DossierLabPersonnePhysiques[{Model.Item2}].PersonnePhysiqueLab.CryptedId", Model.Item1.PersonnePhysiqueLab.CryptedId, new { id = "CryptedPersonnePhysiqueLabCryptedId" + Model.Item2, type = "hidden" })
    @Html.TextBox($"DossierLabPersonnePhysiques[{Model.Item2}].PersonnePhysiqueLab.IdPersonne", Model.Item1.PersonnePhysiqueLab?.IdPersonne, new { id = "PersonnePhysiqueLabIdPersonne" + Model.Item2, type = "hidden" })
    @Html.TextBox($"DossierLabPersonnePhysiques[{Model.Item2}].ToDelete", Model.Item1.ToDelete, new { id = "physicalPersonToDelete" + Model.Item2, type = "hidden" })
    @Html.TextBox($"DossierLabPersonnePhysiques[{Model.Item2}].physicalPersonIsAlreadyImported", false, new { id = "physicalPersonIsAlreadyImported" + Model.Item2, type = "hidden" })
    @Html.TextBox($"DossierLabPersonnePhysiques[{Model.Item2}].IsNew", Model.Item1.IsNew, new { id = "physicalPersonIsNew" + Model.Item2, type = "hidden" })
    <div class="card-header p-1" id="headingPhysicalPerson@(Model.Item2)">
        <div class="d-flex adjust-card-header justify-content-between">
            <div style="width: 100%;">
                <a href="#" id="link@(Model.Item2)" data-toggle="collapse" data-target="#collapsePhysicalPerson@(Model.Item2)" aria-expanded="false" aria-controls="collapsePhysicalPerson@(Model.Item2)" style="text-decoration:none !important; color:inherit">
                    <div>
                        <i class="fas fa-user-plus mr-2"></i>@(translator.Common["PhysicalPerson"]) :
                        <span id="identityPhysicalPerson@(Model.Item2)"> @($"{Model.Item1.PersonnePhysiqueLab.Prenoms} {Model.Item1.PersonnePhysiqueLab.NomNaissance}") @(hasDateNaissance ? "(" : string.Empty)@(dateNaissanceEntete)@(hasDateNaissance ? ")" : string.Empty) @(hasTypeRelationAffaire ? " - " : string.Empty)@(typeRelationAffaire) </span>
                    </div>
                </a>
            </div>
            <div class="d-flex isPersonneDs @(Model.Item1.showIsDeclarationTracfin ? "" : "dx-hidden") mr-5">
                <div class="text-truncate mr-3">
                    <span class="smallCaps text-green font-size-14px font-weight-bold">@translator.Common["IntegreeDs"]</span>
                </div>
                <div>
                    @(Html.DevExtreme().CheckBoxFor(x => x.Item1.IsDeclarationTracfin)
                        .Name($"DossierLabPersonnePhysiques[{Model.Item2}].IsDeclarationTracfin")
                        .ID("PersonnePhysiqueLabIsDeclarationTracfin" + Model.Item2)
                        .ElementAttr("class", "smallCaps text-green")
                        .ReadOnly(_isReadOnly)
                        .OnValueChanged(@<text>
                                             function(e)
                                             {
                                             if(!ensureNombreTiersIntegresDsBelowMaximumNumber(e) ||
                                             !ensureNombreLiensPersonnesIntegreesDsParDossierBelowMaxNumber(e) ||
                                             !ensureNombreReferencesFinancieresTiersIntegresDsBelowMaximumNumber(e))
                                             return;
                                             refreshAllOperationsAssurancesConcernedPersonsLists();
                                             refreshAllOperationsImmobilieresConcernedPersonsLists();
                                             }
                                         </text>))
                </div>
            </div>
            @if (!isRobot && !isIsole)
            {
                <div class="pr-1">
                    @(Html.DevExtreme().Button()
                        .Icon(Url.Content("~/images/person-vcard.svg"))
                        .Hint(translator.Common["Lab.PiecesIdentite.SearchAndDownload"])
                        .ElementAttr(new Dictionary<string, object>
                        {
                            { "class", "btn-pieces-identite" }
                        })
                        .ID("btnPiecesIdentitePersonnePhysiqueLab" + Model.Item2)
                        .Visible(true)
                        .OnClick(@<text>
                            function () {
                                searchPiecesIdentitePersonnePhysique('@(Model.Item2)');
                            }
                        </text>))
                </div>
                <div class="pr-1">
                    @(Html.DevExtreme().Button()
                        .Icon("search")
                        .ElementAttr("class", "color-blue")
                        .ID("CriblagePersonnePhysiqueLab" + Model.Item2)
                        .Hint(translator.Common["CriblagePersonnePhysiqueParNom"])
                        .Visible(!_isReadOnly)
                        .OnClick(@<text>
                                      function () {
                                      showCriblagePersonnePhysiqueLab_onClick('@(Model.Item2)')
                                      }
                                  </text>))
                </div>
            }
            <div class="pr-1">
                @(Html.DevExtreme().Button()
                    .Icon("trash")
                    .ElementAttr("class", "color-red")
                    .ID("remRowDossierLabPersonnePhysiqueLab" + Model.Item2)
                    .OnClick(@<text>
                                  function () {
                                  var confirmDialog = DevExpress.ui.dialog.custom({
                                  title: "@translator.Common["Warning"]",
                                  message: "@translator.Common["VoulezVousSupprimerSujet"]",
                                  buttons: [{ text: "@translator.Common["Yes"]", onClick: function() { return true; } }, { text: "@translator.Common["No"]", onClick: function() { return false; } }]
                                  });
                                  confirmDialog.show().done(function (dialogResult) {
                                  if (dialogResult)
                                  {
                                  removePhysicalPerson(@(Model.Item2));
                                  refreshAllOperationsAssurancesConcernedPersonsLists();
                                  refreshAllOperationsImmobilieresConcernedPersonsLists();
                                  }
                                  });
                                  }
                              </text>).Visible(!_isReadOnly))
            </div>

            <div>
                @(Html.DevExtreme().Button()
                    .Icon("card")
                    .ElementAttr("class", "color-blue")
                    .ID("addDossierFraudePersonnePhysiqueLab" + Model.Item2).OnClick(@<text>
                                                                                          function () {

                                                                                          searchPpPm_OnClick('@(Model.Item2)','@isPp','@isPm');
                                                                                          }
                                                                                      </text>).Visible(!_isReadOnly)
                )
                @(Html.DevExtreme().Popup()
                    .ID("searchThirdModal")
                    .ElementAttr(new Dictionary<string, object>
                        { { "class", "popup" } })
                    .ShowTitle(true)
                    .DragEnabled(true).ShowCloseButton(true)
                    .ResizeEnabled(false)
                    .Width("100%")
                    .Height("auto")
                    .ElementAttr("style", "min-Height:60%;overflow-y: scroll;")
                    .TitleTemplate(@<text>
                                        <div class="d-flex flex-row align-items-center justify-content-between">
                                            <div class="font-size-16px text-green text-font-weight-600 smallCaps text-green">
                                                <i class="fas fa-pen mr-2"></i>@translator.Common["SearchThird"]
                                            </div>
                                            <button style="cursor: pointer; font-size: 24px; background-color: transparent; border: none; padding: 0; color: inherit;" onclick="$('#searchThirdModal').dxPopup('hide');">&times;</button>
                                        </div>
                                    </text>))
            </div>
        </div>
    </div>
    <div id="collapsePhysicalPerson@(Model.Item2)" class="collapse hide" aria-labelledby="headingPhysicalPerson@(Model.Item2)" data-parent="#accordionPhysicalPersonsList">
        <div>
            <div class="mt-3">
                <div class="nav nav-tabs mb-3 adjust-nav-tab" id="nav-tab" role="tablist">
                    <a class="nav-item nav-link smallCaps text-green active" id="nav-identification-tab@(Model.Item2)" data-toggle="pill" href="#nav-identification@(Model.Item2)" role="tab" aria-controls="nav-identification@(Model.Item2)" aria-selected="true">
                        @translator.Common["Identification"]
                        @(Html.DevExtreme().Tooltip().Width(500)
                            .ID("ToolTip-nav-identification" + Model.Item2)
                            .Target("#nav-identification-tab" + Model.Item2)
                            .ShowEvent("mouseenter")
                            .HideEvent("mouseleave")
                            .CloseOnOutsideClick(false)
                            .Position(Position.Bottom)
                            .ContentTemplate(@<text>
                                                  <div class='smallCaps text-green toolTipSearch text-justify' style="max-width: 500px;">
                                                      @Html.Raw(translator.Common["ToolTipIdentificationNav"])
                                                  </div>
                                              </text>)
                        )
                    </a>
                    <a class="nav-item nav-link smallCaps text-green" id="nav-coordonnees-pp-tab@(Model.Item2)" data-toggle="pill" href="#nav-coordonnees-pp@(Model.Item2)" role="tab" aria-controls="nav-coordonnees-pp@(Model.Item2)" aria-selected="false">@translator.Common["Coordonnees"]</a>
                    <a class="nav-item nav-link smallCaps text-green" id="nav-pieceidentites-tab@(Model.Item2)" data-toggle="pill" href="#nav-pieceidentites@(Model.Item2)" role="tab" aria-controls="nav-pieceidentites@(Model.Item2)" aria-selected="false">
                        @translator.Common["PieceIdentitesHistorique"]
                        @(Html.DevExtreme().Tooltip().Width(500)
                            .ID("ToolTip-nav-pieceidentites-tabPp" + Model.Item2)
                            .Target("#nav-pieceidentites-tab" + Model.Item2)
                            .ShowEvent("mouseenter")
                            .HideEvent("mouseleave")
                            .CloseOnOutsideClick(false)
                            .Position(Position.Bottom)
                            .ContentTemplate(@<text>
                                                  <div class='smallCaps text-green toolTipSearch text-justify' style="max-width: 500px;">
                                                      @Html.Raw(translator.Common["ToolTipPieceIdentite"])
                                                  </div>
                                              </text>)
                        )
                    </a>
                    <a class="nav-item nav-link smallCaps text-green" id="nav-activite-tab@(Model.Item2)" data-toggle="pill" href="#nav-activite@(Model.Item2)" role="tab" aria-controls="nav-activite@(Model.Item2)" aria-selected="false">@translator.Common["ActiviteProfessionnelle"]</a>
                    <a class="nav-item nav-link smallCaps text-green" id="nav-surfacefinanciere-tab@(Model.Item2)" data-toggle="pill" href="#nav-surfacefinanciere@(Model.Item2)" role="tab" aria-controls="nav-surfacefinanciere@(Model.Item2)" aria-selected="false">@translator.Common["SurfaceFinanciere"]</a>
                    <a class="nav-item nav-link smallCaps text-green" id="nav-relationclient-tab@(Model.Item2)" data-toggle="pill" href="#nav-relationclient@(Model.Item2)" role="tab" aria-controls="nav-relationclient@(Model.Item2)" aria-selected="false">@translator.Common["RelationClient"]</a>
                    <a class="nav-item nav-link smallCaps text-green" id="nav-supportfinancier-tab@(Model.Item2)" data-toggle="pill" href="#nav-supportfinancier@(Model.Item2)" role="tab" aria-controls="nav-supportfinancier@(Model.Item2)" aria-selected="false">@translator.Common["ReferencesFinancieres"]</a>
                    @(Html.DevExtreme().Tooltip().Width(500)
                        .ID("ToolTip-nav-supportfinancierPp" + Model.Item2)
                        .Target("#nav-supportfinancier-tab" + Model.Item2)
                        .ShowEvent("mouseenter")
                        .HideEvent("mouseleave")
                        .CloseOnOutsideClick(false)
                        .Position(Position.Bottom)
                        .ContentTemplate(@<text>
                                              <div class='smallCaps text-green toolTipSearch text-justify' style="max-width: 500px;">
                                                  @Html.Raw(translator.TemplateTraduction["ToolTipNavSupportFinancierNav"])
                                              </div>
                                          </text>)
                    )
                    <a class="nav-item nav-link smallCaps text-green" id="nav-notoriete-tab@(Model.Item2)" data-toggle="pill" href="#nav-notoriete@(Model.Item2)" role="tab" aria-controls="nav-notoriete@(Model.Item2)" aria-selected="false">@translator.Common["NotorieteDefavorable"]</a>
                    <a class="nav-item nav-link smallCaps text-green" id="nav-liens-personnephysique-tab@(Model.Item2)" data-toggle="pill" href="#nav-liens-personnephysique@(Model.Item2)" role="tab" aria-controls="nav-liens-personnephysique@(Model.Item2)" aria-selected="false">@translator.Common["Liens"]</a>
                    @(Html.DevExtreme().Tooltip().Width(500)
                        .ID("ToolTip-nav-liens-personnephysique-tab" + Model.Item2)
                        .Target("#nav-liens-personnephysique-tab" + Model.Item2)
                        .ShowEvent("mouseenter")
                        .HideEvent("mouseleave")
                        .CloseOnOutsideClick(false)
                        .Position(Position.Bottom)
                        .ContentTemplate(@<text>
                                              <div class='smallCaps text-green toolTipSearch text-justify' style="max-width: 500px;">
                                                  @Html.Raw(translator.TemplateTraduction["ToolTipLiensPersonnephysiqueNav"])
                                              </div>
                                          </text>)
                    )
                </div>
                <div class="tab-content" id="nav-tabContent">
                    <div class="tab-pane fade show active" id="nav-identification@(Model.Item2)" role="tabpanel" aria-labelledby="nav-identification-tab@(Model.Item2)">
                        <div class="col-12 mb-3">
                            <div class="card bloc-card-personne">
                                <div class="card-body p-2">
                                    <h6 class="card-title">@translator.Common["BasicInformations"]</h6>
                                    <div class="row text-normal">
                                        <div class="col-sm-6 col-md-4 col-lg-2 col-xl-2 pr-1">
                                            <div class="text-truncate">
                                                <span class="smallCaps text-green">@translator.Common["IdentifiantClient"]</span>
                                            </div>
                                            @(Html.DevExtreme().TextBoxFor(x => x.Item1.PersonnePhysiqueLab.IdentifiantClient)
                                                .Height(30).Name($"DossierLabPersonnePhysiques[{Model.Item2}].PersonnePhysiqueLab.IdentifiantClient")
                                                .ID("PersonnePhysiqueLabIdentifiantClient" + Model.Item2)
                                                .ShowClearButton(true).ReadOnly(_isReadOnly))
                                        </div>
                                        <div class="col-sm-6 col-md-4 col-lg-2 col-xl-3 pl-lg-1 pl-xl-1 pr-lg-1 pr-xl-1 pl-md-1 ">
                                            <div class="text-truncate">
                                                <span class="smallCaps text-green">
                                                    @translator.Common["NomNaissance"] <span class="RequiredField">*</span>
                                                </span>
                                            </div>
                                            @(Html.DevExtreme().TextBoxFor(x => x.Item1.PersonnePhysiqueLab.NomNaissance)
                                                .Height(30).Name($"DossierLabPersonnePhysiques[{Model.Item2}].PersonnePhysiqueLab.NomNaissance")
                                                .OnValueChanged(@<text>
                                                                     function() {
                                                                     updateHeaderIdentityPhysicalPerson(@(Model.Item2));
                                                                     refreshAllOperationsAssurancesConcernedPersonsLists();
                                                                     refreshAllOperationsImmobilieresConcernedPersonsLists();
                                                                     }
                                                                 </text>)
                                                .ID("PersonnePhysiqueLabNomNaissance" + Model.Item2).ReadOnly(_isReadOnly).ShowClearButton(true).ElementAttr("class", "mandatory"))
                                        </div>

                                        <div class="col-sm-6 col-md-4 col-lg-2 col-xl-2 pl-1 pr-md-1 pr-lg-1 pr-xl-1">
                                            <div class="text-truncate">
                                                <span class="smallCaps text-green">@translator.Common["NomUsuel"]</span>
                                            </div>
                                            @(Html.DevExtreme().TextBoxFor(x => x.Item1.PersonnePhysiqueLab.NomUsuel)
                                                .Height(30).Name($"DossierLabPersonnePhysiques[{Model.Item2}].PersonnePhysiqueLab.NomUsuel")
                                                .ID("PersonnePhysiqueLabNomUsuel" + Model.Item2)
                                                .ShowClearButton(true).ReadOnly(_isReadOnly))
                                        </div>
                                        <div class="col-sm-6 col-md-4 col-lg-2 col-xl-3 pl-lg-1">
                                            <div class="text-truncate">
                                                <span class="smallCaps text-green">
                                                    @translator.Common["Prenoms"] <span class="RequiredField">*</span>
                                                </span>
                                            </div>
                                            @(Html.DevExtreme().TextBoxFor(x => x.Item1.PersonnePhysiqueLab.Prenoms)
                                                .Height(30)
                                                .Name($"DossierLabPersonnePhysiques[{Model.Item2}].PersonnePhysiqueLab.Prenoms")
                                                .OnValueChanged(@<text>
                                                                     function() {
                                                                     updateHeaderIdentityPhysicalPerson(@(Model.Item2));
                                                                     refreshAllOperationsAssurancesConcernedPersonsLists();
                                                                     refreshAllOperationsImmobilieresConcernedPersonsLists();
                                                                     }
                                                                 </text>)
                                                .ID("PersonnePhysiqueLabPrenoms" + Model.Item2).ShowClearButton(true).ElementAttr("class", "mandatory").ReadOnly(_isReadOnly))
                                        </div>
                                        <div class="col-sm-6 col-md-4 col-lg-2 col-xl-2 pl-1">
                                            <div class="text-truncate">
                                                <span class="smallCaps text-green">
                                                    @translator.Common["Alias"]
                                                    <i id="targetAlias@(Model.Item2)" class="fas fa-info-circle infoTooltipTarget"></i>
                                                </span>

                                            </div>
                                            @(Html.DevExtreme().TextBoxFor(x => x.Item1.PersonnePhysiqueLab.Alias)
		                                        .Height(30)
		                                        .Name($"DossierLabPersonnePhysiques[{Model.Item2}].PersonnePhysiqueLab.Alias")
		                                        .ID("PersonnePhysiqueLabAlias" + Model.Item2).ShowClearButton(true).ReadOnly(_isReadOnly))
                                            @(Html.DevExtreme().Tooltip().Width(500)
                                                .ID("ToolTip-Alias" + Model.Item2)
                                                .Target("#targetAlias" + Model.Item2)
                                                .ShowEvent("mouseenter")
                                                .HideEvent("mouseleave")
                                                .CloseOnOutsideClick(false)
                                                .Position(Position.Bottom)
                                                .ContentTemplate(@<text>
                                                                      <div class='smallCaps text-green toolTipSearch text-justify' style="max-width: 500px;">
                                                                          @Html.Raw(translator.Common["ToolTipAlias"])
                                                                      </div>
                                                                  </text>)
                                            )
                                        </div>

                                    </div>
                                    <div class="row text-normal pt-2">
                                        <div class="col-sm-6 col-md-4 col-lg-2 col-xl-3 pr-1">
                                            <div class="text-truncate"><span class="smallCaps text-green">@translator.Common["TypeImplication"] <span class="RequiredField" id="PersonnePhysiqueLabTypeImplicationId@(requiredAsteriskSuffix)">*</span></span></div>
                                            @(Html.DevExtreme().SelectBoxFor(x => x.Item1.PersonnePhysiqueLab.TypeImplicationId)
                                                .DataSourceOptions(c => c.Sort($"Name{_lang}")).DisplayExpr($"Name{_lang}")
                                                .ValueExpr("Id").Height(30)
                                                .Name($"DossierLabPersonnePhysiques[{Model.Item2}].PersonnePhysiqueLab.TypeImplicationId")
                                                .ID("PersonnePhysiqueLabTypeImplicationId" + Model.Item2).DataSource(typesImplication)
                                                .SearchEnabled(true)
                                                .OnValueChanged(@<text>
                                                    function() {
                                                        desactivateNotorieteDefavorableIfVictimePresumeSelectedPP(@(Model.Item2));
                                                    }
                                                </text>)
                                                .ElementAttr(new
                                                {
                                                    data_error_required = translator.Common["TypeImplicationObligatoire"]
                                                })
                                                .ShowClearButton(true)                                           
                                                .ReadOnly(_isReadOnly))
                                        </div>
                                        <div class="col-sm-6 col-md-4 col-lg-2 col-xl-3 pl-1 pr-md-1 pr-lg-1 pr-xl-">
                                            <div class="text-truncate"><span class="smallCaps text-green">@translator.Common["TypeClient"]</span></div>
                                            <div class="dx-hidden text-center loader-customer-type-individual"></div>
                                            @(Html.DevExtreme().SelectBoxFor(x => x.Item1.PersonnePhysiqueLab.TypeClientId)
                                                .DataSourceOptions(c => c.Sort($"Name{_lang}"))
                                                .DisplayExpr($"Name{_lang}")
                                                .ValueExpr("Id")
                                                .Height(30)
                                                .Name($"DossierLabPersonnePhysiques[{Model.Item2}].PersonnePhysiqueLab.TypeClientId")
                                                .ID("PersonnePhysiqueLabTypeClientId" + Model.Item2).DataSource(typesClient)
                                                .SearchEnabled(true).ShowClearButton(true)
                                                .ElementAttr("class", "input-customer-type-individual")
                                                .ReadOnly(_isReadOnly))
                                        </div>
                                        <div class="col-sm-6 col-md-4 col-lg-2 col-xl-2 pl-1 pr-md-1 pr-lg-1 pr-xl-1">
                                            <div class="text-truncate"><span class="smallCaps text-green">@translator.Common["Civilite"]</span></div>
                                            @(Html.DevExtreme().SelectBoxFor(x => x.Item1.PersonnePhysiqueLab.CiviliteId)
		                                        .DataSourceOptions(c => c.Sort($"Name{_lang}").Filter("['!', ['Id', '=', 4]]"))
		                                        .DisplayExpr($"Name{_lang}")
		                                        .ValueExpr("Id").Height(30)
		                                        .Name($"DossierLabPersonnePhysiques[{Model.Item2}].PersonnePhysiqueLab.CiviliteId")
		                                        .ID("PersonnePhysiqueLabCiviliteId" + Model.Item2).DataSource(_referentiel.Civilites)
		                                        .SearchEnabled(true)
		                                        .ShowClearButton(true)
		                                        .ReadOnly(_isReadOnly))
                                        </div>
                                        <div class="col-sm-6 col-md-4 col-lg-2 col-xl-2 pr-1 pl-1">
                                            <div class="text-truncate"><span class="smallCaps text-green">@translator.Common["Sexe"] </span></div>
                                            @(Html.DevExtreme().SelectBoxFor(x => x.Item1.PersonnePhysiqueLab.SexeId)
                                                .DataSourceOptions(c => c.Sort($"Name{_lang}"))
                                                .DisplayExpr($"Name{_lang}")
                                                .ValueExpr("Id").Height(30)
                                                .Name($"DossierLabPersonnePhysiques[{Model.Item2}].PersonnePhysiqueLab.SexeId")
