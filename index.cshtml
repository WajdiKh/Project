            .Pager(pager =>
                pager.ShowPageSizeSelector(true)
                    .ShowNavigationButtons(true)
                    .AllowedPageSizes(new List<int> { 10, 20, 50 }))
            .Columns(columns =>
            {
                columns.AddFor(m => m.Name)
                    .Caption(translator.Common["Transfert.Document.Name"]);

                columns.AddFor(m => m.Description)
                    .Caption(translator.Common["Description"])
                    .CellTemplate(@<text>
                        <div class="document-description-cell">
                            <%- data.Description %>
                        </div>
                    </text>);

                columns.AddFor(m => m.ContentType)
                    .Caption(translator.Common["Transfert.Document.FileType"]);

                columns.Add()
                    .Caption(translator.Common["Transfert.Document.FileSizeLabel"])
                    .CalculateCellValue("function(data) { return Transfert.Document.formatFileSize(data.FileSize); }");

                columns.AddFor(m => m.UploadDate)
                    .Caption(translator.Common["Transfert.Document.UploadDate"])
                    .DataType(GridColumnDataType.DateTime)
                    .Format(dateTimeFormat);

                columns.AddFor(m => m.ExpiryDate)
                    .Caption(translator.Common["Transfert.Document.ExpiryDate"])
                    .DataType(GridColumnDataType.DateTime)
                    .Format(dateTimeFormat);

                 columns.AddFor(m => m.OwnerName)
                    .Caption(translator.Common["Owner"]);

                columns.Add()
                    .Caption(translator.Common["Transfert.Document.Status"])
                    .DataField($"StatutDocumentName{language}");

                columns.Add()
                    .Caption("")
                    .Width(100)
                    .Alignment(HorizontalAlignment.Center)
                    .AllowFiltering(false)
                    .AllowSorting(false)
                    .AllowHeaderFiltering(false)
                    .AllowExporting(false)
                    .CellTemplate(@<text>
                        <div class="d-flex justify-content-center align-items-center w-100">
                            <a href="javascript:void(0)"
                            title="@translator.Common["Download"]"
                            onclick="Transfert.Document.downloadDocument(<%= data.Id %>)">
                                <i class="fas fa-download color-blue2"></i>
                            </a>
                        </div>
                    </text>);

            })
            .DataSource(ds => ds.Mvc()
                .RouteName("apiRoute")
                .Area("Transfert")
                .Controller("Document")
                .LoadAction("GetSharedWithMeDocuments")))
    </div>
</div>

@(Html.DevExtreme().Popup()
    .ID(TransfertConstants.AddNewDocumentPopupId)
    .ElementAttr(new Dictionary<string, object>
        { { "class", "popup" } })
    .ShowTitle(true)
    .DragEnabled(true)
    .ShowCloseButton(true)
    .ResizeEnabled(false)
    .Width("80%")
    .Height("auto")
    .TitleTemplate(@<text>
<div class="d-flex flex-row align-items-center justify-content-between">
    <div class="font-size-16px text-green text-font-weight-600 smallCaps text-green">
        <i class="fas fa-pen mr-2" aria-hidden="true"></i>@translator.Common["Add"]
    </div>
    <button type="button" class="popup-close-btn" aria-label="@translator.Common["Close"]"
            onclick="Transfert.Document.closeAddDocumentPopup();"
            style="cursor: pointer; font-size: 24px; background: none; border: none; padding: 0; color: inherit;">
        &times;
    </button>
</div>
</text>))

@(Html.DevExtreme().Popup()
    .ID(TransfertConstants.ShareDocumentPopupId)
    .ElementAttr(new Dictionary<string, object>
    {
        { "class", "popup" }
    })
    .ShowTitle(true)
    .DragEnabled(true)
    .ShowCloseButton(true)
    .ResizeEnabled(false)
    .Width("80%")
    .Height("auto")
    .TitleTemplate(@<text>
<div class="d-flex flex-row align-items-center justify-content-between">
    <div class="font-size-16px text-green text-font-weight-600 smallCaps text-green">
        <i class="fas fa-share-alt mr-2" aria-hidden="true"></i>
        <span id="shareDocumentPopupTitle"></span>
    </div>
    <button type="button" class="popup-close-btn" onclick="Transfert.Document.closeShareDocumentPopup();"
            style="cursor: pointer; font-size: 24px; background: none; border: none; padding: 0; color: inherit;">
        &times;
    </button>
</div>
</text>))

