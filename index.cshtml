@using BacaratWeb.ViewModel.Transfert
@inject IViewTranslator translator

@{
    var currentMode = ViewBag.Mode ?? "all";
    
    var language = Context.Features.Get<IRequestCultureFeature>().RequestCulture.Culture.ToString().ToCamelCase();
    
    var dateTimeFormat = language == "En" ? "MM/dd/yyyy hh:mm a" : "dd/MM/yyyy HH:mm";
}


<div class="smallCaps text-green mt-2 mb-2">
    <div id="menuSelectMode" class="align-menu-items-center"></div>
</div>

<script>
    var _transfertCurrentMode = '@currentMode';
    var _transfertCanRead = @Json.Serialize(ViewBag.CanReadTransfert);
    var _transfertCanWrite = @Json.Serialize(ViewBag.CanWriteTransfert);
    var _transfertIsAdminGlobal = @Json.Serialize(ViewBag.IsAdminGlobal);
</script>


<div id="transfertContent">
    <div id="gridAllDocumentsContainer">
        @(Html.DevExtreme().DataGrid<DocumentViewModel>()
            .ID("allDocumentsGrid")
            .Width("100%")
            .ShowBorders(true)
            .LoadPanel(loadPanel => loadPanel
                .Enabled(true)
                .ShowPane(true)
                .ShowIndicator(true)
                .Text(translator.Common["Loading"]))
            .ColumnAutoWidth(true)
            .AllowColumnResizing(true)
            .ColumnResizingMode(ColumnResizingMode.Widget)
            .AllowColumnReordering(true)
            .HoverStateEnabled(true)
            .RowAlternationEnabled(false)
            .RemoteOperations(false)
            .ColumnChooser(cc => cc
                .Enabled(true)
                .AllowSearch(true))
            .Export(e => e
                .Enabled(true)
                .AllowExportSelectedData(true))
            .SearchPanel(s => s
                .Visible(true)
                .Placeholder(translator.Common["Search"] + "...")
                .HighlightCaseSensitive(true))
            .FilterRow(filterRow => filterRow
                .Visible(true)
                .ApplyFilter(GridApplyFilterMode.Auto))
            .Paging(p => p.PageSize(10))
            .Pager(pager =>
                pager.ShowPageSizeSelector(true)
                    .ShowNavigationButtons(true)
                    .AllowedPageSizes(new List<int> { 10, 20, 50 }))
            .Columns(columns =>
            {
                columns.AddFor(m => m.Name)
                    .Caption(translator.Common["Transfert.Document.Name"]);

                columns.AddFor(m => m.Description)
                    .Caption(translator.Common["Description"])
                    .CellTemplate(@<text>
                        <div class="document-description-cell">
                            <%- data.Description %>
                        </div>
                    </text>);

                columns.AddFor(m => m.ContentType)
                    .Caption(translator.Common["Transfert.Document.FileType"]);

                columns.Add()
                    .Caption(translator.Common["Transfert.Document.FileSizeLabel"])
                    .CalculateCellValue("function(data) { return Transfert.Document.formatFileSize(data.FileSize); }");

                columns.AddFor(m => m.UploadDate)
                    .Caption(translator.Common["Transfert.Document.UploadDate"])
                    .DataType(GridColumnDataType.DateTime)
                    .Format(dateTimeFormat);

                columns.AddFor(m => m.ExpiryDate)
                    .Caption(translator.Common["Transfert.Document.ExpiryDate"])
                    .DataType(GridColumnDataType.DateTime)
                    .Format(dateTimeFormat);

                columns.AddFor(m => m.OwnerName)
                        .Caption(translator.Common["Owner"]);

                columns.Add()
                    .Caption(translator.Common["Transfert.Document.Status"])
                    .DataField($"StatutDocumentName{language}");

                columns.Add()
                    .Caption("")
                    .Width(100)
                    .Alignment(HorizontalAlignment.Center)
                    .AllowFiltering(false)
                    .AllowSorting(false)
                    .AllowHeaderFiltering(false)
                    .AllowExporting(false)
                    .CellTemplate(@<text>
                        <div class="d-flex justify-content-center align-items-center w-100">
                            <a href="javascript:void(0)"
                            title="@translator.Common["Download"]"
                            onclick="Transfert.Document.downloadDocument(<%= data.Id %>)">
                                <i class="fas fa-download color-blue2"></i>
                            </a>
                        </div>
                    </text>);
            })
            .DataSource(ds => ds.Mvc()
            .RouteName("apiRoute")
            .Area("Transfert")
            .Controller("Document")
            .LoadAction("GetAllDocuments"))
        )
    </div>

    @if ((bool)ViewBag.CanWriteTransfert)
    {
        <div id="gridMyDocumentsContainer" style="display:none;">
            <div class="mt-3 mb-5 d-flex align-items-center">
                <div id="btnAddDocument"></div>
                <div id="btnShareDocument" class="ml-3"></div>
                <div id="btnShareSettingsDocument" class="ml-3"></div>
            </div>

            @(Html.DevExtreme().DataGrid<DocumentViewModel>()
                .ID("myDocumentsGrid")
                .Width("100%")
                .ShowBorders(true)
                .LoadPanel(loadPanel => loadPanel
                    .Enabled(true)
                    .ShowPane(true)
                    .ShowIndicator(true)
                    .Text(translator.Common["Loading"]))
                .ColumnAutoWidth(true)
                .AllowColumnResizing(true)
                .ColumnResizingMode(ColumnResizingMode.Widget)
                .AllowColumnReordering(true)
                .HoverStateEnabled(true)
                .RowAlternationEnabled(false)
                .RemoteOperations(false)
                .ColumnChooser(cc => cc
                    .Enabled(true)
                    .AllowSearch(true))
                .Export(e => e
                    .Enabled(true)
                    .AllowExportSelectedData(true))
                .SearchPanel(s => s
                    .Visible(true)
                    .Placeholder(translator.Common["Search"] + "...")
                    .HighlightCaseSensitive(true))
                .FilterRow(filterRow => filterRow
                    .Visible(true)
                    .ApplyFilter(GridApplyFilterMode.Auto))
                .Paging(p => p.PageSize(10))
                .Pager(pager =>
                    pager.ShowPageSizeSelector(true)
                        .ShowNavigationButtons(true)
                        .AllowedPageSizes(new List<int> { 10, 20, 50 }))
                .Columns(columns =>
                {
                    columns.AddFor(m => m.Name)
                        .Caption(translator.Common["Transfert.Document.Name"]);

                    columns.AddFor(m => m.Description)
                        .Caption(translator.Common["Description"])
                        .CellTemplate(@<text>
                                <div class="document-description-cell">
                                    <%- data.Description %>
                                </div>
                            </text>);

                    columns.AddFor(m => m.ContentType)
                        .Caption(translator.Common["Transfert.Document.FileType"]);

                    columns.Add()
                        .Caption(translator.Common["Transfert.Document.FileSizeLabel"])
                        .CalculateCellValue("function(data) { return Transfert.Document.formatFileSize(data.FileSize); }");

                    columns.AddFor(m => m.UploadDate)
                        .Caption(translator.Common["Transfert.Document.UploadDate"])
                        .DataType(GridColumnDataType.DateTime)
                        .Format(dateTimeFormat);

                    columns.AddFor(m => m.ExpiryDate)
                        .Caption(translator.Common["Transfert.Document.ExpiryDate"])
                        .DataType(GridColumnDataType.DateTime)
                        .Format(dateTimeFormat);

                    columns.AddFor(m => m.OwnerName)
                        .Caption(translator.Common["Owner"]);

                    columns.Add()
                        .Caption(translator.Common["Transfert.Document.Status"])
                        .DataField($"StatutDocumentName{language}");

                    columns.Add()
                        .Caption("")
                        .Width(130)
                        .Alignment(HorizontalAlignment.Center)
                        .AllowFiltering(false)
                        .AllowSorting(false)
                        .AllowHeaderFiltering(false)
                        .AllowExporting(false)
                        .CellTemplate(@<text>
                            <div class="d-flex justify-content-center align-items-center w-100">
                                <a href="javascript:void(0)"
                                class="mr-3"
                                title="@translator.Common["Download"]"
                                onclick="Transfert.Document.downloadDocument(<%= data.Id %>)">
                                    <i class="fas fa-download color-blue2"></i>
                                </a>

                                <a href="javascript:void(0)"
                                title="@translator.Common["Delete"]"
                                onclick="Transfert.Document.confirmDeleteDocument(<%= data.Id %>)">
                                    <i class="fas fa-trash color-red2"></i>
                                </a>
                            </div>
                        </text>);
                    })
                    .DataSource(ds => ds.Mvc()
                        .RouteName("apiRoute")
                        .Area("Transfert")
                        .Controller("Document")
                        .LoadAction("GetMyDocuments"))
                    .Selection(s => s.Mode(SelectionMode.Single))
                    .OnSelectionChanged("Transfert.Document.onMyDocumentsSelectionChanged")
            )
        </div>
    }

