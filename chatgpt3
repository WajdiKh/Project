USE [BacaratWeb]
GO

BEGIN TRANSACTION;

BEGIN TRY

    ------------------------------------------------------------
    -- 1. Récupération des anciens Id
    ------------------------------------------------------------

    DECLARE @OldDocumentPartageId INT;
    DECLARE @OldDocumentTelechargeId INT;

    SELECT @OldDocumentPartageId = Id
    FROM [Commun].[EmailNotificationType]
    WHERE Code = 'DocumentPartage';

    SELECT @OldDocumentTelechargeId = Id
    FROM [Commun].[EmailNotificationType]
    WHERE Code = 'DocumentTelecharge';


    ------------------------------------------------------------
    -- 2. Sauvegarde des templates liés (FR + EN)
    ------------------------------------------------------------

    DECLARE @DocumentPartageTemplates TABLE (Id INT);
    DECLARE @DocumentTelechargeTemplates TABLE (Id INT);


    INSERT INTO @DocumentPartageTemplates(Id)
    SELECT Id
    FROM [Commun].[EmailNotificationTemplate]
    WHERE EmailNotificationTypeId = @OldDocumentPartageId;


    INSERT INTO @DocumentTelechargeTemplates(Id)
    SELECT Id
    FROM [Commun].[EmailNotificationTemplate]
    WHERE EmailNotificationTypeId = @OldDocumentTelechargeId;


    ------------------------------------------------------------
    -- 3. Sauvegarde des deux notifications existantes
    ------------------------------------------------------------

    DECLARE @Notifications TABLE
    (
        NewId INT,
        Code VARCHAR(100),
        Libelle NVARCHAR(500),
        Description NVARCHAR(1000),
        DateCreation DATETIMEOFFSET(7),
        DateModification DATETIMEOFFSET(7),
        ModificateurId INT,
        CreateurId INT,
        IsActive BIT
    );


    INSERT INTO @Notifications
    (
        NewId,
        Code,
        Libelle,
        Description,
        DateCreation,
        DateModification,
        ModificateurId,
        CreateurId,
        IsActive
    )
    SELECT
        CASE 
            WHEN Code = 'DocumentPartage' THEN 86
            WHEN Code = 'DocumentTelecharge' THEN 87
        END,
        Code,
        Libelle,
        Description,
        DateCreation,
        DateModification,
        ModificateurId,
        CreateurId,
        IsActive
    FROM [Commun].[EmailNotificationType]
    WHERE Code IN
    (
        'DocumentPartage',
        'DocumentTelecharge'
    );


    ------------------------------------------------------------
    -- 4. Libération des FK templates
    ------------------------------------------------------------

    UPDATE [Commun].[EmailNotificationTemplate]
    SET EmailNotificationTypeId = NULL
    WHERE EmailNotificationTypeId IN
    (
        @OldDocumentPartageId,
        @OldDocumentTelechargeId
    );


    ------------------------------------------------------------
    -- 5. Suppression des anciennes lignes mal numérotées
    ------------------------------------------------------------

    DELETE FROM [Commun].[EmailNotificationType]
    WHERE Code IN
    (
        'DocumentPartage',
        'DocumentTelecharge'
    );


    ------------------------------------------------------------
    -- 6. Réinsertion avec les Id alignés avec l'enum
    ------------------------------------------------------------

    SET IDENTITY_INSERT [Commun].[EmailNotificationType] ON;


    INSERT INTO [Commun].[EmailNotificationType]
    (
        Id,
        Code,
        Libelle,
        Description,
        DateCreation,
        DateModification,
        ModificateurId,
        CreateurId,
        IsActive
    )
    SELECT
        NewId,
        Code,
        Libelle,
        Description,
        DateCreation,
        DateModification,
        ModificateurId,
        CreateurId,
        IsActive
    FROM @Notifications;


    ------------------------------------------------------------
    -- 7. Ajout des deux notifications manquantes
    ------------------------------------------------------------

    INSERT INTO [Commun].[EmailNotificationType]
    (
        Id,
        Code,
        Libelle,
        Description,
        DateCreation,
        DateModification,
        ModificateurId,
        CreateurId,
        IsActive
    )
    VALUES
    (
        84,
        'DemandeHabilitationAdminLocal',
        'DemandeHabilitationAdminLocal',
        'DemandeHabilitationAdminLocal',
        SYSDATETIMEOFFSET(),
        NULL,
        NULL,
        NULL,
        1
    ),
    (
        85,
        'DegelTransactionGdaModified',
        'DegelTransactionGdaModified',
        'DegelTransactionGdaModified',
        SYSDATETIMEOFFSET(),
        NULL,
        NULL,
        NULL,
        1
    );


    SET IDENTITY_INSERT [Commun].[EmailNotificationType] OFF;


    ------------------------------------------------------------
    -- 8. Rétablissement des FK templates
    ------------------------------------------------------------

    UPDATE [Commun].[EmailNotificationTemplate]
    SET EmailNotificationTypeId = 86
    WHERE Id IN
    (
        SELECT Id
        FROM @DocumentPartageTemplates
    );


    UPDATE [Commun].[EmailNotificationTemplate]
    SET EmailNotificationTypeId = 87
    WHERE Id IN
    (
        SELECT Id
        FROM @DocumentTelechargeTemplates
    );


    ------------------------------------------------------------
    -- 9. Resynchronisation compteur IDENTITY
    ------------------------------------------------------------

    DBCC CHECKIDENT
    (
        '[Commun].[EmailNotificationType]',
        RESEED,
        87
    );


    COMMIT TRANSACTION;

END TRY
BEGIN CATCH

    ROLLBACK TRANSACTION;

    IF OBJECTPROPERTY(OBJECT_ID('[Commun].[EmailNotificationType]'), 'TableHasIdentity') = 1
    BEGIN
        SET IDENTITY_INSERT [Commun].[EmailNotificationType] OFF;
    END

    THROW;

END CATCH
GO


