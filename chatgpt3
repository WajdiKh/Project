USE [BacaratWeb];
GO

SET XACT_ABORT ON;
GO

DECLARE @IdentityInsertEnabled BIT = 0;

BEGIN TRY
    BEGIN TRANSACTION;

    /* ============================================================
       1. Récupération des identifiants actuels
       ============================================================ */

    DECLARE @OldDocumentPartageId INT;
    DECLARE @OldDocumentTelechargeId INT;

    SELECT @OldDocumentPartageId = [Id]
    FROM [Commun].[EmailNotificationType]
    WHERE [Code] = 'DocumentPartage';

    SELECT @OldDocumentTelechargeId = [Id]
    FROM [Commun].[EmailNotificationType]
    WHERE [Code] = 'DocumentTelecharge';

    IF @OldDocumentPartageId IS NULL
    BEGIN
        THROW 50001, 'Le type DocumentPartage est introuvable.', 1;
    END;

    IF @OldDocumentTelechargeId IS NULL
    BEGIN
        THROW 50002, 'Le type DocumentTelecharge est introuvable.', 1;
    END;

    /* Les identifiants cibles ne doivent pas être utilisés
       par d'autres types de notification. */
    IF EXISTS
    (
        SELECT 1
        FROM [Commun].[EmailNotificationType]
        WHERE [Id] IN (84, 85, 86, 87)
          AND [Code] NOT IN
          (
              'DemandeHabilitationAdminLocal',
              'DegelTransactionGdaModified',
              'DocumentPartage',
              'DocumentTelecharge'
          )
    )
    BEGIN
        THROW 50003, 'Un des identifiants 84 à 87 est déjà utilisé par un autre type de notification.', 1;
    END;

    /* ============================================================
       2. Sauvegarde des templates FR et EN concernés
       ============================================================ */

    DECLARE @DocumentPartageTemplates TABLE
    (
        [Id] INT NOT NULL PRIMARY KEY
    );

    DECLARE @DocumentTelechargeTemplates TABLE
    (
        [Id] INT NOT NULL PRIMARY KEY
    );

    INSERT INTO @DocumentPartageTemplates ([Id])
    SELECT [Id]
    FROM [Commun].[EmailNotificationTemplate]
    WHERE [EmailNotificationTypeId] = @OldDocumentPartageId;

    INSERT INTO @DocumentTelechargeTemplates ([Id])
    SELECT [Id]
    FROM [Commun].[EmailNotificationTemplate]
    WHERE [EmailNotificationTypeId] = @OldDocumentTelechargeId;

    /* ============================================================
       3. Sauvegarde des lignes DocumentPartage et DocumentTelecharge
       ============================================================ */

    DECLARE @NotificationTypesToMove TABLE
    (
        [NewId] INT NOT NULL,
        [Code] VARCHAR(100) NOT NULL,
        [Libelle] NVARCHAR(500) NULL,
        [Description] NVARCHAR(1000) NULL,
        [DateCreation] DATETIMEOFFSET(7) NOT NULL,
        [DateModification] DATETIMEOFFSET(7) NULL,
        [ModificateurId] INT NULL,
        [CreateurId] INT NULL,
        [IsActive] BIT NOT NULL
    );

    INSERT INTO @NotificationTypesToMove
    (
        [NewId],
        [Code],
        [Libelle],
        [Description],
        [DateCreation],
        [DateModification],
        [ModificateurId],
        [CreateurId],
        [IsActive]
    )
    SELECT
        CASE [Code]
            WHEN 'DocumentPartage' THEN 86
            WHEN 'DocumentTelecharge' THEN 87
        END,
        [Code],
        [Libelle],
        [Description],
        [DateCreation],
        [DateModification],
        [ModificateurId],
        [CreateurId],
        [IsActive]
    FROM [Commun].[EmailNotificationType]
    WHERE [Code] IN
    (
        'DocumentPartage',
        'DocumentTelecharge'
    );

    IF (SELECT COUNT(*) FROM @NotificationTypesToMove) <> 2
    BEGIN
        THROW 50004, 'Impossible de sauvegarder les deux types DocumentPartage et DocumentTelecharge.', 1;
    END;

    /* ============================================================
       4. Mise à NULL temporaire des clés étrangères des templates
       ============================================================ */

    UPDATE [Commun].[EmailNotificationTemplate]
    SET [EmailNotificationTypeId] = NULL
    WHERE [EmailNotificationTypeId] IN
    (
        @OldDocumentPartageId,
        @OldDocumentTelechargeId
    );

    /* ============================================================
       5. Suppression des anciennes lignes mal numérotées
       ============================================================ */

    DELETE FROM [Commun].[EmailNotificationType]
    WHERE [Code] IN
    (
        'DocumentPartage',
        'DocumentTelecharge'
    );

    /* Si le script a déjà été partiellement exécuté,
       on évite les doublons sur les deux types manquants. */
    DELETE FROM [Commun].[EmailNotificationType]
    WHERE [Code] IN
    (
        'DemandeHabilitationAdminLocal',
        'DegelTransactionGdaModified'
    );

    /* ============================================================
       6. Réinsertion avec les identifiants conformes à l'enum
       ============================================================ */

    SET IDENTITY_INSERT [Commun].[EmailNotificationType] ON;
    SET @IdentityInsertEnabled = 1;

    INSERT INTO [Commun].[EmailNotificationType]
    (
        [Id],
        [Code],
        [Libelle],
        [Description],
        [DateCreation],
        [DateModification],
        [ModificateurId],
        [CreateurId],
        [IsActive]
    )
    VALUES
    (
        84,
        'DemandeHabilitationAdminLocal',
        'DemandeHabilitationAdminLocal',
        'DemandeHabilitationAdminLocal',
        SYSDATETIMEOFFSET(),
        NULL,
        NULL,
        NULL,
        1
    ),
    (
        85,
        'DegelTransactionGdaModified',
        'DegelTransactionGdaModified',
        'DegelTransactionGdaModified',
        SYSDATETIMEOFFSET(),
        NULL,
        NULL,
        NULL,
        1
    );

    INSERT INTO [Commun].[EmailNotificationType]
    (
        [Id],
        [Code],
        [Libelle],
        [Description],
        [DateCreation],
        [DateModification],
        [ModificateurId],
        [CreateurId],
        [IsActive]
    )
    SELECT
        [NewId],
        [Code],
        [Libelle],
        [Description],
        [DateCreation],
        [DateModification],
        [ModificateurId],
        [CreateurId],
        [IsActive]
    FROM @NotificationTypesToMove;

    SET IDENTITY_INSERT [Commun].[EmailNotificationType] OFF;
    SET @IdentityInsertEnabled = 0;

    /* ============================================================
       7. Rétablissement des clés étrangères des templates FR et EN
       ============================================================ */

    UPDATE template
    SET template.[EmailNotificationTypeId] = 86
    FROM [Commun].[EmailNotificationTemplate] template
    INNER JOIN @DocumentPartageTemplates savedTemplate
        ON savedTemplate.[Id] = template.[Id];

    UPDATE template
    SET template.[EmailNotificationTypeId] = 87
    FROM [Commun].[EmailNotificationTemplate] template
    INNER JOIN @DocumentTelechargeTemplates savedTemplate
        ON savedTemplate.[Id] = template.[Id];

    /* ============================================================
       8. Vérifications avant validation
       ============================================================ */

    IF NOT EXISTS
    (
        SELECT 1
        FROM [Commun].[EmailNotificationType]
        WHERE [Id] = 84
          AND [Code] = 'DemandeHabilitationAdminLocal'
    )
    BEGIN
        THROW 50005, 'La notification DemandeHabilitationAdminLocal n''a pas été correctement créée.', 1;
    END;

    IF NOT EXISTS
    (
        SELECT 1
        FROM [Commun].[EmailNotificationType]
        WHERE [Id] = 85
          AND [Code] = 'DegelTransactionGdaModified'
    )
    BEGIN
        THROW 50006, 'La notification DegelTransactionGdaModified n''a pas été correctement créée.', 1;
    END;

    IF NOT EXISTS
    (
        SELECT 1
        FROM [Commun].[EmailNotificationType]
        WHERE [Id] = 86
          AND [Code] = 'DocumentPartage'
    )
    BEGIN
        THROW 50007, 'La notification DocumentPartage n''a pas été correctement déplacée vers l''Id 86.', 1;
    END;

    IF NOT EXISTS
    (
        SELECT 1
        FROM [Commun].[EmailNotificationType]
        WHERE [Id] = 87
          AND [Code] = 'DocumentTelecharge'
    )
    BEGIN
        THROW 50008, 'La notification DocumentTelecharge n''a pas été correctement déplacée vers l''Id 87.', 1;
    END;

    IF EXISTS
    (
        SELECT 1
        FROM [Commun].[EmailNotificationTemplate] template
        INNER JOIN @DocumentPartageTemplates savedTemplate
            ON savedTemplate.[Id] = template.[Id]
        WHERE template.[EmailNotificationTypeId] <> 86
           OR template.[EmailNotificationTypeId] IS NULL
    )
    BEGIN
        THROW 50009, 'Les templates DocumentPartage n''ont pas été correctement rattachés à l''Id 86.', 1;
    END;

    IF EXISTS
    (
        SELECT 1
        FROM [Commun].[EmailNotificationTemplate] template
        INNER JOIN @DocumentTelechargeTemplates savedTemplate
            ON savedTemplate.[Id] = template.[Id]
        WHERE template.[EmailNotificationTypeId] <> 87
           OR template.[EmailNotificationTypeId] IS NULL
    )
    BEGIN
        THROW 50010, 'Les templates DocumentTelecharge n''ont pas été correctement rattachés à l''Id 87.', 1;
    END;

    /* ============================================================
       9. Resynchronisation du compteur IDENTITY
       La prochaine insertion automatique prendra l'Id 88.
       ============================================================ */

    DBCC CHECKIDENT
    (
        '[Commun].[EmailNotificationType]',
        RESEED,
        87
    );

    COMMIT TRANSACTION;
END TRY
BEGIN CATCH
    /* Si l'erreur survient après IDENTITY_INSERT ON,
       on le désactive avant de quitter le script. */
    IF @IdentityInsertEnabled = 1
    BEGIN
        SET IDENTITY_INSERT [Commun].[EmailNotificationType] OFF;
        SET @IdentityInsertEnabled = 0;
    END;

    IF @@TRANCOUNT > 0
    BEGIN
        ROLLBACK TRANSACTION;
    END;

    THROW;
END CATCH;
GO

/* ============================================================
   Vérification finale
   ============================================================ */

SELECT
    [Id],
    [Code],
    [Libelle],
    [CreateurId],
    [ModificateurId],
    [IsActive]
FROM [Commun].[EmailNotificationType]
WHERE [Code] IN
(
    'DemandeHabilitationAdminLocal',
    'DegelTransactionGdaModified',
    'DocumentPartage',
    'DocumentTelecharge'
)
ORDER BY [Id];

SELECT
    template.[Id] AS [TemplateId],
    template.[EmailNotificationTypeId],
    notificationType.[Code],
    template.[LangueId],
    template.[Subject]
FROM [Commun].[EmailNotificationTemplate] template
INNER JOIN [Commun].[EmailNotificationType] notificationType
    ON notificationType.[Id] = template.[EmailNotificationTypeId]
WHERE notificationType.[Code] IN
(
    'DocumentPartage',
    'DocumentTelecharge'
)
ORDER BY
    notificationType.[Id],
    template.[LangueId];
GO