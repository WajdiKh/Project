-- Vérification
------------------------------------------------------------

SELECT
    Id,
    Code
FROM [Commun].[EmailNotificationType]
WHERE Code IN
(
    'DemandeHabilitationAdminLocal',
    'DegelTransactionGdaModified',
    'DocumentPartage',
    'DocumentTelecharge'
)
ORDER BY Id;


SELECT
    t.Id,
    t.EmailNotificationTypeId,
    n.Code,
    t.LangueId
FROM [Commun].[EmailNotificationTemplate] t
INNER JOIN [Commun].[EmailNotificationType] n
    ON n.Id = t.EmailNotificationTypeId
WHERE n.Code IN
(
    'DocumentPartage',
    'DocumentTelecharge'
);