USE [BacaratWeb]
GO

BEGIN TRANSACTION;

BEGIN TRY

    ------------------------------------------------------------
    -- 1. Sauvegarde des anciens Id DocumentPartage/Telecharge
    ------------------------------------------------------------

    DECLARE @OldDocumentPartageId INT;
    DECLARE @OldDocumentTelechargeId INT;

    SELECT @OldDocumentPartageId = Id
    FROM [Commun].[EmailNotificationType]
    WHERE Code = 'DocumentPartage';

    SELECT @OldDocumentTelechargeId = Id
    FROM [Commun].[EmailNotificationType]
    WHERE Code = 'DocumentTelecharge';


    ------------------------------------------------------------
    -- 2. Libérer les FK des templates
    ------------------------------------------------------------

    UPDATE [Commun].[EmailNotificationTemplate]
    SET EmailNotificationTypeId = NULL
    WHERE EmailNotificationTypeId IN
    (
        @OldDocumentPartageId,
        @OldDocumentTelechargeId
    );


    ------------------------------------------------------------
    -- 3. Insérer les deux notifications manquantes
    ------------------------------------------------------------

    SET IDENTITY_INSERT [Commun].[EmailNotificationType] ON;


    INSERT INTO [Commun].[EmailNotificationType]
    (
        Id,
        Code,
        Libelle,
        Description,
        DateCreation,
        DateModification,
        ModificateurId,
        CreateurId,
        IsActive
    )
    VALUES
    (
        84,
        'DemandeHabilitationAdminLocal',
        'DemandeHabilitationAdminLocal',
        'DemandeHabilitationAdminLocal',
        SYSDATETIMEOFFSET(),
        NULL,
        NULL,
        NULL,
        1
    ),
    (
        85,
        'DegelTransactionGdaModified',
        'DegelTransactionGdaModified',
        'DegelTransactionGdaModified',
        SYSDATETIMEOFFSET(),
        NULL,
        NULL,
        NULL,
        1
    );


    SET IDENTITY_INSERT [Commun].[EmailNotificationType] OFF;


    ------------------------------------------------------------
    -- 4. Corriger les Id DocumentPartage / DocumentTelecharge
    ------------------------------------------------------------

    UPDATE [Commun].[EmailNotificationType]
    SET Id = 86
    WHERE Code = 'DocumentPartage';


    UPDATE [Commun].[EmailNotificationType]
    SET Id = 87
    WHERE Code = 'DocumentTelecharge';


    ------------------------------------------------------------
    -- 5. Remettre les bonnes FK dans les templates
    ------------------------------------------------------------

    UPDATE [Commun].[EmailNotificationTemplate]
    SET EmailNotificationTypeId = 86
    WHERE EmailNotificationTypeId IS NULL
      AND @OldDocumentPartageId IS NOT NULL
      AND EXISTS
      (
          SELECT 1
          FROM [Commun].[EmailNotificationType]
          WHERE Id = 86
            AND Code = 'DocumentPartage'
      )
      AND Subject LIKE '%partag%';


    UPDATE [Commun].[EmailNotificationTemplate]
    SET EmailNotificationTypeId = 87
    WHERE EmailNotificationTypeId IS NULL
      AND @OldDocumentTelechargeId IS NOT NULL
      AND EXISTS
      (
          SELECT 1
          FROM [Commun].[EmailNotificationType]
          WHERE Id = 87
            AND Code = 'DocumentTelecharge'
      )
      AND Subject LIKE '%télécharg%';


    ------------------------------------------------------------
    -- 6. Resynchroniser identity
    ------------------------------------------------------------

    DBCC CHECKIDENT
    (
        '[Commun].[EmailNotificationType]',
        RESEED,
        87
    );


    COMMIT TRANSACTION;

END TRY
BEGIN CATCH

    ROLLBACK TRANSACTION;
    THROW;

END CATCH
GO