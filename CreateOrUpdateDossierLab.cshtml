@using BacaratWeb.Areas.Lab.Services.Interfaces;
@using Microsoft.AspNetCore.Html;
@using Newtonsoft.Json;

@inject IReferentielViewModel _referentiel
@inject IViewTranslator translator
@inject ILabAttachmentService _attachmentService;

@model DossierLabViewModel


@if (Model.Error)
{
    <div class="alert alert-danger" role="alert">
        @Model.ErrorMessage
    </div>
    return;
}
@{
    var _isReadOnly = Model.EVisibleDossier != EVisibleDossier.Editable;
    var _lang = Model.Lang.ToCamelCase();
    var isNew = Model.IsNew;
    var isTracfin = Model.Direction?.IsTracfin ?? Model.IsTracfin;
    var viewParameters = new Dictionary<string, bool>
    {
        { "IsDeclarationTracfin", Model.DeclarationTracfins.Any() },
        { "IsReadOnly", _isReadOnly },
        { "HasRightLabFraude", Model.HasRightLabFraude },
        { "IsCreatorDossierLab", Model.IsCreatorDossierLab },
        { "IsDuplicatedFolder", Model.IsDuplicated },
        { "IsCreatedFromFraude", Model.IsCreatedFromFraude },
        { "IsNew", isNew },
        {
            "IsClotureTracfin", Model.DeclarationTracfins.Any() && isTracfin &&
                                Model.DeclarationTracfins.All(x => !string.IsNullOrEmpty(x.NumeroAccuseReception)) &&
                                Model.DeclarationTracfins.All(x => x.DateDeclaration != null) && Model.DeclarationTracfins.All(x => x.EstNouvelleDeclarationTracfin)
        },
        { "IsDetailsView", Model.IsDetailView },
        { "IsTracfin", isTracfin }
    };

    var categorieGroupeLabs = _referentiel.CategorieGroupeLabs;
    var origineGroupeLabs = _referentiel.OrigineGroupeLabs;
    var avisLabs = _referentiel.AvisLabs;
    var visaLabs = _referentiel.VisaLabs;
    var currentUser = Model.UserPrivilege.GetUserId();
    var requiredAsteriskSuffix = Constants.AsteriskIdSuffix;
}

<script>
    $(document).ready(function () {
    @Html.SetJavaScriptVariable("directionId", Model.DirectionId, Json);
    dateDebutFinAnalyseDeclarationTracfinRequired(0);
    });
    var bRefreshDataGridAttachments = true;
</script>
@if (Model != null)
{
    <form id="dossierLabForm" class="container-fluid-form" method="post" enctype="multipart/form-data">

    @await Html.PartialAsync("_PartialLeftNavLab", viewParameters)
    @await Html.PartialAsync("_PartialRightCommandsLab", viewParameters)
    @Html.AntiForgeryToken()
    @Html.HiddenFor(x => x.CryptedId)
    @Html.HiddenFor(x => x.CodeUnique)
    @Html.HiddenFor(x => x.CryptedUtilisateurId)
    @Html.HiddenFor(x => x.CryptedCreateurId)
    @Html.HiddenFor(x => x.IsNew)
    @Html.HiddenFor(x => x.DuplicateDossierId)

    @Html.Hidden("BlocSubmit", "false")
    @Html.Hidden("IsReadOnly", _isReadOnly.ToString().ToLower())
    <div id="content-wrapper">
    <div asp-validation-summary="ModelOnly"></div>
    <div class="card shadow mb-4 bloc" id="bloc1">
        <div class="card-header card-header-bloc">
            <h6 class="m-0 text-green text-font-weight-600">
                <i class="fas fa-warehouse mr-2"></i>@translator.Common["CaseIdentification"]
            </h6>
        </div>

        <div class="card-body pb-3">

            <div class="row">
                @if (!string.IsNullOrEmpty(Model.CodeUnique))
                {
                    <div class="col-2 pr-1">
                        <div class="smallCaps text-green">
                            @translator.Common["NumberDossier"]
                        </div>
                        <div class="pt-1" style="color: #db1e27; font-weight:bold;">@Model.CodeUnique.ToUpper(CultureInfo.CurrentCulture)</div>
                    </div>
                }


                <div class="pr-1 @(!string.IsNullOrEmpty(Model.CodeUnique) ? "col-2 pl-0" : "col-3")">
                    <span class="smallCaps text-green">
                        @translator.Common["Direction"] <span style="color: red">*</span>
                    </span>
                    @(
                    Html.DevExtreme().SelectBoxFor(x => x.DirectionId)
                        .ID("DirectionId")
                        .Height(30)
                        .Name("DirectionId")
                        .DataSourceOptions(c => c.Sort("Nom"))
                        .DisplayExpr("Nom")
                        .ValueExpr("Id")
                        .Width("100%")
                        .DataSource(Model.DirectionItemDatasources)
                        .SearchEnabled(true)
                        .OnValueChanged(@<text>
                                             function ()
                                             {
                                                directionOnValueChangedCreateUpdateDossierLab('@Model.CryptedId','@_isReadOnly.ToString().ToLower()');
                                                categorieGroupeLab_OnValueChanged(@(Model.DeclarationTracfins.Any().ToString().ToLower()));
                                                refreshPiecesIdentiteAccess();
                                             }
                                         </text>)
                        .SearchEnabled(true)
                        .ShowClearButton(true)
                        .ElementAttr("class", "mandatory")
                        .ReadOnly(_isReadOnly || !Model.IsNew))
                    <input type="hidden" id="createOrUpdateDossierLab_CodeProfession"/>
                </div>
                <div class="pl-0 pr-1 @(!string.IsNullOrEmpty(Model.CodeUnique) ? "col-2" : "col-3")">
                    <span class="smallCaps text-green">
                        @translator.Common["EntiteAgence"] <span style="color: red">*</span>
                    </span>
                    <div id="loader-entite-container" class="dx-hidden text-center"></div>
                    @Html.DevExtreme().SelectBoxFor(x => x.EntiteId).ID("EntiteId").Height(30).Name("EntiteId").DataSourceOptions(c => c.Sort($"Name{_lang}")).DisplayExpr($"Name{_lang}").ValueExpr("Id").Width("100%").SearchEnabled(true).ShowClearButton(true).ReadOnly(_isReadOnly).DataSource(Model.EntitesItemDatasources).ElementAttr("class", "mandatory")
                </div>
                <div class="col-2 pl-0 pr-1">
                    <div>
                        <span class="smallCaps text-green">
                            @translator.Common["DateReception"]
                            <span id="targetDateReception" class="pl-1 align-self-center smallCaps text-truncate button-green" style="width:21%">
                                QLB
                            </span>
                            <span class="RequiredField">*</span>
                        </span>
                    </div>
                    @Html.DevExtreme().DateBoxFor(x => x.DateReception).ID("DateReception").Height(30).Name("DateReception").OnValueChanged("dateReception_OnValueChanged").Max(Model.DateCreation ?? DateTime.Now.AddYears(1)).Min(new DateTime(1990, 1, 1)).DisplayFormat(DateHelper.DateFormat()).UseMaskBehavior(true).Width("100%").ReadOnly(_isReadOnly).ElementAttr("class", "mandatory")
                    @(Html.DevExtreme().Tooltip().Width(500)
                        .ID("ToolTipDateReception")
                        .Target("#targetDateReception")
                        .ShowEvent("mouseenter")
                        .HideEvent("mouseleave")
                        .CloseOnOutsideClick(false)
                        .Position(Position.Bottom)
                        .ContentTemplate(@<text>
                                              <div class='smallCaps text-green toolTipSearch text-justify' style="max-width: 500px;">
                                                  @Html.Raw(translator.TemplateTraduction["ToolTipDateReception"])
                                              </div>
                                          </text>))
                </div>
                <div class="col-2 pl-0 pr-1">
                    <div>
                        <span class="smallCaps text-green">@translator.Common["DateSaisie"]</span>
                    </div>
                    @Html.DevExtreme().DateBoxFor(x => x.DateCreation).ID("DateCreation").Height(30).Name("DateCreation").DisplayFormat(DateHelper.DateTimeFormat()).Type(DateBoxType.DateTime).UseMaskBehavior(true).Width("100%").ShowClearButton(true).ReadOnly(true)
                </div>

                <div class="col-2 pl-0">
                    <div class="smallCaps text-green">
                        @translator.Common["Createur"]
                    </div>
                    @Html.DevExtreme().TextBox().Value(Model.Createur_FullName).Height(30).ReadOnly(true)
                </div>
            </div>
            <div class="row mt-2">

                @if (Model.DuplicateDossierCode != null)
                {
                    <div class="col-xl-2 pr-0 pl-2">
                        <div class="smallCaps text-green">
                            @translator.Common["NumberDossierOrigine"]
                        </div>
                        <div class="pt-1" style="color: #db1e27; font-weight: bold;">
                            @Html.DevExtreme().TextBoxFor(x => x.DuplicateDossierCode).Height(30).ReadOnly(true).Width("100%").Name("DuplicateDossierCode").ID("DuplicateDossierCode")
                        </div>
                    </div>
                }

                <div class="col-2 pr-1">
                    <div id="IsDeclarationSoupconDiv" class="@(Model.IsDeclarationSoupcon ? string.Empty : " dx-hidden")">
                        <div class="text-truncate">
                            <span class="smallCaps text-green"> @translator.Common["DeclarationSoupcon"]</span>
                        </div>
                        <div class="adjust-padding-top-check-box">
                            @(Html.DevExtreme()
                                .CheckBoxFor(x => x.IsDeclarationSoupcon)
                                .ID("IsDeclarationSoupcon")
                                .Height(30)
                                .Name("IsDeclarationSoupcon")
                                .ReadOnly(true)
                                .OnValueChanged(
                                    @<text>
                                        function()
                                        {
                                            refreshPiecesIdentiteButtonsVisibility();
                                        }
                                    </text>
                                ))
                        </div>
                    </div>
                </div>

                <div id="dateDeclarationId" class="col-2 pl-0 pr-1 @(Model.ShowDateDeclaration ? string.Empty : "dx-hidden")">
                    <span class="smallCaps text-green">
                        @translator.Common["Datedeladeclaration"]
                    </span>

                    @for (var i = 0; i < Model.DeclarationTracfins?.Count; i++)
                    {
                        @(Html.DevExtreme().DateBoxFor(x => x.DeclarationTracfins[i].DateDeclarationNewDS).ID("DateDeclaration")
                            .Name("DeclarationTracfins[0].DateDeclarationNewDS")
                            .Max(DateTime.Now)
                            .Min(new DateTime(1990, 1, 1))
                            .DisplayFormat(DateHelper.DateFormat())
                            .UseMaskBehavior(true)
                            .Width("100%").Height(30)
                            .ReadOnly(true)
                            .Width("100%"))
                    }

                </div>


                @if (!string.IsNullOrEmpty(Model.DossierFraudeCryptedId) && (Model.IsAdminGlobal || (Model.IsCreatorDossierLab && Model.HasRightLabFraude) ||
                                                                             (Model.HasRightLabFraude && Model.IsNew)))
                {
                    <div class="col-2 pl-0 pr-1">
                        <div class="smallCaps text-green"> @translator.Common["NumDossierFraude"]</div>
                        @(Html.DevExtreme().Button().Width("100%")
                            .ID("btnFraudeDossier")
                            .Text(Model.DossierFraudeCodeUnique)
                            .Type(ButtonType.Normal)
                            .Width("100%")
                            .Height(30)
                            .ElementAttr("class", "mb-2 color-blue")
                            .OnClick(@<text>
                                          function (){
                                          GetDossierFraude(@Model.StatutDossierFraudeId, '@Model.IsEditDossierlab');
                                          }
                                      </text>))

                        <script>_dossierFraudeCryptedId = '@Model.DossierFraudeCryptedId';</script>

                        @Html.HiddenFor(x => x.DossierFraudeId)
                        @Html.HiddenFor(x => x.DossierFraudeCryptedId)

                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.CodeUniqueDossierFraudeSource) && (Model.IsAdminGlobal || (Model.IsCreatorDossierLab && Model.HasRightLabFraude) ||
                                                                                    (Model.HasRightLabFraude && Model.IsNew)))
                {
                    <div class="col-2 pl-0 pr-1">
                        <div class="smallCaps text-green">@translator.Common["NumDossierFraude"]</div>
                        <div class="pt-0" style="color: #db1e27; font-weight: bold;">
                            @(Html.DevExtreme().Button()
                                .ID("btnFraudeDossierSource")
                                .Text(Model.CodeUniqueDossierFraudeSource)
                                .Type(ButtonType.Normal)
                                .Width("100%")
                                .Height(31)
                                .ElementAttr("class", "mb-2 color-blue")
                                .OnClick(@<text>
                                              function (){
                                              GetDossierFraudeSource(@Model.StatutDossierFraudeId);
                                              }
                                          </text>))
                        </div>
                        <script>_dossierFraudeCryptedId = '@Model.DossierFraudeIdSourceCrypted';</script>
                    </div>
                }
                <div class="col-2 pl-0 pr-1">
                    @if (!string.IsNullOrEmpty(Model.Modificateur_FullName))
                    {
                        <div class="text-truncate">
                            <span class="smallCaps text-green">@translator.Common["Modificateur"]</span>
                        </div>
                        @Html.DevExtreme().TextBoxFor(x => x.Modificateur_FullName).Height(30).ReadOnly(true).Width("100%")
                    }
                </div>

                <div class="col-2 pl-0 pr-1">
                    @if (Model.DateModification != null)
                    {
                        <div class="text-truncate">
                            <span class="smallCaps text-green">@translator.Common["DateModification"]</span>
                        </div>
                        @Html.DevExtreme().DateBoxFor(x => x.DateModification).ID("DateModification").Height(30).Name("DateModification").DisplayFormat(DateHelper.DateFormat()).UseMaskBehavior(true).Width("100%").ShowClearButton(true).ReadOnly(true)
                    }

                </div>

                <div class="col-2 pl-0 pr-1">
                    @if (Model.DateCloture != null)
                    {
                        <div class="text-truncate">
                            <span class="smallCaps text-green">@translator.Common["EndDate"]</span>
                        </div>
                        @Html.DevExtreme().DateBoxFor(x => x.DateCloture).ID("DateCloture").Height(30).Name("DateCloture").DisplayFormat(DateHelper.DateFormat()).UseMaskBehavior(true).Width("100%").ShowClearButton(true).ReadOnly(true)
                    }
                </div>
                <div class="col-2 pl-0 pr-1">
                    <div class="col pl-0 @(Model.UserPrivilege.IsConfidential ? string.Empty : " dx-hidden")" id="div-confidentiel">
                        <div class="text-truncate">
                            <span class="smallCaps text-green">@translator.Common["Confidentiel"] </span>
                        </div>
                        <div class="adjust-padding-top-check-box pl-1">
                            @Html.DevExtreme().CheckBoxFor(x => x.Confidentiel).ID("Confidentiel").Height(30).Name("Confidentiel").ReadOnly(_isReadOnly)
                        </div>
                    </div>
                </div>

                <div class="col-2 pl-0 pr-1">
                </div>
            </div>
        </div>
    </div>


    <div class="card shadow mb-4 bloc" id="bloc3">
    <div class="card-header card-header-bloc">
        <h6 class="m-0 text-green text-font-weight-600">
            <i class="fas fa-list-alt mr-2"></i>@translator.Common["CaracteristiquesOperation"]
        </h6>
    </div>

    <div class="card-body">

    <div class="row pt-1 pb-1">
        <div class="col-sm-12 col-md-7 col-lg-7 col-xl-7 mr-0">

            <div class="row pt-1 pb-1">
                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">
                        @translator.Common["CategorieGroupeLab"] <span class="RequiredField">*</span>
                    </span>
                </div>

                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-10">
                    <div class="dx-hidden text-center loader-categorie"></div>
                    @(Html.DevExtreme().SelectBoxFor(x => x.CategorieGroupeLabId)
                        .DataSource(categorieGroupeLabs)
                        .DataSourceOptions(c => c.Sort($"Name{_lang}"))
                        .ID("CategorieGroupeLabId").Height(30)
                        .Name("CategorieGroupeLabId")
                        .DisplayExpr($"Name{_lang}")
                        .ValueExpr("Id")
                        .SearchEnabled(true).ShowClearButton(true).ElementAttr("class", "mandatory")
                        .OnValueChanged(@<text>
                                             function(e){
                                             categorieGroupeLab_OnValueChanged(@(Model.DeclarationTracfins.Any().ToString().ToLower()));
                                             }
                                         </text>).ReadOnly(_isReadOnly))
                </div>
            </div>

            <div class="row pt-1 pb-1">
                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">
                        @translator.Common["Lab.Categorie"] <span class="RequiredField">*</span>
                    </span>
                </div>

                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-10">
                    <div class="dx-hidden text-center loader-categorie"></div>
                    @(Html.DevExtreme().SelectBoxFor(x => x.CategorieId)
                        .ID("CategorieId")
                        .Height(30)
                        .Name("CategorieId")
                        .DataSourceOptions(c => c.Sort($"Name{_lang}"))
                        .DisplayExpr($"Name{_lang}").ValueExpr("Id")
                        .SearchEnabled(true)
                        .ShowClearButton(true)
                        .OnFocusOut(@<text> function (){validatePaysByCategory('PaysId')}</text>)
                        .ElementAttr("class", "input-categorie mandatory")
                        .OnValueChanged("loadStatutDossierLab")
                        .ReadOnly(_isReadOnly))
                </div>
            </div>

            <div class="row pt-1 pb-1">
                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">
                        @translator.Common["OrigineGroupeLab"] <span class="RequiredField">*</span>
                    </span>
                </div>

                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-10">
                    <div class="dx-hidden text-center loader-origineLab"></div>
                    @(Html.DevExtreme().SelectBoxFor(x => x.OrigineGroupeLabId)
                        .DataSource(origineGroupeLabs)
                        .DataSourceOptions(c => c.Sort($"Name{_lang}"))
                        .ID("OrigineGroupeLabId").Height(30)
                        .Name("OrigineGroupeLabId")
                        .DisplayExpr($"Name{_lang}")
                        .ValueExpr("Id")
                        .SearchEnabled(true).ShowClearButton(true).ElementAttr("class", "mandatory").ReadOnly(_isReadOnly))
                </div>
            </div>

            <div class="row pt-1 pb-1">
                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">
                        @translator.Common["Origine"] <span class="RequiredField">*</span>
                    </span>
                </div>
                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-10">
                    <div class="dx-hidden text-center loader-origineLab"></div>
                    @(Html.DevExtreme().SelectBoxFor(x => x.OrigineLabId)
                        .ID("OrigineLabId")
                        .Height(30).Name("OrigineLabId")
                        .DataSourceOptions(c => c.Sort($"Name{_lang}"))
                        .DisplayExpr($"Name{_lang}")
                        .ValueExpr("Id")
                        .SearchEnabled(true)
                        .ShowClearButton(true)
                        .ElementAttr("class", "input-origineLab mandatory")
                        .OnInitialized(@<text>
                                            function ()
                                            {
                                            origine_lab_OnInitialized('@Model.CryptedId');
                                            }

                                        </text>)
                        .OnValueChanged("origine_lab_OnValueChanged").ReadOnly(_isReadOnly))
                </div>
            </div>

            <div class="row pt-1 pb-1">
                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">@translator.Common["SecteurEconomique"]</span>

                </div>
                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-10">
                    @Html.DevExtreme().SelectBoxFor(x => x.SecteurEconomiqueId).DataSourceOptions(c => c.Sort($"Name{_lang}")).ID("SecteurEconomiqueId").Height(30).Name("SecteurEconomiqueId").DisplayExpr($"Name{_lang}").ValueExpr("Id").SearchEnabled(true).ShowClearButton(true).ReadOnly(_isReadOnly)
                </div>
            </div>


            <div class="row pt-1 pb-1">
                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">
                        @translator.Common["Pays"]<span class="RequiredField" id="PaysId@(requiredAsteriskSuffix)"></span>
                    </span>

                </div>
                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-10">
                    @(Html.DevExtreme().SelectBoxFor(x => x.PaysId).ID("PaysId")
                        .Height(30)
                        .Name("PaysId")
                        .DataSource(_referentiel.Pays)
                        .DataSourceOptions(c => c.Sort($"Name{_lang}"))
                        .DisplayExpr($"Name{_lang}")
                        .ValueExpr("Id")
                        .SearchEnabled(true)
                        .ShowClearButton(true)
                        .ElementAttr(new
                        {
                            data_error_required = translator.Common["PaysObligatoire"]
                        })
                        .ReadOnly(_isReadOnly))
                </div>
            </div>

            <div class="row pt-1 pb-1">
                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">@translator.Common["Dgt"]</span>

                </div>
                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-1 mt-1">
                    @Html.DevExtreme().CheckBoxFor(x => x.IsDgt).ID("IsDgt").Height(30).Name("IsDgt").OnValueChanged("showDateDerniereDeclarationDgt").ReadOnly(_isReadOnly)
                </div>
                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">@translator.Common["AutorisationDGT"]</span>

                </div>
                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-1 mt-1">
                    @Html.DevExtreme().CheckBoxFor(x => x.IsAutorisationDGT).ID("IsAutorisationDGT").Height(30).Name("IsAutorisationDGT").ReadOnly(_isReadOnly)
                </div>
                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">@translator.Common["202COV"]</span>

                </div>
                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-1 mt-1">
                    @Html.DevExtreme().CheckBoxFor(x => x.IsCov).ID("IsCov").Height(30).Name("IsCov").ReadOnly(_isReadOnly)
                </div>

                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">@translator.Common["DossierSuivi"]</span>

                </div>
                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-1 mt-1">
                    @Html.DevExtreme().CheckBoxFor(x => x.IsSuivi).ID("IsSuivi").Height(30).Name("IsSuivi").ReadOnly(_isReadOnly)
                </div>
            </div>
            <div class="row pt-1 pb-1">
                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">@translator.Common["DossiersFluxMultiples"]</span>

                </div>
                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-1 mt-1">
                    @Html.DevExtreme().CheckBoxFor(x => x.DossiersFluxMultiples).ID("DossiersFluxMultiples").Height(30).Name("DossiersFluxMultiples").ReadOnly(_isReadOnly)
                </div>

                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">@translator.Common["SurveillanceDaech"]</span>

                </div>
                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-1 mt-1">
                    @Html.DevExtreme().CheckBoxFor(x => x.SurveillanceDaech).ID("SurveillanceDaech").Height(30).Name("SurveillanceDaech").ReadOnly(_isReadOnly)
                </div>
                <div class="col-sm-12 col-md-2 col-lg-2 col-xl-2 align-self-center">
                    <span class="smallCaps text-green">@translator.Common["DerogationPolitiqueGroupe"]</span>
                </div>
                <div class="col-sm-12 col-md-10 col-lg-10 col-xl-1 mt-1">
                    @Html.DevExtreme().CheckBoxFor(x => x.DerogationPolitiqueGroupe).ID("DerogationPolitiqueGroupe").Height(30).Name("DerogationPolitiqueGroupe").ReadOnly(_isReadOnly)
                </div>
            </div>
        </div>

        <div class="col-sm-12 col-md-5 col-lg-5 col-xl-5">
            <div class="card @(Model.DossierLabOperations?.Count > 0 ? string.Empty : "dx-hidden")" id="dossier-lab-operation-container" style="min-height:235px">
                <div id="loader-dossier-lab-operation-container" class="dx-hidden text-center ml-auto mr-auto" style="position: relative;top: 113px;"></div>
                <div class="card-body" id="dossier-lab-operation-container-body">
                    <h5 class="card-title smallCaps text-green">@translator.Common["OperationsLab"]</h5>
                    <div id="dossier-lab-operation-items-container">
                        @for (var i = 0; i < Model.DossierLabOperations?.Count; i++)
                        {
                            var dossierLabOperation = Model.DossierLabOperations.ElementAt(i);
                            dossierLabOperation.IsReadOnly = _isReadOnly;
                            dossierLabOperation.Culture = _lang;
                            @await Html.PartialAsync("_PartialDossierLabOperation", new Tuple<DossierLabOperationViewModel, int>(dossierLabOperation, i))
