@functions {

    private HtmlString DeclareNombreInitialTiers(string variableName, DossierLabViewModel model)
    {
        if (model == null)
        {
            return new HtmlString($"var {variableName} = undefined;");
        }

        var value = (model.DossierLabPersonnePhysiques?.Count ?? 0) +
                    (model.DossierLabPersonneMorales?.Count ?? 0) +
                    (model.DossierLabNonConnus?.Count ?? 0);
        return new HtmlString($"var {variableName} = {Html.Raw(Json.Serialize(value))};");
    }

}

