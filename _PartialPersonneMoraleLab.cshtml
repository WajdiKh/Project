<div class="tab-content" id="nav-tabContent-pm">
<div class="tab-pane fade show active" id="nav-identification-pm@(Model.Item2)" role="tabpanel" aria-labelledby="nav-identification-pm-tab@(Model.Item2)">
<div class="col-12 mb-3">
    <div class="card bloc-card-personne">
        <div class="card-body p-2">
            <h6 class="card-title">@translator.Common["BasicInformations"]</h6>
            <div class="row text-normal">
                <div class="col-sm-6 col-md-4 col-lg-2 col-xl-3 pr-1">
                    <div class="text-truncate">
                        <span class="smallCaps text-green">@translator.Common["IdentifiantClient"]</span>
                    </div>
                    @(Html.DevExtreme().TextBoxFor(x => x.Item1.PersonneMoraleLab.IdentifiantClient)
                        .Height(30).Name($"DossierLabPersonneMorales[{Model.Item2}].PersonneMoraleLab.IdentifiantClient")
                        .ID("PersonneMoraleLabIdentifiantClient" + Model.Item2)
                        .ShowClearButton(true).ReadOnly(_isReadOnly))
                </div>


                <div class="col-sm-6 col-md-4 col-lg-2 col-xl-3 pl-1 pr-md-1 pr-lg-1 pr-xl-1">
                    <div class="text-truncate">
                        <span class="smallCaps text-green">
                            @translator.Common["IdentificationProfessionel"]
                            <span class="RequiredField" id="PersonneMoraleLabProfessionalIdentificationId@(requiredAsteriskSuffix)">*</span>
                        </span>
                    </div>
                    <div class="dx-hidden text-center loader-customer-type-individual"></div>
                    @(Html.DevExtreme()
                        .SelectBoxFor(x => x.Item1.PersonneMoraleLab.ProfessionalIdentificationId)
                        .DataSourceOptions(c => c.Sort("Id"))
                        .DisplayExpr($"Name{_lang}")
                        .ValueExpr("Id")
                        .Height(30).Name($"DossierLabPersonneMorales[{Model.Item2}].PersonneMoraleLab.ProfessionalIdentificationId")
                        .ID("PersonneMoraleLabProfessionalIdentificationId" + Model.Item2)
                        .DataSource(_referentiel.IdentificationProfessionnelles).SearchEnabled(true).ShowClearButton(true)
                        .ElementAttr(new
                        {
                            data_error_required = translator.Common["IdentificationProObligatoire"]
                        })
                        .ReadOnly(_isReadOnly)
                        .OnValueChanged(@<text>
                                             function(e)
                                             {
                                             ProfessionalIdentificationId_OnValueChanged(e.element.attr('id'));
                                             }
                                         </text>))

                </div>

                <div class="col-sm-6 col-md-4 col-lg-2 col-xl-2 pl-1 pr-md-1 pr-lg-1 pr-xl-1 @(Model.Item1.PersonneMoraleLab.ProfessionalIdentificationId is 7 or 8 ? "" : "dx-hidden")" id="PersonneMoraleLabOtherRaisonIdProDiv@(Model.Item2)">
                    <div class="text-truncate">
                        <span class="smallCaps text-green">
                            @translator.Common["OtherRaisonIdPro"]
                            <span class="RequiredField" id="OtherRaisonIdPro@(requiredAsteriskSuffix)">*</span>
                        </span>
                    </div>
                    <div class="dx-hidden text-center loader-customer-type-individual"></div>
                    @(Html.DevExtreme()
                        .TextBoxFor(x => x.Item1.PersonneMoraleLab.OtherRaisonIdPro)
                        .Height(30)
                        .Name($"DossierLabPersonneMorales[{Model.Item2}].PersonneMoraleLab.OtherRaisonIdPro")
                        .ID("OtherRaisonIdPro" + Model.Item2)
                        .ShowClearButton(true)
                        .ReadOnly(_isReadOnly)
                        .ElementAttr(new
                        {
                            data_error_required = translator.Common["OtherRaisonIdProRequired"]
                        }))
                </div>

                <div class="col-sm-6 col-md-4 col-lg-2 col-xl-2 pl-lg-1 pr-xl-1 @(Model.Item1.PersonneMoraleLab.ProfessionalIdentificationId == 9 ? "dx-hidden" : "")" id="PersonneMoraleLabRaisonSocialeDiv@(Model.Item2)">
