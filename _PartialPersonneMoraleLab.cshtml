                    <div class="text-truncate">
                        <span class="smallCaps text-green">
                            @translator.Common["NumeroImmatriculation"]
                            <span class="RequiredField" id="PersonneMoraleLabNumeroImmatriculation@(requiredAsteriskSuffix)">*</span>
                        </span>
                    </div>
                    @(Html.DevExtreme()
