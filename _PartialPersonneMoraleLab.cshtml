                    {
                        @(Html.DevExtreme().TextBoxFor(x => x.Item1.PersonneMoraleLab.RaisonSociale).Height(30).Name($"DossierLabPersonneMorales[{Model.Item2}].PersonneMoraleLab.RaisonSociale").ID("PersonneMoraleLabRaisonSociale" + Model.Item2).ShowClearButton(true)
