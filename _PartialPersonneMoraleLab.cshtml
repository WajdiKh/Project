                        .Height(30)
                        .Name($"DossierLabPersonneMorales[{Model.Item2}].PersonneMoraleLab.NumeroImmatriculation")
                        .ID("PersonneMoraleLabNumeroImmatriculation" + Model.Item2)
                        .ShowClearButton(true)
                        .ReadOnly(_isReadOnly)
                        .OnValueChanged(@<text>
                                             function () {
                                             updateHeaderIdentityMoralPerson(@(Model.Item2));
                                             }
                                         </text>
                        )
                        .ElementAttr(new { data_error_required = translator.Common["NumeroImmatriculationRequired"] })
                    )
                </div>
                <div id="PersonneMoraleLabPaysDeRegistreDiv@(Model.Item2)" class="col-sm-6 col-md-4 col-lg-2 col-xl-2 pl-3" style="@(Model.Item1.PersonneMoraleLab.ProfessionalIdentificationId != idEtranger ? "display:none;" : "display:block;")">
                    <div class="text-truncate">
                        <span class="smallCaps text-green">@translator.Common["PaysDeRegistre"]</span>
                    </div>
                    @(Html.DevExtreme().SelectBoxFor(x => x.Item1.PersonneMoraleLab.PaysDeRegistreId)
                        .ID("partialPersonneMoraleLab_PaysDeRegistreId" + Model.Item2)
                        .Height(30)
                        .Name($"DossierLabPersonneMorales[{Model.Item2}].PersonneMoraleLab.PaysDeRegistreId")
                        .DataSource(_referentiel.Pays)
                        .DataSourceOptions(c => c.Sort($"Name{_lang}"))
                        .DisplayExpr($"Name{_lang}")
                        .ValueExpr("Id")
                        .SearchEnabled(true)
                        .ShowClearButton(true)
                        .ElementAttr(new { data_error_required = translator.Common["PaysRequired"] })
                        .ReadOnly(_isReadOnly))
                </div>
            </div>

            <div class="row text-normal">

                <div class="col-sm-6 col-md-4 col-lg-2 col-xl-3 pr-1">
                    <div class="text-truncate">
                        <span class="smallCaps text-green">
                            @translator.Common["TypeImplication"] <span class="RequiredField" id="PersonneMoraleLabTypeImplicationId@(requiredAsteriskSuffix)">*</span>
                        </span>
                    </div>
                    <div class="dx-hidden text-center loader-customer-type-individual"></div>
                    @(Html.DevExtreme().SelectBoxFor(x => x.Item1.PersonneMoraleLab.TypeImplicationId)
                        .DataSourceOptions(c => c.Sort($"Name{_lang}"))
                        .DisplayExpr($"Name{_lang}").ValueExpr("Id")
                        .Height(30).Name($"DossierLabPersonneMorales[{Model.Item2}].PersonneMoraleLab.TypeImplicationId")
                        .ID("PersonneMoraleLabTypeImplicationId" + Model.Item2)
                        .DataSource(typesImplication)
                        .OnValueChanged(@<text>
                                             function() {
                                             desactivateNotorieteDefavorableIfVictimePresumeSelectedPM(@(Model.Item2));
                                             }
                                         </text>)
                        .SearchEnabled(true)
                        .ShowClearButton(true).ElementAttr(new
                        {
                            data_error_required = translator.Common["TypeImplicationObligatoire"]
                        })
                        .ReadOnly(_isReadOnly))

                </div>

                <div class="col-sm-6 col-md-4 col-lg-2 col-xl-2 pl-1 pr-md-1 pr-lg-1 pr-xl-1">
                    <div class="text-truncate">
                        <span class="smallCaps text-green">@translator.Common["TypeClient"]</span>
