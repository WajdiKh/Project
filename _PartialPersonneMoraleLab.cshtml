@inject IViewTranslator translator
@inject IRoleAccessUser _roleAccess

@model Tuple<DossierLabPersonneMoraleViewModel, int>;
@inject IReferentielViewModel _referentiel;

@{
    var _isReadOnly = Model.Item1.IsReadOnly;
    var _lang = Context.Features.Get<IRequestCultureFeature>().RequestCulture.Culture.ToString().ToCamelCase();
    var typesImplication = _referentiel.TypesImplicationLabs;
    var typesClient = Model.Item1.DirectionId is > 0 ? _referentiel.GetTypeClientLabs(Model.Item1.DirectionId.Value).Where(x => x.IsCorporate != false) : null;
    var hasNumeroImmatriculation = Model.Item1.PersonneMoraleLab.NumeroImmatriculation != null && Model.Item1.PersonneMoraleLab.NumeroImmatriculation.Trim() != string.Empty;
    var canalEntreeRelationSources = _referentiel.CanalsEntreeEnRelation.Where(x => x.ActiviteId == 1);
    var hasTypeRelationAffaire = Model.Item1.PersonneMoraleLab.TypeRelationAffaireLab != null;
    var typeRelationAffaire = Model.Item1.Culture == "Fr"
        ? Model.Item1.PersonneMoraleLab.TypeRelationAffaireLab?.NameFr
        : Model.Item1.PersonneMoraleLab.TypeRelationAffaireLab?.NameEn;
    var _isRelationTerminee = Model.Item1.PersonneMoraleLab.TypeRelationAffaireLabId == 4 || Model.Item1.PersonneMoraleLab.TypeRelationAffaireLabId == 3;
    var isRobot = _roleAccess.HasRoles(ActiviteModule.Lab, null, RoleUser.Robot);
    var isIsole = _roleAccess.HasClaimIsole(ActiviteModule.Lab);
    var isPm = "True";
    var isPp = "False";
    var relationAffaires = translator.Common["RelationAffaires"];
    var clientOccasionnel = translator.Common["ClientOccasionnel"];
    var tentativeEer = translator.Common["TentativeEer"];
    var priorities = new[] { new { Id = 1, Name = relationAffaires }, new { Id = 2, Name = clientOccasionnel }, new { Id = 3, Name = tentativeEer } };


    var Yes = "Oui";
    var No = "Non";
    var YesEu = "Oui, dans l'UE";
    var YesNoEu = "Oui, hors UE";
    var dontKnow = "Je ne sais pas";
    var sus = "Soupçonné/impliqué";
    var pre = "Victime présumée";

    if (_lang.ToLower() == "en")
    {
        Yes = "Yes";
        No = "No";
        dontKnow = "I don't know";
        sus = "Suspected/involved";
        pre = "Presumed victim";
    }

    var ouiNonDontKnow = new[] { new { Id = 1, Name = Yes }, new { Id = 2, Name = No }, new { Id = 3, Name = dontKnow } };
    var ouiNon = new[] { new { Id = 1, Name = Yes }, new { Id = 0, Name = No } };

    var ouiNonEu = new[] { new { Id = 1, Name = YesEu }, new { Id = 2, Name = YesNoEu }, new { Id = 3, Name = No } };
    var susPre = new[] { new { Id = 1, Name = sus }, new { Id = 2, Name = pre }, new { Id = 3, Name = dontKnow } };

    var idEtranger = _referentiel.IdentificationProfessionnelles
        .Single(idp => idp.Code == nameof(IdentificationProfessionnelleEnum.RN6))
        .Id;
    var requiredAsteriskSuffix = Model.Item2 + Constants.AsteriskIdSuffix;
}

<script type="text/javascript">
    $(document).ready(function () {
        arrayFirstLoadPersonneMorale[@(Model.Item2)] = true;
        if (checkExistDs()) {
            ProfessionalIdentificationId_OnValueChanged("PersonneMoraleLabProfessionalIdentificationId@(Model.Item2)");
        }
        disableEnableRequiredFiledOnAddPpPm();
    });
</script>

<div class="card moralPerson" id="rowMoralPerson@(Model.Item2)">
@Html.TextBox($"DossierLabPersonneMorales[{Model.Item2}].CryptedId", Model.Item1.CryptedId, new { type = "hidden" })
@Html.TextBox($"DossierLabPersonneMorales[{Model.Item2}].CryptedPersonneMoraleLabId", Model.Item1.CryptedPersonneMoraleLabId, new { id = "CryptedPersonneMoraleLabId" + Model.Item2, type = "hidden" })
@Html.TextBox($"DossierLabPersonneMorales[{Model.Item2}].CryptedDossierLabId", Model.Item1.CryptedDossierLabId, new { type = "hidden" })
@Html.TextBox($"DossierLabPersonneMorales[{Model.Item2}].PersonneMoraleLab.CryptedId", Model.Item1.PersonneMoraleLab?.CryptedId, new { id = "PersonneMoraleLabCryptedId" + Model.Item2, type = "hidden" })
@Html.TextBox($"DossierLabPersonneMorales[{Model.Item2}].PersonneMoraleLab.IdPersonne", Model.Item1.PersonneMoraleLab?.IdPersonne, new { id = "PersonneMoraleLabIdPersonne" + Model.Item2, type = "hidden" })
@Html.TextBox($"DossierLabPersonneMorales[{Model.Item2}].ToDelete", Model.Item1.ToDelete, new { id = "moralPersonToDelete" + Model.Item2, type = "hidden" })
@Html.TextBox($"DossierLabPersonneMorales[{Model.Item2}].moralPersonIsAlreadyImported", false, new { id = "moralPersonIsAlreadyImported" + Model.Item2, type = "hidden" })
@Html.TextBox($"DossierLabPersonneMorales[{Model.Item2}].IsNew", Model.Item1.IsNew, new { id = "moralPersonIsNew" + Model.Item2, type = "hidden" })


<div class="card-header p-1" id="headingMoralPerson@(Model.Item2)">
    <div class="d-flex adjust-card-header justify-content-between">
        <div style="width: 100%;">
            <a href="#" id="link@(Model.Item2)" data-toggle="collapse" data-target="#collapseMoralPerson@(Model.Item2)" aria-expanded="false" aria-controls="collapseMoralPerson@(Model.Item2)" style="text-decoration:none !important; color:inherit">
                <div>
                    <i class="fas fa-building mr-2"></i>@(translator.Common["MoralPerson"]) : <span id="identityMoralPerson@(Model.Item2)">@(Model.Item1.PersonneMoraleLab?.RaisonSociale) @(hasNumeroImmatriculation ? " (" : string.Empty)@(Model.Item1.PersonneMoraleLab?.NumeroImmatriculation)@(hasNumeroImmatriculation ? ")" : string.Empty) @(hasTypeRelationAffaire ? " - " : string.Empty)@(typeRelationAffaire)</span>
                </div>
            </a>

        </div>
        <div class="d-flex isPersonneDs @(Model.Item1.showIsDeclarationTracfin ? "" : "dx-hidden") mr-5">
            <div class="text-truncate mr-3">
                <span class="smallCaps text-green font-size-14px font-weight-bold">@translator.Common["IntegreeDs"]</span>
            </div>
            <div>
                @(Html.DevExtreme().CheckBoxFor(x => x.Item1.IsDeclarationTracfin).Name($"DossierLabPersonneMorales[{Model.Item2}].IsDeclarationTracfin").ID("DossierLabPersonneMoralesIsDeclarationTracfin" + Model.Item2).ElementAttr("class", "smallCaps text-green").ReadOnly(_isReadOnly)
                    .OnValueChanged(@<text>
                                         function(e)
                                         {
                                         if(!ensureNombreTiersIntegresDsBelowMaximumNumber(e) ||
                                         !ensureNombreLiensPersonnesIntegreesDsParDossierBelowMaxNumber(e) ||
                                         !ensureNombreReferencesFinancieresTiersIntegresDsBelowMaximumNumber(e))
                                         return;
                                         refreshAllOperationsAssurancesConcernedPersonsLists();
                                         refreshAllOperationsImmobilieresConcernedPersonsLists();
                                         }
                                     </text>))
            </div>
        </div>
        @if (!isRobot && !isIsole)
        {
            <div class="pr-1">
                @(Html.DevExtreme().Button()
                    .Icon("search")
                    .ElementAttr("class", "color-blue")
                    .ID("CriblagePersonneMoraleLab" + Model.Item2)
                    .Hint(translator.Common["CriblagePersonneMoraleParRaison"])
                    .Visible(!_isReadOnly)
                    .OnClick(@<text>
                                  function () {
                                  showCriblagePersonneMoraleLab_onClick('@(Model.Item2)')
                                  }
                              </text>))
            </div>
        }
        <div class="pr-1">
            @(Html.DevExtreme().Button()
                .Icon("trash")
                .ID("remRowDossierLabPersonneMoraleLabs" + Model.Item2)
                .ElementAttr("class", "color-red")
                .OnClick(@<text>
                              function () {
                              var confirmDialog = DevExpress.ui.dialog.custom({
                              title: "@translator.Common["Warning"]",
                              message: "@translator.Common["VoulezVousSupprimerSujet"]",
                              buttons: [{ text: "@translator.Common["Yes"]", onClick: function() { return true; } }, { text: "@translator.Common["No"]", onClick: function() { return false; } }]
                              });
                              confirmDialog.show().done(function (dialogResult) {
                              if (dialogResult) {
                              removeMoralPerson(@(Model.Item2));
                              refreshAllOperationsAssurancesConcernedPersonsLists();
                              refreshAllOperationsImmobilieresConcernedPersonsLists();
                              }
                              });
                              }
                          </text>).Visible(!_isReadOnly)
            )
        </div>
        <div>
            @(Html.DevExtreme().Button()
                .Icon("card")
                .ElementAttr("class", "color-blue")
                .ID("addDossierFraudePersonneMoraleLab" + Model.Item2).OnClick(@<text>
                                                                                    function () {

                                                                                    searchPpPm_OnClick('@(Model.Item2)','@isPp','@isPm');
                                                                                    }
                                                                                </text>).Visible(!_isReadOnly)
            )
            @(Html.DevExtreme().Popup()
                .ID("searchThirdModal")
                .ElementAttr(new Dictionary<string, object>
                    { { "class", "popup" } })
                .ShowTitle(true)
                .DragEnabled(true).ShowCloseButton(true)
                .ResizeEnabled(false)
                .Width("100%")
                .Height("auto")
                .ElementAttr("style", "min-Height:60%;overflow-y: scroll;")
                .TitleTemplate(@<text>
                                    <div class="d-flex flex-row align-items-center justify-content-between">
                                        <div class="font-size-16px text-green text-font-weight-600 smallCaps text-green">
                                            <i class="fas fa-pen mr-2"></i>@translator.Common["SearchThird"]
                                        </div>
                                        <button style="cursor: pointer; font-size: 24px; background-color: transparent; border: none; padding: 0; color: inherit;" onclick="$('#searchThirdModal').dxPopup('hide');">&times;</button>
                                    </div>
                                </text>))
        </div>
    </div>

</div>
