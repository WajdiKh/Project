/* ============================================================================
MODIFICATIONS INDEX — VERSION APRÈS REFACTORING
===============================================================================

Contexte final :
- Les requêtes DocumentDossierLabService font maintenant une jointure directe
  avec [Commun].[AccesPiecesJointesDirection].
- On respecte le couple exact :
  DirectionCibleId + TypeDocumentLabId
- Le filtre principal côté accès est :
  DirectionSourceId + AutoriserRecherche/AutoriserTelechargement + IsActive
- Les documents sont filtrés via :
  DossierLabId
  PersonneAssocieId
  TypeDocumentLabId
  IsDeleted = 0

============================================================================ */

USE [BacaratWeb]
GO


/* ============================================================================
1) GARDER L'INDEX UNIQUE
===============================================================================

Celui-ci reste indispensable.
Il empêche les doublons de paramétrage pour le même triplet :

DirectionSourceId + DirectionCibleId + TypeDocumentLabId
============================================================================ */

IF NOT EXISTS (
    SELECT 1
    FROM sys.indexes
    WHERE name = 'UX_AccesPiecesJointesDirection_Source_Cible_TypeDocument'
      AND object_id = OBJECT_ID('[Commun].[AccesPiecesJointesDirection]')
)
BEGIN
    CREATE UNIQUE NONCLUSTERED INDEX [UX_AccesPiecesJointesDirection_Source_Cible_TypeDocument]
    ON [Commun].[AccesPiecesJointesDirection]
    (
        [DirectionSourceId],
        [DirectionCibleId],
        [TypeDocumentLabId]
    );
END
GO


/* ============================================================================
2) SUPPRIMER LES ANCIENS INDEX MOINS ADAPTÉS SI DÉJÀ CRÉÉS
============================================================================ */

IF EXISTS (
    SELECT 1
    FROM sys.indexes
    WHERE name = 'IX_AccesPiecesJointesDirection_Source_Recherche_Active'
      AND object_id = OBJECT_ID('[Commun].[AccesPiecesJointesDirection]')
)
BEGIN
    DROP INDEX [IX_AccesPiecesJointesDirection_Source_Recherche_Active]
    ON [Commun].[AccesPiecesJointesDirection];
END
GO

IF EXISTS (
    SELECT 1
    FROM sys.indexes
    WHERE name = 'IX_AccesPiecesJointesDirection_Source_Cible_Telechargement_Active'
      AND object_id = OBJECT_ID('[Commun].[AccesPiecesJointesDirection]')
)
BEGIN
    DROP INDEX [IX_AccesPiecesJointesDirection_Source_Cible_Telechargement_Active]
    ON [Commun].[AccesPiecesJointesDirection];
END
GO

IF EXISTS (
    SELECT 1
    FROM sys.indexes
    WHERE name = 'IX_AccesPiecesJointesDirection_TypeDocumentLabId'
      AND object_id = OBJECT_ID('[Commun].[AccesPiecesJointesDirection]')
)
BEGIN
    DROP INDEX [IX_AccesPiecesJointesDirection_TypeDocumentLabId]
    ON [Commun].[AccesPiecesJointesDirection];
END
GO


/* ============================================================================
3) NOUVEL INDEX RECHERCHE
===============================================================================

Utilisé par :
- HasRechercheAccessAsync
- SearchPiecesIdentitePersonnePhysiqueAsync
- SearchPiecesIdentitePersonneMoraleAsync

Optimise :
- DirectionSourceId
- AutoriserRecherche = 1
- IsActive = 1
- jointure sur DirectionCibleId + TypeDocumentLabId
============================================================================ */

IF NOT EXISTS (
    SELECT 1
    FROM sys.indexes
    WHERE name = 'IX_AccesPiecesJointesDirection_Recherche'
      AND object_id = OBJECT_ID('[Commun].[AccesPiecesJointesDirection]')
)
BEGIN
    CREATE NONCLUSTERED INDEX [IX_AccesPiecesJointesDirection_Recherche]
    ON [Commun].[AccesPiecesJointesDirection]
    (
        [DirectionSourceId],
        [AutoriserRecherche],
        [IsActive],
        [DirectionCibleId],
        [TypeDocumentLabId]
    );
END
GO


/* ============================================================================
4) NOUVEL INDEX TÉLÉCHARGEMENT
===============================================================================

Utilisé par :
- DownloadPiecesIdentiteZip
- GetPiecesIdentiteDocumentsAsync

Optimise :
- DirectionSourceId
- DirectionCibleId
- AutoriserTelechargement = 1
- IsActive = 1
- TypeDocumentLabId
============================================================================ */

IF NOT EXISTS (
    SELECT 1
    FROM sys.indexes
    WHERE name = 'IX_AccesPiecesJointesDirection_Telechargement'
      AND object_id = OBJECT_ID('[Commun].[AccesPiecesJointesDirection]')
)
BEGIN
    CREATE NONCLUSTERED INDEX [IX_AccesPiecesJointesDirection_Telechargement]
    ON [Commun].[AccesPiecesJointesDirection]
    (
        [DirectionSourceId],
        [DirectionCibleId],
        [AutoriserTelechargement],
        [IsActive],
        [TypeDocumentLabId]
    );
END
GO


/* ============================================================================
5) INDEX DOCUMENTDOSSIERLAB POUR LA RECHERCHE PIÈCES IDENTITÉ
===============================================================================

Utilisé pour :
- filtrer les documents actifs
- joindre TypeDocumentLabId
- retrouver les PJ d'une personne
- récupérer les documents d'un dossier donné

Index filtré sur IsDeleted = 0 pour réduire sa taille.

ATTENTION :
Si ta base SQL Server ne permet pas l'index filtré avec ce schéma,
utilise l'alternative non filtrée plus bas.
============================================================================ */

IF NOT EXISTS (
    SELECT 1
    FROM sys.indexes
    WHERE name = 'IX_DocumentDossierLab_PiecesIdentite'
      AND object_id = OBJECT_ID('[Lab].[DocumentDossierLab]')
)
BEGIN
    CREATE NONCLUSTERED INDEX [IX_DocumentDossierLab_PiecesIdentite]
    ON [Lab].[DocumentDossierLab]
    (
        [DossierLabId],
        [PersonneAssocieId],
        [TypeDocumentLabId]
    )
    INCLUDE
    (
        [DocumentLabId]
    )
    WHERE [IsDeleted] = 0;
END
GO


/* ============================================================================
6) ALTERNATIVE SI TU NE VEUX PAS D'INDEX FILTRÉ
===============================================================================

À utiliser uniquement si l'index filtré ci-dessus pose problème.

IF NOT EXISTS (
    SELECT 1
    FROM sys.indexes
    WHERE name = 'IX_DocumentDossierLab_PiecesIdentite'
      AND object_id = OBJECT_ID('[Lab].[DocumentDossierLab]')
)
BEGIN
    CREATE NONCLUSTERED INDEX [IX_DocumentDossierLab_PiecesIdentite]
    ON [Lab].[DocumentDossierLab]
    (
        [IsDeleted],
        [DossierLabId],
        [PersonneAssocieId],
        [TypeDocumentLabId]
    )
    INCLUDE
    (
        [DocumentLabId]
    );
END
GO
============================================================================ */


/* ============================================================================
7) VÉRIFICATION
============================================================================ */

SELECT
    i.name AS IndexName,
    OBJECT_SCHEMA_NAME(i.object_id) AS SchemaName,
    OBJECT_NAME(i.object_id) AS TableName,
    i.is_unique,
    i.has_filter,
    i.filter_definition
FROM sys.indexes i
WHERE i.object_id IN (
    OBJECT_ID('[Commun].[AccesPiecesJointesDirection]'),
    OBJECT_ID('[Lab].[DocumentDossierLab]')
)
AND i.name LIKE '%Pieces%'
ORDER BY
    SchemaName,
    TableName,
    IndexName;
GO