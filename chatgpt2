// 7. DocumentDossierLabService
// Corriger la recherche en respectant le couple DirectionCibleId + TypeDocumentLabId
// ==========================================================

public async Task<List<PieceIdentiteSearchResultViewModel>> SearchPiecesIdentitePersonnePhysiqueAsync(
    string nom,
    string prenoms,
    DateTimeOffset? dateNaissance,
    IReadOnlyCollection<AccesPiecesJointesDirectionAutoriseViewModel> accesAutorises,
    CancellationToken token = default)
{
    if (string.IsNullOrWhiteSpace(nom)
        || string.IsNullOrWhiteSpace(prenoms)
        || !dateNaissance.HasValue
        || accesAutorises == null
        || !accesAutorises.Any())
    {
        return new List<PieceIdentiteSearchResultViewModel>();
    }

    return await Repository.Query()
        .AsNoTracking()
        .Where(document =>
            !document.IsDeleted
            && document.TypeDocumentLabId.HasValue
            && accesAutorises.Any(acces =>
                acces.DirectionCibleId == document.DossierLab.DirectionId
                && acces.TypeDocumentLabId == document.TypeDocumentLabId.Value))
        .SelectMany(document => document.DossierLab.DossierLabPersonnePhysiques)
        .Where(personne =>
            personne.PersonnePhysiqueLab.IdPersonne.HasValue
            && personne.PersonnePhysiqueLab.NomNaissance == nom
            && personne.PersonnePhysiqueLab.Prenoms == prenoms
            && personne.PersonnePhysiqueLab.DateNaissance == dateNaissance.Value)
        .Select(personne => new PieceIdentiteSearchResultViewModel
        {
            DossierLabId = personne.DossierLabId,
            PersonneId = personne.PersonnePhysiqueLab.IdPersonne.Value,
            IsPersonneMorale = false,
            Nom = personne.PersonnePhysiqueLab.NomNaissance,
            Prenom = personne.PersonnePhysiqueLab.Prenoms,
            DateNaissance = personne.PersonnePhysiqueLab.DateNaissance,
            CodeDossier = personne.DossierLab.CodeUnique,
            DirectionId = personne.DossierLab.DirectionId,
            DirectionCibleId = personne.DossierLab.DirectionId,
            DirectionName = personne.DossierLab.Direction.Nom
        })
        .Distinct()
        .ToListAsync(token);
}

public async Task<List<PieceIdentiteSearchResultViewModel>> SearchPiecesIdentitePersonneMoraleAsync(
    string raisonSociale,
    string numeroImmatriculation,
    IReadOnlyCollection<AccesPiecesJointesDirectionAutoriseViewModel> accesAutorises,
    CancellationToken token = default)
{
    if (string.IsNullOrWhiteSpace(raisonSociale)
        || string.IsNullOrWhiteSpace(numeroImmatriculation)
        || accesAutorises == null
        || !accesAutorises.Any())
    {
        return new List<PieceIdentiteSearchResultViewModel>();
    }

    return await Repository.Query()
        .AsNoTracking()
        .Where(document =>
            !document.IsDeleted
            && document.TypeDocumentLabId.HasValue
            && accesAutorises.Any(acces =>
                acces.DirectionCibleId == document.DossierLab.DirectionId
                && acces.TypeDocumentLabId == document.TypeDocumentLabId.Value))
        .SelectMany(document => document.DossierLab.DossierLabPersonneMorales)
        .Where(personne =>
            personne.PersonneMoraleLab.IdPersonne.HasValue
            && personne.PersonneMoraleLab.RaisonSociale == raisonSociale
            && personne.PersonneMoraleLab.NumeroImmatriculation == numeroImmatriculation)
        .Select(personne => new PieceIdentiteSearchResultViewModel
        {
            DossierLabId = personne.DossierLabId,
            PersonneId = personne.PersonneMoraleLab.IdPersonne.Value,
            IsPersonneMorale = true,
            RaisonSociale = personne.PersonneMoraleLab.RaisonSociale,
            NumeroImmatriculation = personne.PersonneMoraleLab.NumeroImmatriculation,
            CodeDossier = personne.DossierLab.CodeUnique,
            DirectionId = personne.DossierLab.DirectionId,
            DirectionCibleId = personne.DossierLab.DirectionId,
            DirectionName = personne.DossierLab.Direction.Nom
        })
        .Distinct()
        .ToListAsync(token);
}

public async Task<List<DocumentDossierLab>> GetPiecesIdentiteDocumentsAsync(
    int dossierLabId,
    Guid personneId,
    IReadOnlyCollection<AccesPiecesJointesDirectionAutoriseViewModel> accesAutorises,
    CancellationToken token = default)
{
    if (accesAutorises == null || !accesAutorises.Any())
        return new List<DocumentDossierLab>();

    return await Repository.Query()
        .Include(document => document.DocumentLab)
        .Where(document =>
            !document.IsDeleted
            && document.DossierLabId == dossierLabId
            && document.PersonneAssocieId == personneId
            && document.TypeDocumentLabId.HasValue
            && accesAutorises.Any(acces =>
                acces.DirectionCibleId == document.DossierLab.DirectionId
                && acces.TypeDocumentLabId == document.TypeDocumentLabId.Value))
        .ToListAsync(token);
}


