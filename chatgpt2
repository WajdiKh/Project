[HttpGet]
public async Task<IActionResult> SearchPiecesIdentitePersonnePhysique(
    int directionId,
    string nom,
    string prenoms,
    DateTimeOffset? dateNaissance,
    CancellationToken token = default)
{
    if (directionId <= 0)
        return BadRequest(_translator.Common["Lab.PiecesIdentite.DirectionRequired"]);

    var hasAccess = await _accesPiecesJointesDirectionService
        .HasRechercheAccessAsync(directionId, token);

    if (!hasAccess)
    {
        return StatusCode(
            StatusCodes.Status403Forbidden,
            _translator.Common["Lab.PiecesIdentite.SearchUnauthorized"]);
    }

    var directionsCibles = await _accesPiecesJointesDirectionService
        .GetDirectionsCiblesRechercheAsync(directionId, token);

    var typeDocumentIds = await _accesPiecesJointesDirectionService
        .GetTypesDocumentsRechercheAsync(directionId, token);

    var result = await _labAttachmentService
        .SearchPiecesIdentitePersonnePhysiqueAsync(
            nom,
            prenoms,
            dateNaissance,
            directionsCibles,
            typeDocumentIds,
            token);

    return Json(result);
}


