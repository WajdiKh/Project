        CurrentUser.Email,
        token);

    if (share == null)
    {
        return StatusCode(
            StatusCodes.Status403Forbidden,
            _translator.Common["Transfert.Document.ShareInactive"]);
    }

    var vm = new DownloadDocumentViewModel
    {
        DocumentId = id
    };

    return View("/Areas/Transfert/Views/Document/Download.cshtml", vm);
}

