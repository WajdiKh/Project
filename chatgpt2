            IsPersonneMorale = true,
            RaisonSociale = personne.PersonneMoraleLab.RaisonSociale,
            NumeroImmatriculation = personne.PersonneMoraleLab.NumeroImmatriculation,
            CodeDossier = personne.DossierLab.CodeUnique,
