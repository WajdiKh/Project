[HttpGet]
public async Task<IActionResult> DownloadPiecesIdentiteZip(
    int directionId,
    int dossierLabId,
    Guid personneId,
    bool isPersonneMorale,
    CancellationToken token = default)
{
    if (directionId <= 0)
        return BadRequest(_translator.Common["Lab.PiecesIdentite.DirectionRequired"]);

    var zipContent = await _accesPiecesJointesDirectionService
        .BuildPiecesIdentiteZipAsync(
            directionId,
            dossierLabId,
            personneId,
            isPersonneMorale,
            token);

    if (zipContent == null || zipContent.Length == 0)
        return BadRequest(_translator.Common["Lab.PiecesIdentite.NoResult"]);

    var zipName = $"PiecesIdentite_{DateTime.Now:yyyyMMddHHmmss}.zip";

    return File(
        zipContent,
        "application/zip",
        zipName);
}

