public async Task<byte[]> BuildPiecesIdentiteZipAsync(
    int dossierLabId,
    Guid personneId,
    IReadOnlyCollection<int> typeDocumentIds,
    CancellationToken token = default)
{
    var documents =
        await _documentDossierLabService
            .GetPiecesIdentiteDocumentsAsync(
                dossierLabId,
                personneId,
                typeDocumentIds,
                token);

    return BuildZip(documents);
}


// ==========================================================
// MÉTHODE PRIVÉE À AJOUTER DANS LabAttachmentService
// ==========================================================

private static byte[] BuildZip(
    IReadOnlyCollection<DocumentDossierLab> documents)
{
    if (documents == null || !documents.Any())
        return Array.Empty<byte>();

    using var memoryStream = new MemoryStream();

    using (var archive = new ZipArchive(
        memoryStream,
        ZipArchiveMode.Create,
        true))
    {
        foreach (var document in documents)
        {
            if (document.DocumentLab?.Document == null)
                continue;

            var fileName =
                string.IsNullOrWhiteSpace(document.DocumentLab.Name)
                    ? document.DocumentLab.Document.FileName
                    : document.DocumentLab.Name;

            var entry = archive.CreateEntry(
                fileName,
                CompressionLevel.Fastest);

            using var entryStream = entry.Open();

            entryStream.Write(
                document.DocumentLab.Document,
                0,
                document.DocumentLab.Document.Length);
        }
    }

    return memoryStream.ToArray();
}



