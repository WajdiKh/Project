Garder inchangée GetPiecesIdentiteDocumentsAsync :

public async Task<List<DocumentDossierLab>> GetPiecesIdentiteDocumentsAsync(
    int dossierLabId,
    Guid personneId,
    IReadOnlyCollection<int> typeDocumentIds,
    CancellationToken token = default)
{
    return await Repository.Query()
        .Include(x => x.DocumentLab)
        .Where(x =>
            !x.IsDeleted
            && x.DossierLabId == dossierLabId
            && x.PersonneAssocieId == personneId
            && x.TypeDocumentLabId.HasValue
            && typeDocumentIds.Contains(x.TypeDocumentLabId.Value))
        .ToListAsync(token);
}

