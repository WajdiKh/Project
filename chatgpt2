var dateNaissance = $("#PersonnePhysiqueLabDateNaissance" + index)
    .dxDateBox("instance")
    .option("value");

var dateNaissanceUtc = null;

if (dateNaissance) {

    dateNaissanceUtc = new Date(Date.UTC(
        dateNaissance.getFullYear(),
        dateNaissance.getMonth(),
        dateNaissance.getDate(),
        0,
        0,
        0,
        0))
        .toISOString();
}