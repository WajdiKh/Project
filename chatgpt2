using System;
using System.Collections.Generic;
using System.IO;
using System.IO.Compression;
using System.Linq;
using System.Threading;
using System.Threading.Tasks;
using BacaratWeb.Model.Entities;
using BacaratWeb.Services.Lab.Interfaces;
using BacaratWeb.ViewModel.Lab;
using Microsoft.EntityFrameworkCore;

namespace BacaratWeb.Services.Lab
{
    public class AccesPiecesJointesDirectionService : IAccesPiecesJointesDirectionService
    {
        private readonly BacaratWebContext _context;

        public AccesPiecesJointesDirectionService(BacaratWebContext context)
        {
            _context = context ?? throw new ArgumentNullException(nameof(context));
        }

        public async Task<bool> HasRechercheAccessAsync(
            int directionSourceId,
            CancellationToken token = default)
        {
            return await _context.AccesPiecesJointesDirections
                .AnyAsync(x =>
                    x.DirectionSourceId == directionSourceId &&
                    x.AutoriserRecherche &&
                    x.IsActive,
                    token);
        }

        public async Task<List<PieceIdentiteSearchResultViewModel>> SearchPersonnePhysiqueAsync(
            int directionSourceId,
            Guid personneId,
            CancellationToken token = default)
        {
            var personneSource = await _context.PersonnePhysiqueLabs
                .FirstOrDefaultAsync(x => x.IdPersonne == personneId, token);

            if (personneSource == null)
                return new List<PieceIdentiteSearchResultViewModel>();

            var accesses = await GetRechercheAccessesAsync(directionSourceId, token);

            if (!accesses.Any())
                return new List<PieceIdentiteSearchResultViewModel>();

            var directionCibleIds = accesses
                .Select(x => x.DirectionCibleId)
                .Distinct()
                .ToList();

            var typeDocumentIds = accesses
                .Select(x => x.TypeDocumentLabId)
                .Distinct()
                .ToList();

            return await _context.DossierLabPersonnePhysiques
                .AsNoTracking()
                .Include(x => x.DossierLab)
                    .ThenInclude(x => x.Direction)
                .Include(x => x.PersonnePhysiqueLab)
                .Where(x =>
                    x.PersonnePhysiqueLab.IdPersonne.HasValue &&
                    x.DossierLab != null &&
                    directionCibleIds.Contains(x.DossierLab.DirectionId) &&
                    x.PersonnePhysiqueLab.NomNaissance == personneSource.NomNaissance &&
                    x.PersonnePhysiqueLab.Prenoms == personneSource.Prenoms &&
                    x.PersonnePhysiqueLab.DateNaissance == personneSource.DateNaissance &&
                    _context.DocumentDossierLabs.Any(d =>
                        d.DossierLabId == x.DossierLabId &&
                        d.PersonneAssocieId == x.PersonnePhysiqueLab.IdPersonne &&
                        d.TypeDocumentLabId.HasValue &&
                        typeDocumentIds.Contains(d.TypeDocumentLabId.Value) &&
                        !d.IsDeleted))
                .Select(x => new PieceIdentiteSearchResultViewModel
                {
                    DossierLabId = x.DossierLabId,
                    PersonneId = x.PersonnePhysiqueLab.IdPersonne.Value,
                    IsPersonneMorale = false,
                    Nom = x.PersonnePhysiqueLab.NomNaissance,
                    Prenom = x.PersonnePhysiqueLab.Prenoms,
                    DateNaissance = x.PersonnePhysiqueLab.DateNaissance,
                    CodeDossier = x.DossierLab.CodeUnique,
                    DirectionId = x.DossierLab.DirectionId,
                    DirectionName = x.DossierLab.Direction != null ? x.DossierLab.Direction.Nom : string.Empty,
                    NombrePiecesIdentite = _context.DocumentDossierLabs.Count(d =>
                        d.DossierLabId == x.DossierLabId &&
                        d.PersonneAssocieId == x.PersonnePhysiqueLab.IdPersonne &&
                        d.TypeDocumentLabId.HasValue &&
                        typeDocumentIds.Contains(d.TypeDocumentLabId.Value) &&
                        !d.IsDeleted)
                })
                .ToListAsync(token);
        }

        public async Task<List<PieceIdentiteSearchResultViewModel>> SearchPersonneMoraleAsync(
            int directionSourceId,
            Guid personneId,
            CancellationToken token = default)
        {
            var personneSource = await _context.PersonneMoraleLabs
                .FirstOrDefaultAsync(x => x.IdPersonne == personneId, token);

            if (personneSource == null)
                return new List<PieceIdentiteSearchResultViewModel>();

            var accesses = await GetRechercheAccessesAsync(directionSourceId, token);

            if (!accesses.Any())
                return new List<PieceIdentiteSearchResultViewModel>();

            var directionCibleIds = accesses
                .Select(x => x.DirectionCibleId)
                .Distinct()
                .ToList();

            var typeDocumentIds = accesses
                .Select(x => x.TypeDocumentLabId)
                .Distinct()
                .ToList();

            return await _context.DossierLabPersonneMorales
                .AsNoTracking()
                .Include(x => x.DossierLab)
                    .ThenInclude(x => x.Direction)
                .Include(x => x.PersonneMoraleLab)
                .Where(x =>
                    x.PersonneMoraleLab.IdPersonne.HasValue &&
                    x.DossierLab != null &&
                    directionCibleIds.Contains(x.DossierLab.DirectionId) &&
                    x.PersonneMoraleLab.RaisonSociale == personneSource.RaisonSociale &&
                    x.PersonneMoraleLab.NumeroImmatriculation == personneSource.NumeroImmatriculation &&
                    _context.DocumentDossierLabs.Any(d =>
                        d.DossierLabId == x.DossierLabId &&
                        d.PersonneAssocieId == x.PersonneMoraleLab.IdPersonne &&
                        d.TypeDocumentLabId.HasValue &&
                        typeDocumentIds.Contains(d.TypeDocumentLabId.Value) &&
                        !d.IsDeleted))
                .Select(x => new PieceIdentiteSearchResultViewModel
                {
                    DossierLabId = x.DossierLabId,
                    PersonneId = x.PersonneMoraleLab.IdPersonne.Value,
                    IsPersonneMorale = true,
                    RaisonSociale = x.PersonneMoraleLab.RaisonSociale,
                    NumeroImmatriculation = x.PersonneMoraleLab.NumeroImmatriculation,
                    CodeDossier = x.DossierLab.CodeUnique,
                    DirectionId = x.DossierLab.DirectionId,
                    DirectionName = x.DossierLab.Direction != null ? x.DossierLab.Direction.Nom : string.Empty,
                    NombrePiecesIdentite = _context.DocumentDossierLabs.Count(d =>
                        d.DossierLabId == x.DossierLabId &&
                        d.PersonneAssocieId == x.PersonneMoraleLab.IdPersonne &&
                        d.TypeDocumentLabId.HasValue &&
                        typeDocumentIds.Contains(d.TypeDocumentLabId.Value) &&
                        !d.IsDeleted)
                })
                .ToListAsync(token);
        }

        public async Task<byte[]> BuildPiecesIdentiteZipAsync(
            int directionSourceId,
            int dossierLabId,
            Guid personneId,
            bool isPersonneMorale,
            CancellationToken token = default)
        {
            var dossier = await _context.DossierLabs
                .AsNoTracking()
                .FirstOrDefaultAsync(x => x.Id == dossierLabId, token);

            if (dossier == null)
                return Array.Empty<byte>();

            var typeDocumentIds = await _context.AccesPiecesJointesDirections
                .Where(x =>
                    x.DirectionSourceId == directionSourceId &&
                    x.DirectionCibleId == dossier.DirectionId &&
                    x.AutoriserTelechargement &&
                    x.IsActive)
                .Select(x => x.TypeDocumentLabId)
                .Distinct()
                .ToListAsync(token);

            if (!typeDocumentIds.Any())
                return Array.Empty<byte>();

            var documents = await _context.DocumentDossierLabs
                .AsNoTracking()
                .Include(x => x.DocumentLab)
                .Where(x =>
                    x.DossierLabId == dossierLabId &&
                    x.PersonneAssocieId == personneId &&
                    x.TypeDocumentLabId.HasValue &&
                    typeDocumentIds.Contains(x.TypeDocumentLabId.Value) &&
                    !x.IsDeleted &&
                    x.DocumentLab != null)
                .ToListAsync(token);

            if (!documents.Any())
                return Array.Empty<byte>();

            using var memoryStream = new MemoryStream();

            using (var archive = new ZipArchive(memoryStream, ZipArchiveMode.Create, true))
            {
                foreach (var document in documents)
                {
                    var fileName = !string.IsNullOrWhiteSpace(document.FileName)
                        ? document.FileName
                        : document.DocumentLab.Name;

                    var safeFileName = SanitizeZipEntryName(fileName);

                    var entry = archive.CreateEntry(safeFileName, CompressionLevel.Fastest);

                    using var entryStream = entry.Open();

                    await entryStream.WriteAsync(
                        document.DocumentLab.FileContent,
                        0,
                        document.DocumentLab.FileContent.Length,
                        token);
                }
            }

            return memoryStream.ToArray();
        }

        private async Task<List<AccesPiecesJointesDirection>> GetRechercheAccessesAsync(
            int directionSourceId,
            CancellationToken token)
        {
            return await _context.AccesPiecesJointesDirections
                .AsNoTracking()
                .Where(x =>
                    x.DirectionSourceId == directionSourceId &&
                    x.AutoriserRecherche &&
                    x.IsActive)
                .ToListAsync(token);
        }

        private static string SanitizeZipEntryName(string fileName)
        {
            var invalidChars = Path.GetInvalidFileNameChars();

            foreach (var invalidChar in invalidChars)
                fileName = fileName.Replace(invalidChar, '_');

            return fileName;
        }
    }
}

