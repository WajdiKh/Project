1.
Chargement droits
-------------------------------------------------------------------------------

function loadIdentityDocumentAccess()
{
    const directionId =
        $("#DirectionId")
            .dxSelectBox("instance")
            .option("value");

    if (!directionId)
    {
        window.canSearchIdentityDocuments = false;
        refreshIdentityIcons();
        return;
    }

    $.get(
        urlHasAccesRecherchePiecesIdentite,
        { directionId },
        function(result)
        {
            window.canSearchIdentityDocuments = result.hasAccess;
            refreshIdentityIcons();
        });
}


