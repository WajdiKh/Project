function refreshPiecesIdentiteButtonsVisibility() {
    $(".btn-pieces-identite").each(function () {
        var $button = $(this);

        var canDisplayByIntegreeDsCondition =
            $button.data("can-display-integree-ds") === true ||
            $button.data("can-display-integree-ds") === "true";

        $button.toggle(canDisplayByIntegreeDsCondition && canSearchPiecesIdentite);
    });
}



// ==========================================================
// REMPLACER PAR
// ==========================================================

function refreshPiecesIdentiteButtonsVisibility() {

    var canDisplayPiecesIdentite =
        $("#CanDisplayPiecesIdentite").length > 0
        && canSearchPiecesIdentite;

    $(".btn-pieces-identite").toggle(canDisplayPiecesIdentite);
}



// ==========================================================
// OPTIONNEL MAIS PLUS LISIBLE
// ==========================================================

function canDisplayPiecesIdentite() {

    return $("#CanDisplayPiecesIdentite").length > 0
        && canSearchPiecesIdentite;
}

function refreshPiecesIdentiteButtonsVisibility() {

    $(".btn-pieces-identite")
        .toggle(canDisplayPiecesIdentite());
}



// ==========================================================
// SI TU VEUX ÉVITER LE HIDDEN FIELD
// ET QUE LA CHECKBOX EST TOUJOURS DANS LE DOM
//
// ALTERNATIVE
// ==========================================================

function canDisplayPiecesIdentite() {

    return $("#IsDeclarationSoupcon").is(":visible")
        && canSearchPiecesIdentite;
}

function refreshPiecesIdentiteButtonsVisibility() {

    $(".btn-pieces-identite")
        .toggle(canDisplayPiecesIdentite());
}



