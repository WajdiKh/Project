function disableDocumentShare(documentShareId) {
    DevExpress.ui.dialog.confirm(
        _transfertDocumentDisableShareConfirm,
        _transfertDocumentShareHistory
    ).done(function (dialogResult) {

        if (!dialogResult) {
            return;
        }

        $.ajax({
            method: "POST",
            url: "/" + currentCulture + "/transfert/disable-share-document",
            data: {
                documentShareId: documentShareId
            }
        }).done(function () {

            DevExpress.ui.notify(
                _transfertDocumentShareDisabledSuccess,
                "success",
                3000);

            refreshDocumentSharesGrid();

        }).fail(function (xhr) {

            DevExpress.ui.notify(
                xhr.responseText || _transfertDocumentShareDisableError,
                "error",
                3000);
        });
    });
}


