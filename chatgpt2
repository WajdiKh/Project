public async Task<List<DocumentDossierLab>> GetPiecesIdentiteDocumentsAsync(
    int directionSourceId,
    int dossierLabId,
    Guid personneId,
    int directionCibleId,
    CancellationToken token = default)
{
    if (directionSourceId <= 0
        || dossierLabId <= 0
        || personneId == Guid.Empty
        || directionCibleId <= 0)
    {
        return new List<DocumentDossierLab>();
    }

    var query =
        from document in Repository.Query()
            .Include(x => x.DocumentLab)
        join acces in Context.AccesPiecesJointesDirections.AsNoTracking()
            on new
            {
                DirectionCibleId = document.DossierLab.DirectionId,
                TypeDocumentLabId = document.TypeDocumentLabId.Value
            }
            equals new
            {
                acces.DirectionCibleId,
                acces.TypeDocumentLabId
            }
        where !document.IsDeleted
              && document.DossierLabId == dossierLabId
              && document.PersonneAssocieId == personneId
              && document.TypeDocumentLabId.HasValue
              && document.DossierLab.DirectionId == directionCibleId
              && acces.DirectionSourceId == directionSourceId
              && acces.DirectionCibleId == directionCibleId
              && acces.AutoriserTelechargement
              && acces.IsActive
        select document;

    return await query
        .Distinct()
        .ToListAsync(token);
}



