// Remplacer les méthodes concernées par celles-ci
//
// IMPORTANT :
// Ces méthodes supposent que DocumentDossierLabService a accès à Context.
// Si dans ton service la propriété s'appelle autrement, remplace Context par
// la propriété existante.
// ============================================================================

public async Task<List<PieceIdentiteSearchResultViewModel>> SearchPiecesIdentitePersonnePhysiqueAsync(
    int directionSourceId,
    string nom,
    string prenoms,
    DateTimeOffset? dateNaissance,
    CancellationToken token = default)
{
    if (directionSourceId <= 0
        || string.IsNullOrWhiteSpace(nom)
        || string.IsNullOrWhiteSpace(prenoms)
        || !dateNaissance.HasValue)
    {
        return new List<PieceIdentiteSearchResultViewModel>();
    }

    var query =
        from document in Repository.Query().AsNoTracking()
        join acces in Context.AccesPiecesJointesDirections.AsNoTracking()
            on new
            {
                DirectionCibleId = document.DossierLab.DirectionId,
                TypeDocumentLabId = document.TypeDocumentLabId.Value
            }
            equals new
            {
                acces.DirectionCibleId,
                acces.TypeDocumentLabId
            }
        from personne in document.DossierLab.DossierLabPersonnePhysiques
        where !document.IsDeleted
              && document.TypeDocumentLabId.HasValue
              && acces.DirectionSourceId == directionSourceId
              && acces.AutoriserRecherche
              && acces.IsActive
              && personne.PersonnePhysiqueLab.IdPersonne.HasValue
              && personne.PersonnePhysiqueLab.NomNaissance == nom
              && personne.PersonnePhysiqueLab.Prenoms == prenoms
              && personne.PersonnePhysiqueLab.DateNaissance == dateNaissance.Value
        select new PieceIdentiteSearchResultViewModel
        {
            DossierLabId = personne.DossierLabId,
            PersonneId = personne.PersonnePhysiqueLab.IdPersonne.Value,
            IsPersonneMorale = false,
            Nom = personne.PersonnePhysiqueLab.NomNaissance,
            Prenom = personne.PersonnePhysiqueLab.Prenoms,
            DateNaissance = personne.PersonnePhysiqueLab.DateNaissance,
            CodeDossier = personne.DossierLab.CodeUnique,
            DirectionId = personne.DossierLab.DirectionId,
            DirectionCibleId = personne.DossierLab.DirectionId,
            DirectionName = personne.DossierLab.Direction.Nom
        };

    return await query
        .Distinct()
        .ToListAsync(token);
}

public async Task<List<PieceIdentiteSearchResultViewModel>> SearchPiecesIdentitePersonneMoraleAsync(
    int directionSourceId,
    string raisonSociale,
    string numeroImmatriculation,
    CancellationToken token = default)
