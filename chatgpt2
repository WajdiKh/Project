USE [BacaratWeb]
GO

DECLARE @Traductions TABLE
(
    Id NVARCHAR(250) NOT NULL,
    FrenchTranslate VARCHAR(MAX) NOT NULL,
    EnglishTranslate VARCHAR(MAX) NOT NULL
);

INSERT INTO @Traductions
(
    Id,
    FrenchTranslate,
    EnglishTranslate
)
VALUES
(
    N'Lab.PiecesIdentite.SearchAndDownload',
    'Rechercher et télécharger les pièces d''identité',
    'Search and download identity documents'
);

MERGE [Commun].[Traduction] AS target
USING @Traductions AS source
    ON target.Id = source.Id
WHEN MATCHED THEN
    UPDATE SET
        target.FrenchTranslate = source.FrenchTranslate,
        target.EnglishTranslate = source.EnglishTranslate
WHEN NOT MATCHED BY TARGET THEN
    INSERT
    (
        Id,
        FrenchTranslate,
        EnglishTranslate
    )
    VALUES
    (
        source.Id,
        source.FrenchTranslate,
        source.EnglishTranslate
    );
GO