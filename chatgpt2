private string GetDocumentExpiryDelayLabel(
    Document document,
    CultureInfo cultureInfo)
{
    var delayHours = document.ExpiryDelayHours;

    if (!delayHours.HasValue)
    {
        delayHours = (int)Math.Round(
            (document.ExpiryDate - document.UploadDate).TotalHours,
            MidpointRounding.AwayFromZero);
    }

    var horsWeekendLabel =
        cultureInfo.TwoLetterISOLanguageName.Equals("fr", StringComparison.OrdinalIgnoreCase)
            ? "Hors weekend"
            : "Excluding weekends";

    return string.Format(
        cultureInfo,
        "{0} h ({1})",
        delayHours.Value,
        horsWeekendLabel);
}

