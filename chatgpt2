using System.Collections.Generic;
using System.Linq;
using System.Threading;
using System.Threading.Tasks;
using BacaratWeb.Model.Entities;
using BacaratWeb.Services.Lab.Interfaces;
using Microsoft.EntityFrameworkCore;

namespace BacaratWeb.Services.Lab
{
    public class AccesPiecesJointesDirectionService : IAccesPiecesJointesDirectionService
    {
        private readonly BacaratWebContext _context;

        public AccesPiecesJointesDirectionService(BacaratWebContext context)
        {
            _context = context;
        }

        public async Task<bool> HasRechercheAccessAsync(
            int directionSourceId,
            CancellationToken token = default)
        {
            return await _context.AccesPiecesJointesDirections
                .AnyAsync(x =>
                    x.DirectionSourceId == directionSourceId &&
                    x.AutoriserRecherche &&
                    x.IsActive,
                    token);
        }

        public async Task<List<int>> GetDirectionsCiblesRechercheAsync(
            int directionSourceId,
            CancellationToken token = default)
        {
            return await _context.AccesPiecesJointesDirections
                .Where(x =>
                    x.DirectionSourceId == directionSourceId &&
                    x.AutoriserRecherche &&
                    x.IsActive)
                .Select(x => x.DirectionCibleId)
                .Distinct()
                .ToListAsync(token);
        }

        public async Task<List<int>> GetTypesDocumentsRechercheAsync(
            int directionSourceId,
            int directionCibleId,
            CancellationToken token = default)
        {
            return await _context.AccesPiecesJointesDirections
                .Where(x =>
                    x.DirectionSourceId == directionSourceId &&
                    x.DirectionCibleId == directionCibleId &&
                    x.AutoriserRecherche &&
                    x.IsActive)
                .Select(x => x.TypeDocumentLabId)
                .Distinct()
                .ToListAsync(token);
        }

        public async Task<List<int>> GetTypesDocumentsTelechargementAsync(
            int directionSourceId,
            int directionCibleId,
            CancellationToken token = default)
        {
            return await _context.AccesPiecesJointesDirections
                .Where(x =>
                    x.DirectionSourceId == directionSourceId &&
                    x.DirectionCibleId == directionCibleId &&
                    x.AutoriserTelechargement &&
                    x.IsActive)
                .Select(x => x.TypeDocumentLabId)
                .Distinct()
                .ToListAsync(token);
        }

        public async Task<bool> CanDownloadAsync(
            int directionSourceId,
            int directionCibleId,
            int typeDocumentLabId,
            CancellationToken token = default)
        {
            return await _context.AccesPiecesJointesDirections
                .AnyAsync(x =>
                    x.DirectionSourceId == directionSourceId &&
                    x.DirectionCibleId == directionCibleId &&
                    x.TypeDocumentLabId == typeDocumentLabId &&
                    x.AutoriserTelechargement &&
                    x.IsActive,
                    token);
        }
    }
}

