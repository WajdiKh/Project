DECLARE @DirectionSourceId INT;
DECLARE @DirectionCibleId INT;

SELECT TOP 1 @DirectionSourceId = Id
FROM [Commun].[Direction]
WHERE Nom = 'PREDICA'
   OR Abreviation = 'PREDICA';

SELECT TOP 1 @DirectionCibleId = Id
FROM [Commun].[Direction]
WHERE Nom = 'LCL'
   OR Abreviation = 'LCL';

IF @DirectionSourceId IS NULL
    THROW 50001, 'Direction source PREDICA introuvable dans Commun.Direction.', 1;

IF @DirectionCibleId IS NULL
    THROW 50002, 'Direction cible LCL introuvable dans Commun.Direction.', 1;

DECLARE @Types TABLE(Code NVARCHAR(50));

INSERT INTO @Types(Code)
VALUES
(N'TA2'),
(N'TA3'),
(N'TA4'),
(N'TA5'),
(N'TA6'),
(N'TA7'),
(N'TA8'),
(N'TA9');

;WITH TypesDocuments AS
(
    SELECT Id AS TypeDocumentLabId
    FROM [Lab].[TypeDocumentLab]
    WHERE Code IN (SELECT Code FROM @Types)
      AND IsActive = 1
),
Acces AS
(
    SELECT
        @DirectionSourceId AS DirectionSourceId,
        @DirectionCibleId AS DirectionCibleId,
        TypeDocumentLabId,
        CAST(1 AS BIT) AS AutoriserRecherche,
        CAST(1 AS BIT) AS AutoriserTelechargement,
        CAST(1 AS BIT) AS IsActive
    FROM TypesDocuments
)
MERGE [Commun].[AccesPiecesJointesDirection] AS target
USING Acces AS source
    ON target.DirectionSourceId = source.DirectionSourceId
   AND target.DirectionCibleId = source.DirectionCibleId
   AND target.TypeDocumentLabId = source.TypeDocumentLabId
WHEN MATCHED THEN
    UPDATE SET
        target.AutoriserRecherche = source.AutoriserRecherche,
        target.AutoriserTelechargement = source.AutoriserTelechargement,
        target.IsActive = source.IsActive,
        target.DateModification = SYSDATETIMEOFFSET()
WHEN NOT MATCHED BY TARGET THEN
    INSERT
    (
        DirectionSourceId,
        DirectionCibleId,
        TypeDocumentLabId,
        AutoriserRecherche,
        AutoriserTelechargement,
        DateCreation,
        DateModification,
        CreateurId,
        ModificateurId,
        IsActive
    )
    VALUES
    (
        source.DirectionSourceId,
        source.DirectionCibleId,
        source.TypeDocumentLabId,
        source.AutoriserRecherche,
        source.AutoriserTelechargement,
        SYSDATETIMEOFFSET(),
        NULL,
        NULL,
        NULL,
        source.IsActive
    );
GO

