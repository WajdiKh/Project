public async Task<List<AccesPiecesJointesDirectionAutoriseViewModel>> GetAccesRechercheAutorisesAsync(
    int directionSourceId,
    CancellationToken token = default)
{
    return await _context.AccesPiecesJointesDirections
        .AsNoTracking()
        .Where(x =>
            x.DirectionSourceId == directionSourceId
            && x.AutoriserRecherche
            && x.IsActive)
        .Select(x => new AccesPiecesJointesDirectionAutoriseViewModel
        {
            DirectionCibleId = x.DirectionCibleId,
            TypeDocumentLabId = x.TypeDocumentLabId
        })
        .Distinct()
        .ToListAsync(token);
}

