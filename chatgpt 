@using BacaratWeb.Areas.Transfert.Helpers
@using BacaratWeb.ViewModel.Transfert

@inject IViewTranslator translator

@model ShareDocumentViewModel

@{
    var startDate = Model.StartDate;
    var expiryDate = Model.ExpiryDate;
    var maxDate = Model.DocumentExpiryDate;
}

<div class="card-body">

    @using (Html.BeginForm(FormMethod.Post, new { id = TransfertConstants.ShareDocumentFormId }))
    {
        @Html.HiddenFor(x => x.DocumentId)

        @using (Html.DevExtreme().ValidationGroup(TransfertConstants.ShareDocumentFormValidationGroupName))
        {
            <div class="row mb-3">

                <div class="col-sm-12 col-md-3">
                    <div class="text-truncate text-green">
                        E-mail :
                    </div>
                </div>

                <div class="col-sm-12 col-md-9">
                    @(Html.DevExtreme()
                        .TextArea()
                        .ID("ShareEmails")
                        .Name("Emails")
                        .Height(90)
                        .Width("100%"))
                </div>

            </div>

            <div class="row mb-3">

                <div class="col-sm-12 col-md-6">

                    <div class="mb-2 text-green">
                        Date de début du partage :
                    </div>

                    @(Html.DevExtreme()
                        .DateBox()
                        .ID("ShareStartDate")
                        .Name("StartDate")
                        .Type(DateBoxType.Date)
                        .DisplayFormat("dd/MM/yyyy")
                        .UseMaskBehavior(true)
                        .Value(startDate.LocalDateTime)
                        .Min(DateTime.Now)
                        .Max(maxDate.LocalDateTime)
                        .Width("100%"))

                </div>

                <div class="col-sm-12 col-md-6">

                    <div class="mb-2 text-green">
                        Date d'expiration du partage :
                    </div>

                    @(Html.DevExtreme()
                        .DateBox()
                        .ID("ShareExpiryDate")
                        .Name("ExpiryDate")
                        .Type(DateBoxType.Date)
                        .DisplayFormat("dd/MM/yyyy")
                        .UseMaskBehavior(true)
                        .Value(expiryDate.LocalDateTime)
                        .Min(startDate.LocalDateTime)
                        .Max(maxDate.LocalDateTime)
                        .Width("100%"))

                </div>

            </div>

            <div class="row mt-5">

                <div class="col d-flex justify-content-end align-items-center">

                    <div class="mr-2">
                        @(Html.DevExtreme()
                            .Button()
                            .Text("Envoyer")
                            .Icon("email")
                            .ElementAttr("class", "color-blue")
                            .OnClick("Transfert.Document.saveShareDocument"))
                    </div>

                    <div>
                        @(Html.DevExtreme()
                            .Button()
                            .Text("Annuler")
                            .Icon("close")
                            .ElementAttr("class", "color-red")
                            .OnClick("Transfert.Document.closeShareDocumentPopup"))
                    </div>

                </div>

            </div>
        }
    }
</div>


// ==============================
// FICHIER : document.js
// AJOUTER DANS document.ready
// ==============================

Transfert.Document.initShareButton();


// ==============================
// FICHIER : document.js
// AJOUTER
// ==============================

Transfert.Document.initShareButton = function () {

    $("#btnShareDocument").dxButton({
        text: "Partagés avec d'autres utilisateurs",
        icon: "share",
        disabled: true,

        elementAttr:
        {
            class: "color-green"
        },

        onClick: function () {

            var grid = $("#myDocumentsGrid").dxDataGrid("instance");

            var selectedRows = grid.getSelectedRowsData();

            if (!selectedRows || selectedRows.length === 0) {
                return;
            }

            Transfert.Document.openSharePopup(selectedRows[0].Id);
        }
    });

    var grid = $("#myDocumentsGrid").dxDataGrid("instance");

    if (grid) {

        grid.option("selection", {
            mode: "single"
        });

        grid.option("onSelectionChanged", function (e) {

            var button = $("#btnShareDocument").dxButton("instance");

            button.option(
                "disabled",
                e.selectedRowsData.length === 0);
        });
    }
};

Transfert.Document.openSharePopup = function (documentId) {

    $.ajax({
        method: "GET",
        cache: false,
        url: "/" + culture + "/transfert/share-document/" + documentId

    }).done(function (htmlContent) {

        showScrollablePopup(
            _transfertShareDocumentPopupId,
            htmlContent);

        Transfert.Document.initShareDocumentValidators();

    }).fail(function (e) {

        DevExpress.ui.notify(
            e.responseText || _commonTranslatableMessageErrorLoadForm,
            "error");
    });
};

Transfert.Document.closeShareDocumentPopup = function () {

    closePopup(_transfertShareDocumentPopupId);
};

Transfert.Document.initShareDocumentValidators = function () {

    $("#ShareEmails").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            {
                type: "required",
                message: _transfertTranslatableDocumentShareEmailRequired
            },
            {
                type: "custom",
                message: _transfertTranslatableDocumentShareEmailInvalid,
                validationCallback: function (e) {

                    if (!e.value) {
                        return false;
                    }

                    var emails = e.value
                        .split(";")
                        .map(x => x.trim())
                        .filter(x => x !== "");

                    var regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

                    return emails.every(x => regex.test(x));
                }
            }
        ]
    });

    $("#ShareStartDate").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            {
                type: "required",
                message: _transfertTranslatableDocumentShareStartDateRequired
            }
        ]
    });

    $("#ShareExpiryDate").dxValidator({
        validationGroup: _transfertShareDocumentFormValidationGroupName,
        validationRules: [
            {
                type: "required",
                message: _transfertTranslatableDocumentShareExpiryDateRequired
            }
        ]
    });
};

Transfert.Document.saveShareDocument = function () {

    if (!validateGroup(_transfertShareDocumentFormValidationGroupName)) {
        return;
    }

    var form = $("#" + _transfertShareDocumentFormId)[0];
    var formData = new FormData(form);

    $.ajax({
        url: "/" + culture + "/transfert/save-share-document",
        type: "POST",
        data: formData,
        processData: false,
        contentType: false,

        success: function () {

            DevExpress.ui.notify(
                _transfertDocumentShareSuccess,
                "success",
                3000);

            $("#" + _transfertShareDocumentPopupId)
                .dxPopup("instance")
                .hide();

            Transfert.Document.refreshGrid("myDocumentsGrid");
            Transfert.Document.refreshGrid("sharedDocumentsGrid");
        },

        error: function (xhr) {

            var message =
                xhr.responseText ||
                _transfertDocumentSaveError;

            DevExpress.ui.notify(message, "error", 5000);
        }
    });
};


// ==============================
// FICHIER : DocumentController.cs
// AJOUTER
// ==============================

[HttpGet("{culture:required}/transfert/share-document/{documentId:int}")]
public async Task<IActionResult> ShareDocument(
    int documentId,
    CancellationToken token = default)
{
    var document = await _documentService.GetAsync(documentId, true, token);

    if (document == null)
        return NotFound();

    var now = DateTimeOffset.Now;

    var vm = new ShareDocumentViewModel
    {
        DocumentId = document.Id,
        StartDate = now,
        ExpiryDate = document.ExpiryDate,
        DocumentExpiryDate = document.ExpiryDate
    };

    return PartialView(
        "/Areas/Transfert/Views/Document/_PartialShareDocument.cshtml",
        vm);
}

[HttpPost("{culture:required}/transfert/save-share-document")]
public async Task<IActionResult> SaveShareDocument(
    ShareDocumentViewModel model,
    CancellationToken token = default)
{
    try
    {
        if (!ModelState.IsValid)
            return BadRequest(GetModelStateErrorMessage());

        var document = await _documentService.GetAsync(model.DocumentId, true, token);

        if (document == null)
            return BadRequest("Document introuvable.");

        if (model.StartDate.Date < DateTimeOffset.Now.Date)
            return BadRequest(_translator.Common["Transfert.Document.ShareStartDateInvalid"]);

        if (model.ExpiryDate.Date < model.StartDate.Date)
            return BadRequest(_translator.Common["Transfert.Document.ShareExpiryDateInvalid"]);

        if (model.ExpiryDate.Date > document.ExpiryDate.Date)
            return BadRequest(_translator.Common["Transfert.Document.ShareExpiryDateInvalid"]);

        var emails = model.Emails
            .Split(';', StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x.Trim())
            .Distinct()
            .ToList();

        foreach (var email in emails)
        {
            var user = await _utilisateurService
                .GetUtilisateurByEmailAsync(email, token);

            if (user == null)
                continue;

            var share = new DocumentShare
            {
                DocumentId = document.Id,
                SharedWithUserId = user.Id,
                Email = email,
                SharedDate = model.StartDate,
                ExpiryDate = model.ExpiryDate
            };

            document.DocumentShares ??= new List<DocumentShare>();
            document.DocumentShares.Add(share);
        }

        var saved = await _documentService.UpdateAsync(document, token);

        if (!saved)
            return BadRequest(_translator.Common["Transfert.Document.SaveError"]);

        return Ok(new { success = true });
    }
    catch (Exception ex)
    {
        _logger.TraceError(ex);

        return StatusCode(
            500,
            _translator.Common["Transfert.Document.SaveError"]);
    }
}