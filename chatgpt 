var _transfertTranslatableDocumentShareStartDateRequired =
    "@Html.Raw(translator.Common["Transfert.Document.ShareStartDateRequired"])";

var _transfertTranslatableDocumentShareExpiryDateRequired =
    "@Html.Raw(translator.Common["Transfert.Document.ShareExpiryDateRequired"])";

var _transfertDocumentShareSuccess =
    "@Html.Raw(translator.Common["Transfert.Document.ShareSuccess"])";


