using BacaratWeb.ViewModel.Transfert;
using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Authorization;
using System.Collections.Generic;

namespace BacaratWeb.Areas.Transfert.Controllers
{
    [Authorize]
    [Area("Transfert")]
    public class DocumentController : Controller
    {
        [Route("{culture:required}/transfert/document/{mode?}")]
        public IActionResult Index(string mode="all")
        {
            ViewBag.Mode = mode;
            return View();
        }

        [HttpGet]
        public IActionResult GetMyDocuments()
        {
            var data = new List<DocumentViewModel>();
            return Json(data);
        }

        [HttpGet]
        public IActionResult GetSharedWithMeDocuments()
        {
            var data = new List<DocumentViewModel>();
            return Json(data);
        }

        [HttpPost]
public async Task<IActionResult> Add(AddDocumentViewModel model)
{
    if (!ModelState.IsValid)
        return BadRequest("Données invalides.");

    if (model.File == null || model.File.Length == 0)
        return BadRequest("Fichier obligatoire.");

    if (model.File.Length > 10 * 1024 * 1024)
        return BadRequest("Fichier trop volumineux.");

    byte[] fileBytes;
    using (var ms = new MemoryStream())
    {
        await model.File.CopyToAsync(ms);
        fileBytes = ms.ToArray();
    }

    // ⚠️ temporaire (à remplacer par user connecté)
    var userId = 1;

    var document = new Document
    {
        Name = model.Name,
        Description = model.Description,
        FileContent = fileBytes,
        FileSize = model.File.Length,
        ContentType = model.File.ContentType,
        UploadDate = DateTimeOffset.Now,
        ExpiryDate = model.ExpiryDate ?? DateTimeOffset.Now.AddDays(2),
        OwnerId = userId,
        SecurityCode = Guid.NewGuid().ToString("N").Substring(0, 6)
    };

    var share = new DocumentShare
    {
        Email = model.RecipientEmail,
        SharedDate = DateTimeOffset.Now,
        ExpiryDate = document.ExpiryDate
    };

    // ⚠️ pour l'instant sans service
    _context.Documents.Add(document);
    share.Document = document;
    _context.DocumentShares.Add(share);

    await _context.SaveChangesAsync();

    return Ok(new { success = true });
}
        }

        [HttpPost]
        public IActionResult Delete(int id)
        {
            return Ok(new { success = true });
        }

        [HttpGet]
        public IActionResult Download(int id)
        {
            var vm = new DownloadDocumentViewModel
            {
                DocumentId = id
            };

            return View(vm);
        }

        [HttpPost]
        public IActionResult ValidateSecurityCode(DownloadDocumentViewModel model)
        {
            if (!ModelState.IsValid)
                return BadRequest("Code de sécurité invalide.");

            return Ok(new
            {
                success = true,
                downloadUrl = Url.Action("DownloadFile", "Document", new { area = "Transfert", id = model.DocumentId })
            });
        }

        [HttpGet]
        public IActionResult DownloadFile(int id)
        {
            return BadRequest("Téléchargement non implémenté.");
        }
    }

private static string GenerateSecurityCode()
{
    return Guid.NewGuid().ToString("N").Substring(0, 6).ToUpperInvariant();
}
[HttpPost]
[Route("{culture:required}/transfert/document/save-document")]
public async Task<IActionResult> SaveDocument(AddDocumentViewModel model, CancellationToken token)
{
    if (!ModelState.IsValid)
        return BadRequest(GetModelStateErrorMessage());

    if (!new[] { 24, 48, 72 }.Contains(model.ExpiryDelayHours))
        return BadRequest("Délai d'expiration invalide.");

    var allowedExtensions = new[] { ".zip", ".rar", ".tar", ".gz", ".7z" };
    var extension = Path.GetExtension(model.File.FileName)?.ToLowerInvariant();

    if (string.IsNullOrWhiteSpace(extension) || !allowedExtensions.Contains(extension))
        return BadRequest("Tous les fichiers doivent être zippés : rar, tar, gz, zip, 7z.");

    if (model.File.Length > 10 * 1024 * 1024)
        return BadRequest("La taille du document ne doit pas dépasser 10Mo.");

    var recipient = await _utilisateurService.GetUtilisateurByEmailAsync(model.RecipientEmail, token);

    if (recipient == null)
    {
        return BadRequest("L'utilisateur n'existe pas dans BacaratWeb Transfert. Merci d'effectuer une demande d'habilitation pour le destinataire.");
    }

    var statutActif = await _documentService.GetStatutDocumentByCodeAsync("Active", token);

    if (statutActif == null)
        return BadRequest("Le statut actif est introuvable.");

    byte[] fileContent;
    using (var memoryStream = new MemoryStream())
    {
        await model.File.CopyToAsync(memoryStream, token);
        fileContent = memoryStream.ToArray();
    }

    var now = DateTimeOffset.Now;
    var expiryDate = now.AddHours(model.ExpiryDelayHours);

    var document = new Document
    {
        Name = model.Name,
        Description = model.Description,
        OriginalFileName = model.File.FileName,
        FileExtension = extension,
        ContentType = model.File.ContentType,
        FileContent = fileContent,
        FileSize = model.File.Length,
        UploadDate = now,
        ExpiryDate = expiryDate,
        OwnerId = CurrentUser.Id,
        StatutDocumentId = statutActif.Id,
        SecurityCode = GenerateSecurityCode(),
        EncryptionKey = model.EncryptionKey
    };

    var documentShare = new DocumentShare
    {
        SharedWithUserId = recipient.Id,
        Email = recipient.Email,
        SharedDate = now,
        ExpiryDate = expiryDate
    };

    var saved = await _documentService.AddDocumentAsync(document, documentShare, token);

    if (!saved)
        return BadRequest("Erreur lors de l'enregistrement du document.");

    return Ok(new { success = true });
}

private static string GenerateSecurityCode()
{
    return Guid.NewGuid().ToString("N").Substring(0, 6).ToUpperInvariant();
}

private string GetModelStateErrorMessage()
{
    var errorKey = ModelState.Values
        .SelectMany(v => v.Errors)
        .Select(e => e.ErrorMessage)
        .FirstOrDefault();

    if (string.IsNullOrWhiteSpace(errorKey))
        return "Données invalides.";

    return _translator.Common[errorKey];
}
}
