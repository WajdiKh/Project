        [HttpGet]
        public IActionResult GetSharedWithMeDocuments()
        {
            var data = new List<DocumentViewModel>();
            return Json(data);
        }

            [HttpPost("{culture:required}/transfert/save-document")]
        public async Task<IActionResult> SaveDocument(AddDocumentViewModel model, CancellationToken token = default)
        {
            try
            {
                if (!ModelState.IsValid)
                    return BadRequest(GetModelStateErrorMessage());

                if (!new[] { 24, 48, 72 }.Contains(model.ExpiryDelayHours))
                    return BadRequest(_translator.Common["Transfert.Document.ExpiryDelayHoursRange"]);

                var allowedExtensions = new[] { ".zip", ".rar", ".tar", ".gz", ".7z" };
                var extension = Path.GetExtension(model.File.FileName)?.ToLowerInvariant();

                if (string.IsNullOrWhiteSpace(extension) || !allowedExtensions.Contains(extension))
                    return BadRequest(_translator.Common["Transfert.Document.FileExtension"]);

                if (model.File.Length > 10 * 1024 * 1024)
                    return BadRequest(_translator.Common["Transfert.Document.FileSize"]);

                var recipient = await _utilisateurService.GetUtilisateurByEmailAsync(model.RecipientEmail, token);

                var statutActif = await _documentService.GetStatutDocumentByCodeAsync(nameof(StatutDocumentTransfert.Active), token);

                if (statutActif == null)
                    throw new CustomMessageException("Active status not found");

                byte[] fileContent;
                using (var memoryStream = new MemoryStream())
                {
                    await model.File.CopyToAsync(memoryStream, token);
                    fileContent = memoryStream.ToArray();
                }

                var now = DateTimeOffset.Now;
                var expiryDate = now.AddHours(model.ExpiryDelayHours);

                var document = new Document
                {
                    Name = model.Name,
                    Description = model.Description,
                    OriginalFileName = model.File.FileName,
                    FileExtension = extension,
                    ContentType = model.File.ContentType,
                    FileContent = fileContent,
                    FileSize = model.File.Length,
                    UploadDate = now,
                    ExpiryDate = expiryDate,
                    OwnerId = CurrentUser.Id,
                    StatutDocumentId = statutActif.Id,
                    SecurityCode = GenerateSecurityCode(),
                    EncryptionKey = model.EncryptionKey
                };
                
                var saved = await _documentService.AddDocumentAsync(document, token);

                if (!saved)
                    return BadRequest(_translator.Common["Transfert.Document.ErrorWhileSavingDocument"]);

                var notificationSent = await SendNotificationDocumentPartage(recipient, document, token);

                if(!notificationSent)
                {
                    throw new CustomMessageException("Failed to send Notification");
                }
                
                return Ok(new { success = true });
            }
            catch(Exception ex)
            {
                _logger.TraceError(ex);
                return StatusCode(500, _translator.Common["Transfert.Document.ErrorWhileSavingDocument"]);
            }
        }

        private async Task<bool> SendNotificationDocumentPartage(
            Utilisateur recipient, 
            Document document, 
            CancellationToken token = default)
        {
            var template = await _emailNotificationTemplateService.GetEmailNotification(
                (int)ActiviteModule.TRANSFERT, 
                (int)NotificationType.DocumentPartage, 
                recipient.LangueId, 
                token);

            if(template == null)
            {
                throw new CustomMessageException("Notification template not found");
            }
            
            var cultureInfo = Culture.GetCultureByLanguageId(template.LangueId);

            var bodyArgs = new object[] {
                document.Name,
                CurrentUser.FullName,
                document.UploadDate.ToString("dddd d MMMM yyyy HH:mm:ss 'UTC'zzz", cultureInfo),
                document.ExpiryDate.ToString("dddd d MMMM yyyy HH:mm:ss 'UTC'zzz", cultureInfo),
                null,
                document.SecurityCode,
                document.EncryptionKey
            };
            
            var emailNotification = new EmailNotification
            {
                EmailTo = recipient.Email,
                Subject = template.Subject,
                Body = string.Format(cultureInfo, template.Body, bodyArgs),
                DateNotification = DateTime.Now
            };
            
            return await _emailNotificationService.PushNotification(emailNotification, token);
        }

        private static string GenerateSecurityCode()
        {
            return Guid.NewGuid().ToString("N").Substring(0, 6).ToUpperInvariant();
        }

        private string GetModelStateErrorMessage()
        {
            var errorKey = ModelState.Values
                .SelectMany(v => v.Errors)
                .Select(e => e.ErrorMessage)
                .FirstOrDefault();

            if (string.IsNullOrWhiteSpace(errorKey))
                return "Données invalides.";

            return _translator.Common[errorKey];
        }

        [Route("{culture}/transfert/add-document")]
        public IActionResult AddNewDocument()
        {
            if(!CanAddNewDocument())
            {
                return new StatusCodeResult(StatusCodes.Status403Forbidden);
            }

            return PartialView("/Areas/Transfert/Views/Document/_PartialAddNewDocument.cshtml");
        }
        
        private bool CanAddNewDocument()
        {
            return _roleAccessUser.HasRoles(null, null, RoleUser.AdminGlobal) ||
            _roleAccessUser.HasClaims(ActiviteModule.TRANSFERT, ClaimUser.WRITE, null);
        }

        [HttpPost]
        public IActionResult Delete(int id)
        {
            return Ok(new { success = true });
        }

        [HttpGet]
        public IActionResult Download(int id)
        {
            var vm = new DownloadDocumentViewModel
            {
                DocumentId = id
            };

            return View(vm);
        }

        [HttpPost]
        public IActionResult ValidateSecurityCode(DownloadDocumentViewModel model)
        {
            if (!ModelState.IsValid)
                return BadRequest("Code de sécurité invalide.");

            return Ok(new
            {
                success = true,
                downloadUrl = Url.Action("DownloadFile", "Document", new { area = "Transfert", id = model.DocumentId })
            });
        }

        [HttpGet]
        public IActionResult DownloadFile(int id)
        {
            return BadRequest("Téléchargement non implémenté.");
        }
